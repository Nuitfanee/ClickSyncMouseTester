<Window x:Class="Views.Shell.StartupNavigationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WpfApp1.Converters"
        xmlns:navigation="clr-namespace:WpfApp1.Navigation"
        Title="{DynamicResource Window.Title}"
        Width="{StaticResource Layout.Window.DefaultWidth}"
        Height="{StaticResource Layout.Window.DefaultHeight}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{DynamicResource Font.Body}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextRenderingMode="{StaticResource TextRenderingMode.ClearType}"
        TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.Body}"
        TextOptions.TextHintingMode="{StaticResource TextHintingMode.UI}">
    <Window.Resources>
        <converters:NavigationMenuForegroundConverter x:Key="NavigationMenuForegroundConverter" />
        <converters:NavigationMenuIndexConverter x:Key="NavigationMenuIndexConverter" />
    </Window.Resources>

    <Grid x:Name="StartupInteractionRoot"
          Background="Transparent"
          IsHitTestVisible="False">
        <Border x:Name="NavigationCurtainSurface"
                Panel.ZIndex="120"
                Background="{DynamicResource NavigationCurtainBackgroundBrush}"
                BorderBrush="{DynamicResource NavigationCurtainBorderBrush}"
                BorderThickness="0"
                Visibility="Collapsed"
                SizeChanged="NavigationCurtainSurface_SizeChanged">
            <Border.Clip>
                <RectangleGeometry x:Name="NavigationCurtainClipGeometry" Rect="0,0,0,0" />
            </Border.Clip>
            <Grid x:Name="NavigationCurtainContent"
                  RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
                <Border Background="Transparent" />
                <Border x:Name="NavigationCurtainVerticalGuide"
                        Width="1"
                        Background="{DynamicResource NavigationMenuTextBrush}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Panel.ZIndex="1"
                        IsHitTestVisible="False" />
                <Grid x:Name="NavigationCurtainLayoutRoot"
                      Margin="{StaticResource Layout.Navigation.OverlayPadding}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="NavigationCurtainTopGuideRow" Height="0" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="NavigationCurtainLeftGuideColumn" Width="0" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Height="1"
                            Background="{DynamicResource NavigationMenuTextBrush}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="1"
                            IsHitTestVisible="False" />
                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Margin="0"
                                Panel.ZIndex="2"
                                RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="-20"
                                                Y="-30" />
                        </StackPanel.RenderTransform>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,28,0">
                            <Button x:Name="NavigationGithubLinkButton"
                                    Width="36"
                                    Height="36"
                                    Foreground="{DynamicResource NavigationMenuTextBrush}"
                                    ToolTip="GitHub / Nuitfanee"
                                    Click="GithubLinkButton_Click"
                                    Style="{StaticResource HeaderToggleLinkButtonStyle}"
                                    VerticalAlignment="Center">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="F1 M 8,0.25 C 3.72,0.25 0.25,3.72 0.25,8 C 0.25,11.43 2.47,14.34 5.55,15.37 C 5.95,15.44 6.09,15.2 6.09,14.99 C 6.09,14.81 6.08,14.22 6.07,13.43 C 3.87,13.91 3.4,12.37 3.4,12.37 C 3.04,11.45 2.52,11.2 2.52,11.2 C 1.8,10.71 2.58,10.72 2.58,10.72 C 3.38,10.78 3.8,11.54 3.8,11.54 C 4.5,12.76 5.66,12.4 6.11,12.19 C 6.18,11.67 6.39,11.31 6.63,11.1 C 4.87,10.9 3.02,10.22 3.02,7.19 C 3.02,6.33 3.32,5.62 3.82,5.07 C 3.74,4.87 3.48,4.06 3.89,2.96 C 3.89,2.96 4.56,2.75 6.08,3.78 C 6.72,3.6 7.4,3.51 8.08,3.51 C 8.76,3.51 9.44,3.6 10.08,3.78 C 11.6,2.75 12.27,2.96 12.27,2.96 C 12.68,4.06 12.42,4.87 12.34,5.07 C 12.84,5.62 13.14,6.33 13.14,7.19 C 13.14,10.23 11.28,10.9 9.52,11.1 C 9.82,11.36 10.09,11.87 10.09,12.66 C 10.09,13.8 10.08,14.72 10.08,14.99 C 10.08,15.2 10.22,15.45 10.63,15.37 C 13.7,14.33 15.91,11.43 15.91,8 C 15.91,3.72 12.44,0.25 8.16,0.25 L 8,0.25 Z" />
                                </Viewbox>
                            </Button>
                            <TextBlock Text="BY NUITFANEE"
                                       Margin="10,0,0,0"
                                       Style="{StaticResource NavigationToggleActiveTextStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid Margin="0,0,40,0"
                              VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="NavigationLanguageChineseButton"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Command="{Binding ToggleLanguageCommand}"
                                    ToolTip="{Binding LanguageToggleText}"
                                    Tag="{Binding IsChineseLanguageCurrent}"
                                    Style="{StaticResource HeaderToggleLinkButtonStyle}">
                                <TextBlock Text="简中"
                                           Style="{StaticResource NavigationToggleLinkTextStyle}" />
                            </Button>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="8,0"
                                       Text="/"
                                       Style="{StaticResource NavigationToggleDividerTextStyle}" />

                            <Button x:Name="NavigationLanguageEnglishButton"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Command="{Binding ToggleLanguageCommand}"
                                    ToolTip="{Binding LanguageToggleText}"
                                    Tag="{Binding IsEnglishLanguageCurrent}"
                                    Style="{StaticResource HeaderToggleLinkButtonStyle}">
                                <TextBlock Text="EN"
                                           Style="{StaticResource NavigationToggleLinkTextStyle}" />
                            </Button>

                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    Height="1"
                                    Margin="0,2,0,0"
                                    Background="{DynamicResource NavigationMenuTextBrush}"
                                    RenderTransformOrigin="0,0.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0" />
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0" ScaleY="1" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, ElementName=NavigationLanguageChineseButton}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Tag, ElementName=NavigationLanguageChineseButton}" Value="False" />
                                                    <Condition Binding="{Binding IsMouseOver, ElementName=NavigationLanguageChineseButton}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Opacity" Value="1" />
                                                <MultiDataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiDataTrigger.EnterActions>
                                                <MultiDataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="0"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiDataTrigger.ExitActions>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="2"
                                    Height="1"
                                    Margin="0,2,0,0"
                                    Background="{DynamicResource NavigationMenuTextBrush}"
                                    RenderTransformOrigin="0,0.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0" />
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0" ScaleY="1" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, ElementName=NavigationLanguageEnglishButton}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Tag, ElementName=NavigationLanguageEnglishButton}" Value="False" />
                                                    <Condition Binding="{Binding IsMouseOver, ElementName=NavigationLanguageEnglishButton}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Opacity" Value="1" />
                                                <MultiDataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiDataTrigger.EnterActions>
                                                <MultiDataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="0"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiDataTrigger.ExitActions>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,28,0"
                              VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="NavigationThemeLightButton"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Command="{Binding ToggleThemeCommand}"
                                    ToolTip="{Binding ThemeToggleText}"
                                    Tag="{Binding IsLightThemeCurrent}"
                                    Style="{StaticResource HeaderToggleLinkButtonStyle}">
                                <TextBlock Text="{DynamicResource Theme.Toggle.KeyLight}"
                                           Style="{StaticResource NavigationToggleLinkTextStyle}" />
                            </Button>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="8,0"
                                       Text="/"
                                       Style="{StaticResource NavigationToggleDividerTextStyle}" />

                            <Button x:Name="NavigationThemeDarkButton"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Command="{Binding ToggleThemeCommand}"
                                    ToolTip="{Binding ThemeToggleText}"
                                    Tag="{Binding IsDarkThemeCurrent}"
                                    Style="{StaticResource HeaderToggleLinkButtonStyle}">
                                <TextBlock Text="{DynamicResource Theme.Toggle.KeyDark}"
                                           Style="{StaticResource NavigationToggleLinkTextStyle}" />
                            </Button>

                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    Height="1"
                                    Margin="0,2,0,0"
                                    Background="{DynamicResource NavigationMenuTextBrush}"
                                    RenderTransformOrigin="0,0.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0" />
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0" ScaleY="1" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, ElementName=NavigationThemeLightButton}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Tag, ElementName=NavigationThemeLightButton}" Value="False" />
                                                    <Condition Binding="{Binding IsMouseOver, ElementName=NavigationThemeLightButton}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Opacity" Value="1" />
                                                <MultiDataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiDataTrigger.EnterActions>
                                                <MultiDataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="0"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiDataTrigger.ExitActions>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="2"
                                    Height="1"
                                    Margin="0,2,0,0"
                                    Background="{DynamicResource NavigationMenuTextBrush}"
                                    RenderTransformOrigin="0,0.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0" />
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0" ScaleY="1" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag, ElementName=NavigationThemeDarkButton}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Tag, ElementName=NavigationThemeDarkButton}" Value="False" />
                                                    <Condition Binding="{Binding IsMouseOver, ElementName=NavigationThemeDarkButton}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Opacity" Value="1" />
                                                <MultiDataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiDataTrigger.EnterActions>
                                                <MultiDataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="0"
                                                                             Duration="0:0:0.3"
                                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </MultiDataTrigger.ExitActions>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                            <Viewbox Width="28"
                                     Height="28"
                                     Stretch="Uniform"
                                     VerticalAlignment="Center">
                                <Grid Width="24"
                                      Height="24"
                                      SnapsToDevicePixels="True"
                                      UseLayoutRounding="True">
                                    <Grid.Resources>
                                        <Storyboard x:Key="NavigationLocalSpinnerStoryboard"
                                                    RepeatBehavior="Forever">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="NavigationLocalSpinnerOrbitScale"
                                                                           Storyboard.TargetProperty="ScaleX">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0.02" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:2" Value="1" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:3" Value="0.02" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:4" Value="1" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="NavigationLocalSpinnerMeridianScale"
                                                                           Storyboard.TargetProperty="ScaleX">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.02" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="1" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:2" Value="0.02" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:3" Value="1" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:4" Value="0.02" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="NavigationLocalSpinnerMeridian"
                                                                           Storyboard.TargetProperty="Opacity">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.16" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="1" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:2" Value="0.16" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:3" Value="1" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:4" Value="0.16" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </Grid.Resources>
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard Storyboard="{StaticResource NavigationLocalSpinnerStoryboard}" />
                                        </EventTrigger>
                                    </Grid.Triggers>

                                    <Canvas Width="20"
                                            Height="20"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <Path Fill="{DynamicResource NavigationMenuTextBrush}"
                                              Data="M10,20C4.5,20,0,15.5,0,10C0,4.5,4.5,0,10,0c5.5,0,10,4.5,10,10C20,15.5,15.5,20,10,20z M10,1c-5,0-9,4-9,9c0,5,4,9,9,9 c5,0,9-4,9-9C19,5,15,1,10,1z" />
                                        <Rectangle Canvas.Left="1"
                                                   Canvas.Top="6.3"
                                                   Width="17.9"
                                                   Height="1"
                                                   Fill="{DynamicResource NavigationMenuTextBrush}" />
                                        <Rectangle Canvas.Left="1"
                                                   Canvas.Top="12.7"
                                                   Width="17.9"
                                                   Height="1"
                                                   Fill="{DynamicResource NavigationMenuTextBrush}" />
                                        <Canvas Width="20"
                                                Height="20"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Canvas.RenderTransform>
                                                <ScaleTransform x:Name="NavigationLocalSpinnerOrbitScale"
                                                                ScaleX="1"
                                                                ScaleY="1" />
                                            </Canvas.RenderTransform>
                                            <Ellipse Width="20"
                                                     Height="20"
                                                     Stroke="{DynamicResource NavigationMenuTextBrush}"
                                                     StrokeThickness="1"
                                                     Opacity="0.96" />
                                        </Canvas>
                                        <Rectangle x:Name="NavigationLocalSpinnerMeridian"
                                                   Canvas.Left="9.5"
                                                   Canvas.Top="0"
                                                   Width="1"
                                                   Height="20"
                                                   Fill="{DynamicResource NavigationMenuTextBrush}"
                                                   Opacity="0.16"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <ScaleTransform x:Name="NavigationLocalSpinnerMeridianScale"
                                                                ScaleX="0.02"
                                                                ScaleY="1" />
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                            <TextBlock x:Name="NavigationLocalClockText"
                                       Margin="8,0,0,0"
                                       Text="00:00:00"
                                       VerticalAlignment="Center"
                                       FontFamily="{DynamicResource Font.ListDisplay}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource NavigationMenuTextBrush}"
                                       TextOptions.TextRenderingMode="{StaticResource TextRenderingMode.Grayscale}"
                                       TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.UI}"
                                       Typography.NumeralAlignment="Tabular"
                                       Typography.NumeralStyle="Lining" />
                        </StackPanel>
                    </StackPanel>

                    <Border x:Name="NavigationBrandQuadrant"
                            Grid.Row="1"
                            Grid.Column="0"
                            Background="{DynamicResource NavigationCurtainBackgroundBrush}"
                            ClipToBounds="True"
                            Panel.ZIndex="0"
                            SizeChanged="NavigationBrandQuadrant_SizeChanged"
                            IsHitTestVisible="False">
                        <Border.Clip>
                            <RectangleGeometry x:Name="NavigationBrandQuadrantClipGeometry"
                                               Rect="0,0,0,0" />
                        </Border.Clip>
                        <Viewbox Stretch="Fill"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch">
                            <Canvas Width="409"
                                    Height="760"
                                    SnapsToDevicePixels="True"
                                    UseLayoutRounding="True">
                                <Polygon x:Name="NavigationBrandPolygonPrimary"
                                         Fill="Black"
                                         Points="0,760 0,559.3 0,0 166.5,0 409,0 409,760" />
                                <Polygon x:Name="NavigationBrandPolygonSecondary"
                                         Fill="Black"
                                         Points="409,0 409,0 242.5,0 242.5,0 409,0" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <Button x:Name="NavigationCurtainCloseButton"
                            Grid.Row="0"
                            Grid.Column="0"
                            Click="NavigationCurtainCloseButton_Click"
                            Style="{StaticResource NavigationCurtainCloseButtonStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0"
                            Panel.ZIndex="3">
                        <Button.RenderTransform>
                            <TranslateTransform Y="-30" />
                        </Button.RenderTransform>
                    </Button>

                    <Grid Grid.Row="1"
                          Grid.Column="1"
                          Margin="{DynamicResource Layout.Navigation.MenuRegionMargin.Localized}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          Panel.ZIndex="1">
                        <ScrollViewer x:Name="NavigationMenuScrollViewer"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Hidden"
                                      CanContentScroll="False"
                                      Background="Transparent"
                                      Width="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=ActualWidth}"
                                      MaxWidth="{DynamicResource Layout.Navigation.ContentMaxWidth.Localized}"
                                      MaxHeight="{DynamicResource Layout.Navigation.MenuMaxHeight.Localized}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Top"
                                      SizeChanged="NavigationMenuScrollViewer_SizeChanged">
                            <ItemsControl x:Name="NavigationMenuItemsControl"
                                          ItemsSource="{Binding Pages}"
                                          HorizontalAlignment="Stretch">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type navigation:AppPageDescriptor}">
                                        <Button Command="{Binding DataContext.NavigateToPageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Stretch"
                                                PreviewMouseLeftButtonDown="NavigationMenuButton_PreviewMouseLeftButtonDown"
                                                PreviewKeyDown="NavigationMenuButton_PreviewKeyDown"
                                                MouseEnter="NavigationMenuButton_MouseEnter"
                                                MouseLeave="NavigationMenuButton_MouseLeave"
                                                Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ViewportWidth}"
                                                Style="{StaticResource NavigationCurtainMenuButtonStyle}">
                                            <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ViewportWidth}"
                                                  HorizontalAlignment="Center">
                                                <Border VerticalAlignment="Center"
                                                        HorizontalAlignment="Stretch"
                                                        Background="Transparent"
                                                        ClipToBounds="True">
                                                    <Grid x:Name="MenuItemAnimatedContent"
                                                          MaxWidth="{DynamicResource Layout.Navigation.ContentMaxWidth.Localized}"
                                                          HorizontalAlignment="Stretch"
                                                          Margin="{DynamicResource Layout.Navigation.ContentStartMargin.Localized}"
                                                          VerticalAlignment="Center"
                                                          SnapsToDevicePixels="True"
                                                          UseLayoutRounding="True"
                                                          RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
                                                        <StackPanel HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    Orientation="Vertical">
                                                            <StackPanel Orientation="Horizontal"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,0,0,4">
                                                                <TextBlock x:Name="MenuIndexTextBlock"
                                                                           Margin="0,0,10,0"
                                                                           Text="{Binding PageKey, Converter={StaticResource NavigationMenuIndexConverter}}"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Center"
                                                                           TextAlignment="Left"
                                                                           Style="{StaticResource NavigationMenuIndexTextStyle}">
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource NavigationMenuForegroundConverter}">
                                                                            <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.CurrentPageKey" />
                                                                            <Binding Path="PageKey" />
                                                                            <Binding RelativeSource="{RelativeSource AncestorType=Button}" Path="IsMouseOver" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                                <TextBlock x:Name="MenuMetaTextBlock"
                                                                           Text="{Binding DisplayMenuMeta}"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Center"
                                                                           TextAlignment="Left"
                                                                           Style="{StaticResource NavigationMenuMetaTextStyle}">
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource NavigationMenuForegroundConverter}">
                                                                            <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.CurrentPageKey" />
                                                                            <Binding Path="PageKey" />
                                                                            <Binding RelativeSource="{RelativeSource AncestorType=Button}" Path="IsMouseOver" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <Border Margin="{DynamicResource Layout.Navigation.TitleMaskMargin.Localized}"
                                                                    Padding="{DynamicResource Layout.Navigation.TitleMaskPadding.Localized}"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    Background="Transparent"
                                                                    ClipToBounds="False">
                                                                <TextBlock x:Name="MenuTitleTextBlock"
                                                                           Text="{Binding DisplayMenuTitle}"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Center"
                                                                           TextAlignment="Left"
                                                                           Style="{StaticResource NavigationMenuTitleTextStyle}">
                                                                    <TextBlock.RenderTransform>
                                                                        <TranslateTransform />
                                                                    </TextBlock.RenderTransform>
                                                                    <TextBlock.Foreground>
                                                                        <MultiBinding Converter="{StaticResource NavigationMenuForegroundConverter}">
                                                                            <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.CurrentPageKey" />
                                                                            <Binding Path="PageKey" />
                                                                            <Binding RelativeSource="{RelativeSource AncestorType=Button}" Path="IsMouseOver" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
