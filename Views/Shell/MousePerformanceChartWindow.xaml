<Window x:Class="Views.Shell.MousePerformanceChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WpfApp1.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitleText}"
        Width="1400"
        Height="1040"
        MinWidth="1320"
        MinHeight="980"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        FontFamily="{DynamicResource Font.Body}"
        TextOptions.TextRenderingMode="{StaticResource TextRenderingMode.ClearType}"
        TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.UI}"
        TextOptions.TextHintingMode="{StaticResource TextHintingMode.UI}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{StaticResource Layout.Chrome.CaptionHeight}"
                            ResizeBorderThickness="{StaticResource Layout.Chrome.ResizeBorderThickness}"
                            CornerRadius="{StaticResource Layout.Window.CornerRadius}"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="MousePerformanceChartOuterBorderBrush"
                         Color="#E4B3B3" />

        <Style x:Key="MousePerformanceChartToolbarTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource KeyDetectionThresholdTextBoxStyle}">
            <Setter Property="Width" Value="116" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="EditorialInputSurface"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0,8,0,7"
                                              VerticalAlignment="Center" />
                            </Border>
                            <Rectangle x:Name="EditorialInputTopRule"
                                       Height="1"
                                       VerticalAlignment="Top"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.18" />
                            <Rectangle x:Name="EditorialInputBottomRule"
                                       Height="1"
                                       VerticalAlignment="Bottom"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.82" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorialInputSurface" Property="Background" Value="#08FFFFFF" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorialInputSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Opacity" Value="1" />
                                <Setter TargetName="EditorialInputTopRule" Property="Opacity" Value="0.32" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorialInputSurface" Property="Opacity" Value="0.36" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MousePerformanceChartWindowTitleStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="MousePerformanceChartWindowHintStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HintTextStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>

        <Style x:Key="MousePerformanceChartToolbarLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
        </Style>

        <Style x:Key="MousePerformanceChartToolbarSupplementStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HintTextStyle}">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="LineHeight" Value="15" />
            <Setter Property="MaxHeight" Value="30" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="MousePerformanceChartToolbarCheckBoxStyle"
               TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0,0,0,2" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="EditorialToggleSurface"
                                    Background="{TemplateBinding Background}" />
                            <Rectangle x:Name="EditorialToggleTopRule"
                                       Height="1"
                                       VerticalAlignment="Top"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.18" />
                            <Rectangle x:Name="EditorialToggleBottomRule"
                                       Height="1"
                                       VerticalAlignment="Bottom"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.82" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,2">
                                <Border x:Name="EditorialToggleMarker"
                                        Width="10"
                                        Height="10"
                                        Margin="0,0,8,0"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        Background="Transparent" />
                                <ContentPresenter VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorialToggleSurface" Property="Background" Value="#08FFFFFF" />
                                <Setter TargetName="EditorialToggleBottomRule" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="EditorialToggleBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorialToggleSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialToggleBottomRule" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="EditorialToggleBottomRule" Property="Opacity" Value="1" />
                                <Setter TargetName="EditorialToggleTopRule" Property="Opacity" Value="0.32" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="EditorialToggleMarker" Property="Background" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialToggleMarker" Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialToggleBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialToggleBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorialToggleSurface" Property="Opacity" Value="0.36" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MousePerformanceChartTitleBarEditorialButtonStyle"
               TargetType="Button">
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="EditorialButtonSurface"
                                    Background="{TemplateBinding Background}" />
                            <Rectangle x:Name="EditorialButtonTopRule"
                                       Height="1"
                                       VerticalAlignment="Top"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.18" />
                            <Rectangle x:Name="EditorialButtonBottomRule"
                                       Height="1"
                                       VerticalAlignment="Bottom"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.82" />
                            <ContentPresenter x:Name="EditorialButtonContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="#08FFFFFF" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialButtonContent" Property="Margin" Value="18,1,18,-1" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorialButtonSurface" Property="Opacity" Value="0.34" />
                                <Setter TargetName="EditorialButtonContent" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="WindowPresentationSurface"
          Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource Layout.Chrome.RowHeight}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Margin="{StaticResource Layout.OuterFrame.Margin}"
                BorderBrush="{StaticResource MousePerformanceChartOuterBorderBrush}"
                BorderThickness="{StaticResource Thickness.WindowOuterBorder.All}"
                CornerRadius="{StaticResource Layout.Window.CornerRadius}"
                SnapsToDevicePixels="True"
                IsHitTestVisible="False" />

        <Border Grid.Row="0"
                Background="{DynamicResource GlassTitleBarBackgroundBrush}"
                BorderBrush="{StaticResource MousePerformanceChartOuterBorderBrush}"
                BorderThickness="1,1,1,0"
                CornerRadius="{StaticResource Layout.Window.TopCornerRadius}">
            <Grid>
                <Border BorderBrush="{DynamicResource GlassTitleBarBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="{StaticResource Layout.Window.TopCornerRadius}" />

                <Grid Margin="{StaticResource Layout.Chrome.ContentMargin}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center"
                                Margin="18,0,18,0">
                        <TextBlock Text="{Binding WindowTitleText}"
                                   Style="{StaticResource MousePerformanceChartWindowTitleStyle}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            MinWidth="112"
                            Margin="0,0,8,0"
                            Click="SavePngButton_Click"
                            Content="{DynamicResource MousePerformance.Chart.Action.SavePng}"
                            Style="{StaticResource MousePerformanceChartTitleBarEditorialButtonStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />

                    <Button Grid.Column="2"
                            Click="MinimizeButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="{StaticResource Layout.Chrome.GlyphFontSize}"
                                   TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.UI}"
                                   Text="&#xE921;" />
                    </Button>

                    <Button x:Name="MaximizeRestoreButton"
                            Grid.Column="3"
                            Click="MaximizeRestoreButton_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock x:Name="MaximizeRestoreGlyph"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="{StaticResource Layout.Chrome.GlyphFontSize}"
                                   TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.UI}"
                                   Text="&#xE922;" />
                    </Button>

                    <Button Grid.Column="4"
                            Click="CloseButton_Click"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="{StaticResource Layout.Chrome.GlyphFontSize}"
                                   TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.UI}"
                                   Text="&#xE8BB;" />
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Text="{DynamicResource MousePerformance.Chart.WindowHint}"
                               Style="{StaticResource MousePerformanceChartWindowHintStyle}"
                               VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Row="2"
                      Grid.IsSharedSizeScope="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"
                                           SharedSizeGroup="ChartToolbarLabelRow" />
                            <RowDefinition Height="6"
                                           SharedSizeGroup="ChartToolbarGapRow" />
                            <RowDefinition Height="Auto"
                                           SharedSizeGroup="ChartToolbarControlRow" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="324" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{DynamicResource MousePerformance.Chart.Control.PlotType}"
                                   Style="{StaticResource MousePerformanceChartToolbarLabelStyle}" />

                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Text="{DynamicResource MousePerformance.Chart.Control.RangeStart}"
                                   Style="{StaticResource MousePerformanceChartToolbarLabelStyle}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />

                        <TextBlock Grid.Row="0"
                                   Grid.Column="4"
                                   Text="{DynamicResource MousePerformance.Chart.Control.RangeEnd}"
                                   Style="{StaticResource MousePerformanceChartToolbarLabelStyle}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />

                        <ComboBox Grid.Row="2"
                                  Grid.Column="0"
                                  Width="324"
                                  ItemsSource="{Binding PlotTypeOptions}"
                                  SelectedValue="{Binding SelectedPlotType}"
                                  SelectedValuePath="PlotType"
                                  Style="{StaticResource AvantGardeComboBoxStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Style="{StaticResource DeviceComboItemTextStyle}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBox Grid.Row="2"
                                 Grid.Column="2"
                                 Width="116"
                                 Text="{Binding RangeStartText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MousePerformanceChartToolbarTextBoxStyle}"
                                 LostFocus="RangeTextBox_LostFocus"
                                 PreviewKeyDown="RangeTextBox_PreviewKeyDown" />

                        <TextBox Grid.Row="2"
                                 Grid.Column="4"
                                 Width="116"
                                 Text="{Binding RangeEndText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MousePerformanceChartToolbarTextBoxStyle}"
                                 LostFocus="RangeTextBox_LostFocus"
                                 PreviewKeyDown="RangeTextBox_PreviewKeyDown" />

                        <CheckBox Grid.Row="2"
                                  Grid.Column="6"
                                  IsChecked="{Binding ShowStem}"
                                  Content="{DynamicResource MousePerformance.Chart.Control.Stem}"
                                  Style="{StaticResource MousePerformanceChartToolbarCheckBoxStyle}" />

                        <CheckBox Grid.Row="2"
                                  Grid.Column="8"
                                  IsChecked="{Binding ShowLines}"
                                  Content="{DynamicResource MousePerformance.Chart.Control.Lines}"
                                  Style="{StaticResource MousePerformanceChartToolbarCheckBoxStyle}" />
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"
                                           SharedSizeGroup="ChartToolbarLabelRow" />
                            <RowDefinition Height="6"
                                           SharedSizeGroup="ChartToolbarGapRow" />
                            <RowDefinition Height="Auto"
                                           SharedSizeGroup="ChartToolbarControlRow" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Grid.RowSpan="3"
                                Width="1"
                                Margin="0,6,0,6"
                                Background="{DynamicResource HairlineBrush}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="12,0,0,2"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Center"
                                   TextAlignment="Left"
                                   Text="{Binding ToolbarSupplementText}"
                                   ToolTip="{Binding ToolbarSupplementText}"
                                   Style="{StaticResource MousePerformanceChartToolbarSupplementStyle}" />
                    </Grid>
                </Grid>
            </Grid>

            <Border Grid.Row="1"
                    Background="{DynamicResource HairlineBrush}"
                    IsHitTestVisible="False" />

            <controls:MousePerformanceChartControl x:Name="ChartControl"
                                                   Grid.Row="2"
                                                   Margin="0,14,0,0"
                                                   RenderFrame="{Binding RenderFrame}" />
        </Grid>
    </Grid>
</Window>
