<UserControl x:Class="Views.Pages.KeyDetectionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="KeyDetectionPage_Loaded"
             Unloaded="KeyDetectionPage_Unloaded"
             IsVisibleChanged="KeyDetectionPage_IsVisibleChanged"
             DataContextChanged="KeyDetectionPage_DataContextChanged"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <Style x:Key="KeyDetectionRoundedPanelBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionPanelBorderStyle}">
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="18,14" />
        </Style>

        <Style x:Key="KeyDetectionThresholdBarBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionRoundedPanelBorderStyle}">
            <Setter Property="CornerRadius" Value="26" />
            <Setter Property="Padding" Value="18,14" />
        </Style>

        <Style x:Key="KeyDetectionRoundedInsetSurfaceBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionInsetSurfaceBorderStyle}">
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Background" Value="{DynamicResource GlassPopupBackgroundBrush}" />
        </Style>

        <Style x:Key="KeyDetectionMetricTileBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionRoundedInsetSurfaceBorderStyle}">
            <Setter Property="MinHeight" Value="76" />
            <Setter Property="Padding" Value="18,14,18,10" />
        </Style>

        <Style x:Key="KeyDetectionTimingSurfaceBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionMetricTileBorderStyle}">
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="Padding" Value="18,14,18,10" />
        </Style>

        <Style x:Key="KeyDetectionRoundedButtonCardBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionButtonCardBorderStyle}">
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BorderThickness" Value="1.4" />
            <Setter Property="Padding" Value="20,16,20,18" />
            <Setter Property="MinHeight" Value="346" />
        </Style>

        <Style x:Key="KeyDetectionPillBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionRoundedInsetSurfaceBorderStyle}">
            <Setter Property="BorderThickness" Value="1.35" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="KeyDetectionStatusPillBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionPillBorderStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCustomKeyDown}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                    <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="KeyDetectionHeroStatusTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Body}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="LineHeight" Value="22" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
        </Style>

        <Style x:Key="KeyDetectionInfoTagBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="1.25" />
        </Style>

        <Style x:Key="KeyDetectionInfoTagTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="KeyDetectionInfoValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionHeroStatusTextStyle}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="KeyDetectionRaisedThresholdTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource KeyDetectionThresholdTextBoxStyle}">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="#C5C5C5" />
            <Setter Property="BorderBrush" Value="#CFCFCF" />
            <Setter Property="BorderThickness" Value="1.3" />
            <Setter Property="CaretBrush" Value="#111111" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid ClipToBounds="False"
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <Border x:Name="ShadowPlate"
                                    Margin="5,5,0,0"
                                    Background="#ECECEC"
                                    CornerRadius="8"
                                    IsHitTestVisible="False"
                                    Opacity="1" />

                            <Border x:Name="InputSurface"
                                    Margin="0,0,5,5"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="InputSurface" Property="BorderBrush" Value="#D4D4D4" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="HoldEnd">
                                            <DoubleAnimation Storyboard.TargetName="ShadowPlate"
                                                             From="1"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.12"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="HoldEnd">
                                            <DoubleAnimation Storyboard.TargetName="ShadowPlate"
                                                             From="0"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.16"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputSurface" Property="BorderBrush" Value="#DEDEDE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputSurface" Property="Opacity" Value="0.52" />
                                <Setter TargetName="ShadowPlate" Property="Opacity" Value="0.36" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeyDetectionWheelRailBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionRoundedInsetSurfaceBorderStyle}">
            <Setter Property="CornerRadius" Value="32" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="KeyDetectionWheelPulseZoneStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="10,12" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                    <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1.025"
                                                 Duration="0:0:0.08"
                                                 EasingFunction="{StaticResource MotionOutEase}" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="1.025"
                                                 Duration="0:0:0.08"
                                                 EasingFunction="{StaticResource MotionOutEase}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="KeyDetectionPillGhostButtonStyle"
               TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="1.35" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Meta}" />
            <Setter Property="FontWeight" Value="{DynamicResource TextWeight.SecondaryButton}" />
            <Setter Property="FontSize" Value="{DynamicResource TypeScale.SecondaryButton}" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}"
                                Opacity="0.92">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.76" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeyDetectionCompactPanelTitleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionSectionTitleTextStyle}">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="KeyDetectionCompactSectionTitleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionSectionTitleTextStyle}">
            <Setter Property="FontSize" Value="16" />
        </Style>

        <Style x:Key="KeyDetectionCardCenteredTitleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionCardTitleTextStyle}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="KeyDetectionCardSectionDividerStyle"
               TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="KeyDetectionCardSummaryLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionEyebrowTextStyle}">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="KeyDetectionCardHeroValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionCardValueTextStyle}">
            <Setter Property="FontSize" Value="36" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="KeyDetectionCardRowLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Body}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
        </Style>

        <Style x:Key="KeyDetectionCardRowValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
            <Setter Property="Typography.NumeralStyle" Value="Lining" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
        </Style>

        <Style x:Key="KeyDetectionCardTimingValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionTimingValueTextStyle}">
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="KeyDetectionExpandedTimingValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionTimingValueTextStyle}">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="KeyDetectionSubMetricValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Opacity" Value="0.82" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
            <Setter Property="Typography.NumeralStyle" Value="Lining" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
        </Style>

        <Style x:Key="KeyDetectionCompactMetricValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionCountValueTextStyle}">
            <Setter Property="FontSize" Value="20" />
        </Style>

        <Style x:Key="KeyDetectionMetricHeaderTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionCardRowLabelTextStyle}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="LineHeight" Value="19" />
            <Setter Property="Margin" Value="0,1,0,0" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="KeyDetectionMetricCenterValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionCompactMetricValueTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="24" />
        </Style>

        <Style x:Key="KeyDetectionMetricInlineValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionCompactMetricValueTextStyle}">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="LineHeight" Value="24" />
            <Setter Property="Margin" Value="0,-2,0,0" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="KeyDetectionMetricInlineTimingValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionExpandedTimingValueTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,-1,0,0" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="KeyDetectionMetricNoteTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="KeyDetectionMetricFooterLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionEyebrowTextStyle}">
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="KeyDetectionMetricFooterValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionSubMetricValueTextStyle}">
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="KeyDetectionCompactScrollValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionScrollValueTextStyle}">
            <Setter Property="FontSize" Value="28" />
        </Style>

        <DataTemplate x:Key="KeyDetectionButtonCardTemplate">
            <Grid Margin="0,0,8,8">
                <Border x:Name="ButtonCardShadow"
                        CornerRadius="22"
                        Background="{DynamicResource TextStrongBrush}"
                        Opacity="0.18"
                        IsHitTestVisible="False">
                    <Border.RenderTransform>
                        <TranslateTransform X="7" Y="7" />
                    </Border.RenderTransform>
                </Border>

                <Border x:Name="ButtonCardBorder"
                        Style="{StaticResource KeyDetectionRoundedButtonCardBorderStyle}"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform X="0" Y="0" />
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock HorizontalAlignment="Center"
                                   Text="{Binding Title}"
                                   Style="{StaticResource KeyDetectionCardCenteredTitleTextStyle}" />

                        <StackPanel Grid.Row="2"
                                    HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       Text="{Binding DoubleClickCountText}"
                                       Style="{StaticResource KeyDetectionCardHeroValueTextStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       HorizontalAlignment="Center"
                                       Text="{DynamicResource KeyDetection.Metric.DoubleClicks}"
                                       Style="{StaticResource KeyDetectionCardSummaryLabelTextStyle}" />
                        </StackPanel>

                        <Border Grid.Row="4"
                                Style="{StaticResource KeyDetectionCardSectionDividerStyle}" />

                        <Grid Grid.Row="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{DynamicResource KeyDetection.Metric.DownCount}"
                                           Style="{StaticResource KeyDetectionCardRowLabelTextStyle}" />
                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           Text="{Binding DownCountText}"
                                           Style="{StaticResource KeyDetectionCardRowValueTextStyle}" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{DynamicResource KeyDetection.Metric.UpCount}"
                                           Style="{StaticResource KeyDetectionCardRowLabelTextStyle}" />
                                <TextBlock Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           Text="{Binding UpCountText}"
                                           Style="{StaticResource KeyDetectionCardRowValueTextStyle}" />
                            </Grid>
                        </Grid>

                        <Border Grid.Row="8"
                                Style="{StaticResource KeyDetectionCardSectionDividerStyle}" />

                        <Grid Grid.Row="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{DynamicResource KeyDetection.Metric.DownToDown}"
                                               Style="{StaticResource KeyDetectionCardRowLabelTextStyle}" />
                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Text="{Binding CurrentDownDownText}"
                                               Style="{StaticResource KeyDetectionCardTimingValueTextStyle}" />
                                </Grid>

                                <StackPanel Margin="0,8,0,0"
                                            HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{DynamicResource KeyDetection.Metric.Min}"
                                                   Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
                                        <TextBlock Margin="4,0,0,0"
                                                   Text="{Binding MinimumDownDownText}"
                                                   Style="{StaticResource KeyDetectionSubMetricValueTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,3,0,0"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{DynamicResource KeyDetection.Metric.Avg}"
                                                   Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
                                        <TextBlock Margin="4,0,0,0"
                                                   Text="{Binding AverageDownDownText}"
                                                   Style="{StaticResource KeyDetectionSubMetricValueTextStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{DynamicResource KeyDetection.Metric.DownToUp}"
                                               Style="{StaticResource KeyDetectionCardRowLabelTextStyle}" />
                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Text="{Binding CurrentDownUpText}"
                                               Style="{StaticResource KeyDetectionCardTimingValueTextStyle}" />
                                </Grid>

                                <StackPanel Margin="0,8,0,0"
                                            HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{DynamicResource KeyDetection.Metric.Min}"
                                                   Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
                                        <TextBlock Margin="4,0,0,0"
                                                   Text="{Binding MinimumDownUpText}"
                                                   Style="{StaticResource KeyDetectionSubMetricValueTextStyle}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,3,0,0"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <TextBlock Text="{DynamicResource KeyDetection.Metric.Avg}"
                                                   Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
                                        <TextBlock Margin="4,0,0,0"
                                                   Text="{Binding AverageDownUpText}"
                                                   Style="{StaticResource KeyDetectionSubMetricValueTextStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsPressed}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard FillBehavior="HoldEnd">
                                <DoubleAnimation Storyboard.TargetName="ButtonCardBorder"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 To="7"
                                                 Duration="0:0:0.08"
                                                 EasingFunction="{StaticResource MotionOutEase}" />
                                <DoubleAnimation Storyboard.TargetName="ButtonCardBorder"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="7"
                                                 Duration="0:0:0.08"
                                                 EasingFunction="{StaticResource MotionOutEase}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard FillBehavior="HoldEnd">
                                <DoubleAnimation Storyboard.TargetName="ButtonCardBorder"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                 To="0"
                                                 Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource MotionOutEase}" />
                                <DoubleAnimation Storyboard.TargetName="ButtonCardBorder"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.12"
                                                 EasingFunction="{StaticResource MotionOutEase}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>
    <Grid x:Name="RootScrollViewer"
          Background="{DynamicResource WindowBackgroundBrush}"
          Focusable="True"
          PreviewMouseDown="RootScrollViewer_PreviewMouseDown"
          PreviewMouseWheel="RootScrollViewer_PreviewMouseWheel">
        <Grid Margin="{StaticResource Layout.KeyDetection.PageMargin}"
              RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ContentControl Content="{Binding ButtonCards[0]}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" />
                <ContentControl Grid.Column="2"
                                Content="{Binding ButtonCards[1]}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" />
                <ContentControl Grid.Column="4"
                                Content="{Binding ButtonCards[2]}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" />
                <ContentControl Grid.Column="6"
                                Content="{Binding ButtonCards[3]}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" />
                <ContentControl Grid.Column="8"
                                Content="{Binding ButtonCards[4]}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" />
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource KeyDetectionThresholdBarBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="{DynamicResource KeyDetection.MouseThreshold.Title}"
                                   Style="{StaticResource KeyDetectionCompactPanelTitleTextStyle}" />
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Text="{DynamicResource KeyDetection.MouseThreshold.Description}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource HintTextStyle}" />
                    </Grid>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Text="{DynamicResource KeyDetection.MouseThreshold.InputLabel}"
                                   Style="{StaticResource MicroLabelStyle}" />
                        <TextBox x:Name="MouseThresholdTextBox"
                                 Width="78"
                                 Text="{Binding MouseDoubleClickThresholdText, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                 Style="{StaticResource KeyDetectionRaisedThresholdTextBoxStyle}"
                                 PreviewKeyDown="ThresholdTextBox_PreviewKeyDown"
                                 LostFocus="ThresholdTextBox_LostFocus"
                                 GotKeyboardFocus="ThresholdTextBox_GotKeyboardFocus"
                                 LostKeyboardFocus="ThresholdTextBox_LostKeyboardFocus" />

                        <Button Margin="12,0,0,0"
                                MinWidth="108"
                                Command="{Binding ResetStatisticsCommand}"
                                Content="{DynamicResource KeyDetection.Action.ResetStatistics}"
                                Style="{StaticResource KeyDetectionPillGhostButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="10"
                        Style="{StaticResource KeyDetectionRoundedPanelBorderStyle}">
                    <Border Style="{StaticResource KeyDetectionWheelRailBorderStyle}">
                        <Grid Margin="0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource KeyDetectionWheelPulseZoneStyle}"
                                    Tag="{Binding IsScrollUpPulseActive}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Viewbox Width="18"
                                             Height="10"
                                             Margin="0,0,0,12"
                                             HorizontalAlignment="Center"
                                             Stretch="Fill">
                                        <Path Data="M 13 0 L 26 16 L 0 16 Z"
                                              Fill="{DynamicResource TextStrongBrush}"
                                              Stretch="Fill" />
                                    </Viewbox>

                                    <TextBlock HorizontalAlignment="Center"
                                               Text="{Binding ScrollUpCountText}"
                                               Style="{StaticResource KeyDetectionCompactScrollValueTextStyle}" />

                                    <TextBlock Margin="0,8,0,0"
                                               HorizontalAlignment="Center"
                                               Text="{DynamicResource KeyDetection.Scroll.Up}"
                                               TextAlignment="Center"
                                               Style="{StaticResource MicroLabelStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Width="40"
                                    Height="1"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource HairlineBrush}"
                                    Opacity="0.52" />

                            <Border Grid.Row="2"
                                    Style="{StaticResource KeyDetectionWheelPulseZoneStyle}"
                                    Tag="{Binding IsScrollDownPulseActive}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Viewbox Width="18"
                                             Height="10"
                                             Margin="0,0,0,12"
                                             HorizontalAlignment="Center"
                                             Stretch="Fill">
                                        <Path Data="M 0 0 L 26 0 L 13 16 Z"
                                              Fill="{DynamicResource TextStrongBrush}"
                                              Stretch="Fill" />
                                    </Viewbox>

                                    <TextBlock HorizontalAlignment="Center"
                                               Text="{Binding ScrollDownCountText}"
                                               Style="{StaticResource KeyDetectionCompactScrollValueTextStyle}" />

                                    <TextBlock Margin="0,8,0,0"
                                               HorizontalAlignment="Center"
                                               Text="{DynamicResource KeyDetection.Scroll.Down}"
                                               TextAlignment="Center"
                                               Style="{StaticResource MicroLabelStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Border>

                <Border Grid.Column="2"
                        Padding="18,16"
                        Style="{StaticResource KeyDetectionRoundedPanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{DynamicResource KeyDetection.CustomKey.Title}"
                                           Style="{StaticResource KeyDetectionCompactPanelTitleTextStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           MaxWidth="720"
                                           Text="{DynamicResource KeyDetection.CustomKey.Description}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource HintTextStyle}" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    MinWidth="78"
                                    Command="{Binding ToggleKeyPickModeCommand}"
                                    Content="{Binding CustomKeyPickButtonText}"
                                    Style="{StaticResource KeyDetectionPillGhostButtonStyle}" />

                            <Button Grid.Column="4"
                                    MinWidth="78"
                                    Command="{Binding ResetCustomKeyCommand}"
                                    Content="{DynamicResource KeyDetection.CustomKey.Button.Reset}"
                                    Style="{StaticResource KeyDetectionPillGhostButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.02*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="1.28*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource KeyDetectionPillBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource KeyDetectionInfoTagBorderStyle}">
                                        <TextBlock Text="{DynamicResource KeyDetection.CustomKey.Selection.Label}"
                                                   Style="{StaticResource KeyDetectionInfoTagTextStyle}" />
                                    </Border>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CustomKeySelectionValueText}"
                                               Style="{StaticResource KeyDetectionInfoValueTextStyle}" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource KeyDetectionStatusPillBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource KeyDetectionInfoTagBorderStyle}">
                                        <TextBlock Text="{DynamicResource KeyDetection.CustomKey.Status.Label}"
                                                   Style="{StaticResource KeyDetectionInfoTagTextStyle}" />
                                    </Border>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CustomKeyStatusValueText}"
                                               Style="{StaticResource KeyDetectionInfoValueTextStyle}" />
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource KeyDetectionMetricTileBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{DynamicResource KeyDetection.Metric.DownCount}"
                                                       Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CustomKeyDownCountText}"
                                                       Style="{StaticResource KeyDetectionMetricInlineValueTextStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Style="{StaticResource KeyDetectionMetricTileBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{DynamicResource KeyDetection.Metric.UpCount}"
                                                       Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CustomKeyUpCountText}"
                                                       Style="{StaticResource KeyDetectionMetricInlineValueTextStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="4"
                                        Style="{StaticResource KeyDetectionMetricTileBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{DynamicResource KeyDetection.Metric.DoubleClicks}"
                                                       Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CustomKeyDoubleClickCountText}"
                                                       Style="{StaticResource KeyDetectionMetricInlineValueTextStyle}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource KeyDetectionTimingSurfaceBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{DynamicResource KeyDetection.CustomKey.ThresholdTitle}"
                                                       Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <TextBox x:Name="CustomKeyThresholdTextBox"
                                                         Width="94"
                                                         Text="{Binding KeyDoubleClickThresholdText, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                         Style="{StaticResource KeyDetectionRaisedThresholdTextBoxStyle}"
                                                         PreviewKeyDown="ThresholdTextBox_PreviewKeyDown"
                                                         LostFocus="ThresholdTextBox_LostFocus"
                                                         GotKeyboardFocus="ThresholdTextBox_GotKeyboardFocus"
                                                         LostKeyboardFocus="ThresholdTextBox_LostKeyboardFocus" />

                                                <TextBlock Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="{DynamicResource KeyDetection.CustomKey.ThresholdInputLabel}"
                                                           Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Grid.Row="2"
                                                   Margin="0,6,0,0"
                                                   Text="{DynamicResource KeyDetection.CustomKey.ThresholdHint}"
                                                   Style="{StaticResource KeyDetectionMetricNoteTextStyle}" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Style="{StaticResource KeyDetectionTimingSurfaceBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{DynamicResource KeyDetection.Metric.DownToDown}"
                                                       Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CustomKeyCurrentDownDownText}"
                                                       Style="{StaticResource KeyDetectionMetricInlineTimingValueTextStyle}" />
                                        </Grid>

                                        <StackPanel Grid.Row="2"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="{DynamicResource KeyDetection.Metric.Min}"
                                                       Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                                            <TextBlock Margin="4,0,0,0"
                                                       Text="{Binding CustomKeyMinimumDownDownText}"
                                                       Style="{StaticResource KeyDetectionMetricFooterValueTextStyle}" />
                                            <TextBlock Margin="14,0,0,0"
                                                       Text="{DynamicResource KeyDetection.Metric.Avg}"
                                                       Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                                            <TextBlock Margin="4,0,0,0"
                                                       Text="{Binding CustomKeyAverageDownDownText}"
                                                       Style="{StaticResource KeyDetectionMetricFooterValueTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="4"
                                        Style="{StaticResource KeyDetectionTimingSurfaceBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{DynamicResource KeyDetection.Metric.DownToUp}"
                                                       Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CustomKeyCurrentDownUpText}"
                                                       Style="{StaticResource KeyDetectionMetricInlineTimingValueTextStyle}" />
                                        </Grid>

                                        <StackPanel Grid.Row="2"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="{DynamicResource KeyDetection.Metric.Min}"
                                                       Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                                            <TextBlock Margin="4,0,0,0"
                                                       Text="{Binding CustomKeyMinimumDownUpText}"
                                                       Style="{StaticResource KeyDetectionMetricFooterValueTextStyle}" />
                                            <TextBlock Margin="14,0,0,0"
                                                       Text="{DynamicResource KeyDetection.Metric.Avg}"
                                                       Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                                            <TextBlock Margin="4,0,0,0"
                                                       Text="{Binding CustomKeyAverageDownUpText}"
                                                       Style="{StaticResource KeyDetectionMetricFooterValueTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
