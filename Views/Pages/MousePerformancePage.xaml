<UserControl x:Class="Views.Pages.MousePerformancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="MousePerformancePage_Loaded"
             Unloaded="MousePerformancePage_Unloaded"
             IsVisibleChanged="MousePerformancePage_IsVisibleChanged"
             DataContextChanged="MousePerformancePage_DataContextChanged"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <Style x:Key="MousePerformanceSectionTitleStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MousePerformanceFieldLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MousePerformanceStatusMessageBlockStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource StatusMessageTextStyle}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="LineHeight" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MousePerformanceQualityTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HintTextStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="MousePerformanceValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="34" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Typography.NumeralStyle" Value="Lining" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MousePerformanceSummaryLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="MousePerformanceSummaryUnitStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HintTextStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="MousePerformanceEditorialInputTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource KeyDetectionThresholdTextBoxStyle}">
            <Setter Property="Width" Value="168" />
            <Setter Property="Height" Value="54" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="EditorialInputSurface"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0,10,0,8"
                                              VerticalAlignment="Center" />
                            </Border>
                            <Rectangle x:Name="EditorialInputTopRule"
                                       Height="1"
                                       VerticalAlignment="Top"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.18" />
                            <Rectangle x:Name="EditorialInputBottomRule"
                                       Height="1"
                                       VerticalAlignment="Bottom"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.82" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorialInputSurface" Property="Background" Value="#08FFFFFF" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorialInputSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Opacity" Value="1" />
                                <Setter TargetName="EditorialInputTopRule" Property="Opacity" Value="0.32" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorialInputSurface" Property="Opacity" Value="0.36" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MousePerformanceEditorialActionButtonBaseStyle"
               TargetType="Button">
            <Setter Property="MinWidth" Value="164" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="EditorialButtonSurface"
                                    Background="{TemplateBinding Background}" />
                            <Rectangle x:Name="EditorialButtonTopRule"
                                       Height="1"
                                       VerticalAlignment="Top"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.18" />
                            <Rectangle x:Name="EditorialButtonBottomRule"
                                       Height="1"
                                       VerticalAlignment="Bottom"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.82" />
                            <ContentPresenter x:Name="EditorialButtonContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="#08FFFFFF" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialButtonContent" Property="Margin" Value="0,1,0,-1" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorialButtonSurface" Property="Opacity" Value="0.34" />
                                <Setter TargetName="EditorialButtonContent" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MousePerformancePrimaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MousePerformanceEditorialActionButtonBaseStyle}">
            <Setter Property="Foreground" Value="{DynamicResource VoltGreenBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="MousePerformanceActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MousePerformanceEditorialActionButtonBaseStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="MousePerformancePlotActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MousePerformanceActionButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlotHighlighted}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource VoltGreenBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MousePerformanceCenteredComboBoxStyle"
               TargetType="ComboBox"
               BasedOn="{StaticResource AvantGardeComboBoxStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Opacity="0.92" />
                            <Border x:Name="ActiveLine"
                                    Height="1"
                                    Margin="18,0,18,0"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Stretch"
                                    Background="{DynamicResource VoltGreenBrush}"
                                    Opacity="0.92"
                                    RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="0" />
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="40,12,40,12"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              SnapsToDevicePixels="True"
                                              IsHitTestVisible="False" />
                            <Border Width="24"
                                    HorizontalAlignment="Right"
                                    Background="Transparent">
                                <Path x:Name="Arrow"
                                      Width="8"
                                      Height="4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M 0 0 L 8 0 L 4 4 z"
                                      Fill="{DynamicResource TextMutedBrush}"
                                      Opacity="0.72"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Path.RenderTransform>
                                </Path>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="300"
                                        Background="{DynamicResource GlassPopupBackgroundBrush}"
                                        BorderBrush="{DynamicResource GlassPopupBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True">
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="1" />
                                <Setter TargetName="Arrow" Property="Opacity" Value="1" />
                                <Setter TargetName="ActiveLine" Property="Opacity" Value="0.42" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="1" />
                                <Setter TargetName="Arrow" Property="Opacity" Value="1" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             To="180"
                                                             Duration="{StaticResource MotionMediumDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ActiveLine"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1"
                                                             Duration="{StaticResource MotionMediumDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             To="0"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ActiveLine"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="0"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.45" />
                                <Setter TargetName="Arrow" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="CaptureSurface"
            Background="{DynamicResource WindowBackgroundBrush}"
            Focusable="True"
            Padding="{StaticResource Layout.CaptureSurface.Padding}">
        <Grid Margin="0,18,18,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="CaptureLockZone"
                    Grid.Column="2"
                    Margin="16,32,16,32"
                    Background="Transparent"
                    Focusable="True"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />

            <StackPanel Grid.Column="1"
                        MaxWidth="980"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,12,0,0">
                <StackPanel Width="840"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding StatusPillText}"
                               Style="{StaticResource StatusPillTextStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding StatusMessage}"
                               Style="{StaticResource MousePerformanceStatusMessageBlockStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding QualityText}"
                               Style="{StaticResource MousePerformanceQualityTextStyle}" />
                </StackPanel>

                <Border Width="72"
                        Height="1"
                        Margin="0,24,0,28"
                        Background="{DynamicResource HairlineBrush}"
                        HorizontalAlignment="Center"
                        IsHitTestVisible="False" />

                <Grid Width="840"
                      HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="168" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Bottom"
                               Text="{DynamicResource MousePerformance.Device.Title}"
                               Style="{StaticResource MousePerformanceFieldLabelStyle}" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,1"
                               Text="{DynamicResource MousePerformance.Cpi.Title}"
                               Style="{StaticResource MousePerformanceFieldLabelStyle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />

                    <ComboBox Grid.Row="2"
                              Grid.Column="0"
                              ItemsSource="{Binding Devices}"
                              SelectedItem="{Binding SelectedDevice}"
                              IsEnabled="{Binding IsDeviceSelectionEnabled}"
                              Style="{StaticResource MousePerformanceCenteredComboBoxStyle}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayLabel}"
                                           Style="{StaticResource DeviceComboItemTextStyle}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBox x:Name="CpiTextBox"
                             Grid.Row="2"
                             Grid.Column="2"
                             HorizontalAlignment="Center"
                             Text="{Binding CpiText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MousePerformanceEditorialInputTextBoxStyle}"
                             LostFocus="CpiTextBox_LostFocus"
                             PreviewKeyDown="CpiTextBox_PreviewKeyDown" />
                </Grid>

                <Grid Width="840"
                      Margin="0,28,0,0"
                      IsEnabled="{Binding AreActionButtonsEnabled}"
                      HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding CollectCommand}"
                            Content="{DynamicResource MousePerformance.Action.Collect}"
                            Style="{StaticResource MousePerformancePrimaryActionButtonStyle}" />
                    <Button Grid.Column="2"
                            Command="{Binding ResetCommand}"
                            Content="{DynamicResource MousePerformance.Action.Reset}"
                            Style="{StaticResource MousePerformanceActionButtonStyle}" />
                    <Button Grid.Column="4"
                            Command="{Binding PlotCommand}"
                            Content="{DynamicResource MousePerformance.Action.Plot}"
                            Style="{StaticResource MousePerformancePlotActionButtonStyle}" />
                </Grid>

                <StackPanel Margin="0,36,0,0"
                            Width="840"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource MousePerformance.Summary.Title}"
                               Style="{StaticResource MousePerformanceSectionTitleStyle}" />
                    <Border Width="72"
                            Height="1"
                            Margin="0,12,0,18"
                            Background="{DynamicResource HairlineBrush}"
                            HorizontalAlignment="Center"
                            IsHitTestVisible="False" />

                    <Grid MinHeight="116">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource MousePerformance.Summary.EventCount}"
                                       Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
                            <TextBlock Margin="0,16,0,0"
                                       Text="{Binding EventCountText}"
                                       Style="{StaticResource MousePerformanceValueTextStyle}" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Margin="0,10"
                                Background="{DynamicResource HairlineBrush}"
                                IsHitTestVisible="False" />

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource MousePerformance.Summary.SumX}"
                                       Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
                            <TextBlock Margin="0,16,0,0"
                                       Text="{Binding SumXCountText}"
                                       Style="{StaticResource MousePerformanceValueTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SumXCmText}"
                                       Style="{StaticResource MousePerformanceSummaryUnitStyle}" />
                        </StackPanel>

                        <Border Grid.Column="3"
                                Margin="0,10"
                                Background="{DynamicResource HairlineBrush}"
                                IsHitTestVisible="False" />

                        <StackPanel Grid.Column="4"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource MousePerformance.Summary.SumY}"
                                       Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
                            <TextBlock Margin="0,16,0,0"
                                       Text="{Binding SumYCountText}"
                                       Style="{StaticResource MousePerformanceValueTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SumYCmText}"
                                       Style="{StaticResource MousePerformanceSummaryUnitStyle}" />
                        </StackPanel>

                        <Border Grid.Column="5"
                                Margin="0,10"
                                Background="{DynamicResource HairlineBrush}"
                                IsHitTestVisible="False" />

                        <StackPanel Grid.Column="6"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource MousePerformance.Summary.Path}"
                                       Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
                            <TextBlock Margin="0,16,0,0"
                                       Text="{Binding PathCountText}"
                                       Style="{StaticResource MousePerformanceValueTextStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding PathCmText}"
                                       Style="{StaticResource MousePerformanceSummaryUnitStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
