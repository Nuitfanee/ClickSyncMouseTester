                                                           BasedOn="{StaticResource MeasureEditorialAxisLabelTextStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="0,14,0,0"
                                                       Text="{Binding MeasureHeroSupportText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock"
                                                           BasedOn="{StaticResource MeasureCenterResultTitleTextStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Margin="0,10,0,0"
                                                       MaxWidth="368"
                                                       Text="{Binding HintText}"
                                                       Style="{StaticResource MeasureEditorialCenterSupportTextStyle}" />
                                        </StackPanel>

                                        <Rectangle Grid.Row="2"
                                                   Width="1"
                                                   Margin="0,20,0,6"
                                                   VerticalAlignment="Stretch"
                                                   Fill="{DynamicResource HairlineBrush}"
                                                   Opacity="0.28" />
                                    </Grid>

                                    <Grid x:Name="MeasureCenterResultHost"
                                          MaxWidth="360"
                                          VerticalAlignment="Stretch"
                                          Style="{StaticResource MeasureCenterResultHostStyle}">
                                        <Grid.RenderTransform>
                                            <TranslateTransform x:Name="MeasureCenterResultTranslate" />
                                        </Grid.RenderTransform>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Rectangle Grid.Row="0"
                                                   Width="1"
                                                   Margin="0,6,0,24"
                                                   VerticalAlignment="Stretch"
                                                   Fill="{DynamicResource HairlineBrush}"
                                                   Opacity="0.22" />

                                        <StackPanel Grid.Row="1"
                                                    Width="340"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Grid Margin="0,10,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0">
                                                    <TextBlock Text="{DynamicResource SensitivityMatch.Result.RecommendedDpi}"
                                                               Style="{StaticResource MeasureCenterResultLabelTextStyle}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding RecommendedTargetDpiText}"
                                                               Style="{StaticResource MeasureCenterResultValueTextStyle}" />
                                                </StackPanel>

                                                <Rectangle Grid.Row="1"
                                                           Height="1"
                                                           Margin="26,12,26,12"
                                                           Fill="{DynamicResource HairlineBrush}"
                                                           Opacity="0.16" />

                                                <StackPanel Grid.Row="2">
                                                    <TextBlock Text="{DynamicResource SensitivityMatch.Result.Scale}"
                                                               Style="{StaticResource MeasureCenterResultLabelTextStyle}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding ScaleText}"
                                                               Style="{StaticResource MeasureCenterResultValueTextStyle}" />
                                                </StackPanel>

                                                <Rectangle Grid.Row="3"
                                                           Height="1"
                                                           Margin="26,12,26,12"
                                                           Fill="{DynamicResource HairlineBrush}"
                                                           Opacity="0.16" />

                                                <StackPanel Grid.Row="4">
                                                    <TextBlock Text="{DynamicResource SensitivityMatch.Result.Consistency}"
                                                               Style="{StaticResource MeasureCenterResultLabelTextStyle}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding ConsistencyText}"
                                                               Style="{StaticResource MeasureCenterResultInlineValueTextStyle}" />
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Margin="0,12,0,0"
                                                       MaxWidth="320"
                                                       Text="{Binding HintText}"
                                                       Style="{StaticResource MeasureEditorialCenterMetaTextStyle}" />
                                        </StackPanel>

                                        <Rectangle Grid.Row="2"
                                                   Width="1"
                                                   Margin="0,24,0,6"
                                                   VerticalAlignment="Stretch"
                                                   Fill="{DynamicResource HairlineBrush}"
                                                   Opacity="0.22" />
                                    </Grid>
                                </Grid>

                                <Grid Grid.Column="2"
                                      Margin="24,38,0,34"
                                      Style="{StaticResource MeasureLaneHostPanelStyle}">
                                    <Grid HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Margin="0,76,0,0"
                                                   HorizontalAlignment="Left"
                                                   Tag="{Binding MeasureTargetValueText}"
                                                   Text="{DynamicResource SensitivityMatch.Measure.TargetLane}"
                                                   TextAlignment="Left">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock"
                                                       BasedOn="{StaticResource MeasureEditorialAxisLabelTextStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <Trigger Property="Tag" Value="--">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Row="1"
                                                   Margin="-36,8,0,0"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding MeasureTargetValueText}"
                                                   TextAlignment="Left">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock"
                                                       BasedOn="{StaticResource MeasureGiantPercentageTextStyle}">
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="--">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Grid.Row="2"
                                                    Margin="0,0,0,52"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Bottom"
                                                    Tag="{Binding MeasureTargetValueText}">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <Trigger Property="Tag" Value="--">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock HorizontalAlignment="Left"
                                                       MaxWidth="318"
                                                       Text="{Binding TargetInfoBand.DeviceTitle}"
                                                       TextAlignment="Left"
                                                       Style="{StaticResource SensitivityMatchMeasureLaneDeviceTextStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="0"
                                                    Grid.RowSpan="3"
                                                    Width="318"
                                                    Margin="0,18,0,14"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Tag="{Binding MeasureTargetValueText}">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <Trigger Property="Tag" Value="--">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock HorizontalAlignment="Left"
                                                       Text="{DynamicResource SensitivityMatch.Measure.TargetLane}"
                                                       TextAlignment="Left"
                                                       Style="{StaticResource MeasureEditorialAxisLabelTextStyle}" />
                                            <TextBlock Margin="0,12,0,0"
                                                       HorizontalAlignment="Left"
                                                       Text="{Binding TargetProgressText}"
                                                       TextAlignment="Left"
                                                       Style="{StaticResource MeasureEditorialLaneSupportTextStyle}" />
                                            <Rectangle Height="1"
                                                       Margin="0,18,72,18"
                                                       Fill="{DynamicResource HairlineBrush}"
                                                       Opacity="0.14" />
                                            <TextBlock HorizontalAlignment="Left"
                                                       MaxWidth="318"
                                                       Text="{Binding TargetInfoBand.DeviceTitle}"
                                                       TextAlignment="Left"
                                                       Style="{StaticResource SensitivityMatchMeasureLaneDeviceTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>

                        <Grid x:Name="MeasureRoundsList"
                              Grid.Row="1"
                              Margin="0,4,0,10">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="MeasureRoundsTranslate" />
                            </Grid.RenderTransform>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                    <TextBlock Text="{DynamicResource SensitivityMatch.Measure.RoundsTitle}"
                                               Style="{StaticResource MeasureEditorialAxisLabelTextStyle}" />

                                <Rectangle Grid.Column="1"
                                           Height="1"
                                           Margin="16,8,0,0"
                                           VerticalAlignment="Top"
                                           Fill="{DynamicResource HairlineBrush}"
                                           Opacity="0.16" />
                            </Grid>

                            <ItemsControl Grid.Row="1"
                                          ItemsSource="{Binding Rounds}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource MeasureEditorialRoundRowBorderStyle}">
                                                <Grid VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Title}"
                                                               Style="{StaticResource MeasureEditorialRoundTitleTextStyle}" />

                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding StatusText}"
                                                               Style="{StaticResource MeasureEditorialRoundStatusTextStyle}" />

                                                    <TextBlock Grid.Column="2"
                                                               Margin="18,0,28,0"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding DetailText}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock"
                                                                   BasedOn="{StaticResource MeasureEditorialRoundDetailTextStyle}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowProgressTrack}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <Border Grid.Column="2"
                                                            Margin="18,0,28,0"
                                                            HorizontalAlignment="Stretch">
                                                        <Border.Style>
                                                            <Style TargetType="Border"
                                                                   BasedOn="{StaticResource MeasureEditorialRoundTrackSurfaceStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowProgressTrack}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid Height="48">
                                                            <Grid ClipToBounds="True">
                                                                <Border Margin="0,19,0,0"
                                                                        HorizontalAlignment="Stretch"
                                                                        VerticalAlignment="Top"
                                                                        Style="{StaticResource MeasureEditorialRoundTrackLineStyle}" />

                                                                <Rectangle Margin="0,14,0,0"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Top"
                                                                           Style="{StaticResource MeasureEditorialRoundTrackStartMarkerStyle}" />

                                                                <Canvas x:Name="RoundTrackTravelCanvas"
                                                                        HorizontalAlignment="Stretch"
                                                                        VerticalAlignment="Top"
                                                                        Height="48"
                                                                        ClipToBounds="True"
                                                                        UseLayoutRounding="True">
                                                                    <Grid Canvas.Left="10"
                                                                          Canvas.Top="7"
                                                                          Style="{StaticResource MeasureEditorialRoundTrackMouseHostStyle}"
                                                                          UseLayoutRounding="True">
                                                                        <Grid.RenderTransform>
                                                                            <TranslateTransform>
                                                                                <TranslateTransform.X>
                                                                                    <MultiBinding Converter="{StaticResource TrackProgressOffsetConverter}"
                                                                                                  ConverterParameter="60">
                                                                                        <Binding Path="TrackProgressValue" />
                                                                                        <Binding ElementName="RoundTrackTravelCanvas"
                                                                                                 Path="ActualWidth" />
                                                                                    </MultiBinding>
                                                                                </TranslateTransform.X>
                                                                            </TranslateTransform>
                                                                        </Grid.RenderTransform>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="24" />
                                                                            <ColumnDefinition Width="2" />
                                                                            <ColumnDefinition Width="24" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <Grid Grid.Column="0">
                                                                            <Border Style="{StaticResource MeasureEditorialRoundTrackMouseBodyStyle}" />
                                                                            <Border Width="6"
                                                                                    Height="13"
                                                                                    VerticalAlignment="Top"
                                                                                    HorizontalAlignment="Center"
                                                                                    Margin="0,6,0,0"
                                                                                    CornerRadius="3"
                                                                                    Background="#101215" />
                                                                            <Rectangle Height="1"
                                                                                       Margin="0,18,0,0"
                                                                                       VerticalAlignment="Top"
                                                                                       Fill="#16000000" />
                                                                        </Grid>

                                                                        <Grid Grid.Column="2">
                                                                            <Border Style="{StaticResource MeasureEditorialRoundTrackMouseBodyStyle}" />
                                                                            <Border Width="6"
                                                                                    Height="13"
                                                                                    VerticalAlignment="Top"
                                                                                    HorizontalAlignment="Center"
                                                                                    Margin="0,6,0,0"
                                                                                    CornerRadius="3"
                                                                                    Background="#101215" />
                                                                            <Rectangle Height="1"
                                                                                       Margin="0,18,0,0"
                                                                                       VerticalAlignment="Top"
                                                                                       Fill="#16000000" />
                                                                        </Grid>
                                                                    </Grid>
                                                                </Canvas>
                                                            </Grid>
                                                        </Grid>
                                                    </Border>

                                                    <TextBlock Grid.Column="3"
                                                               MinWidth="84"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding ValueText}"
                                                               Style="{StaticResource MeasureEditorialRoundValueTextStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                        </Grid>

                    <Canvas x:Name="MeasureTransitionOverlay"
                            Panel.ZIndex="8"
                            Visibility="Collapsed"
                            IsHitTestVisible="False">
                        <TextBlock x:Name="MeasureTransitionLeftWord"
                                   Text="SOURCE"
                                   RenderTransformOrigin="0,0"
                                   Style="{StaticResource MeasureTransitionOverlayWordTextStyle}">
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="MeasureTransitionLeftScale" />
                                    <TranslateTransform x:Name="MeasureTransitionLeftTranslate" />
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock x:Name="MeasureTransitionRightWord"
                                   Text="TARGET"
                                   RenderTransformOrigin="0,0"
                                   Style="{StaticResource MeasureTransitionOverlayWordTextStyle}">
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="MeasureTransitionRightScale" />
                                    <TranslateTransform x:Name="MeasureTransitionRightTranslate" />
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Canvas>
                </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="{DynamicResource HairlineBrush}" />

            <Border Grid.Row="4"
                    MinHeight="{StaticResource Layout.SensitivityMatch.ActionMinHeight}"
                    BorderThickness="1,0,1,1"
                    Style="{StaticResource SensitivityMatchPanelBorderStyle}">
                <Grid>
                    <Grid x:Name="IntroActionSectionHost"
                          Style="{StaticResource SectionIntroStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid x:Name="IntroActionHost"
                              Grid.Column="1"
                              Opacity="0">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="IntroActionTranslate"
                                                    Y="12" />
                            </Grid.RenderTransform>
                            <Button x:Name="IntroStartButton"
                                    Click="IntroStartButton_Click"
                                    Content="{DynamicResource SensitivityMatch.Button.StartSetup}"
                                    IsHitTestVisible="False"
                                    IsTabStop="False"
                                    Style="{StaticResource SensitivityMatchPrimaryButtonStyle}" />
                        </Grid>
                    </Grid>

                    <Grid x:Name="SetupFooterHost"
                          Style="{StaticResource SectionSetupFooterStyle}">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="SetupFooterTranslate" />
                        </Grid.RenderTransform>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Click="SetupBackButton_Click"
                                Content="{DynamicResource SensitivityMatch.Button.Back}"
                                Style="{StaticResource SensitivityMatchSecondaryButtonStyle}" />
                        <Button Grid.Column="2"
                                Click="ContinueToMeasureButton_Click"
                                Content="{DynamicResource SensitivityMatch.Button.ContinueToMeasure}"
                                IsEnabled="{Binding IsContinueFromSetupEnabled}"
                                Style="{StaticResource SensitivityMatchPrimaryButtonStyle}" />
                    </Grid>

                    <Grid x:Name="MeasureFooterHost"
                          Style="{StaticResource SectionMeasureStyle}">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="MeasureFooterTranslate" />
                        </Grid.RenderTransform>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Click="MeasureBackButton_Click"
                                Content="{DynamicResource SensitivityMatch.Button.Back}"
                                Style="{StaticResource SensitivityMatchSecondaryButtonStyle}" />

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock
                                       Foreground="{DynamicResource TextStrongBrush}"
                                       Text="{Binding StatusPillText}"
                                       Style="{StaticResource SensitivityMatchLabelTextStyle}" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Command="{Binding StartRoundCommand}"
                                Content="{Binding StartRoundButtonText}"
                                Style="{StaticResource MeasureFooterStartButtonStyle}" />

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource MeasureFooterResultActionsHostStyle}">
                            <Button Command="{Binding RemeasureCommand}"
                                    Content="{DynamicResource SensitivityMatch.Button.Remeasure}"
                                    Style="{StaticResource SensitivityMatchSecondaryButtonStyle}" />
                            <Button Margin="10,0,0,0"
                                    Command="{Binding CopyRecommendedDpiCommand}"
                                    Content="{DynamicResource SensitivityMatch.Button.CopyRecommendedDpi}"
                                    Style="{StaticResource SensitivityMatchPrimaryButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
