<UserControl x:Class="Views.Pages.SensitivityMatchingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WpfApp1.Converters"
             xmlns:models="clr-namespace:WpfApp1.Models"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Loaded="SensitivityMatchingPage_Loaded"
             Unloaded="SensitivityMatchingPage_Unloaded"
             IsVisibleChanged="SensitivityMatchingPage_IsVisibleChanged"
             DataContextChanged="SensitivityMatchingPage_DataContextChanged"
             SizeChanged="SensitivityMatchingPage_SizeChanged"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <converters:TrackProgressOffsetConverter x:Key="TrackProgressOffsetConverter" />

        <Style x:Key="SensitivityMatchPanelBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionPanelBorderStyle}">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="18,16" />
        </Style>

        <SolidColorBrush x:Key="OutlineBorderBrush"
                         Color="{DynamicResource GhostHoverColor}" />

        <Style x:Key="SensitivityMatchInsetBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionInsetSurfaceBorderStyle}">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="16,14" />
        </Style>

        <Style x:Key="SensitivityMatchHeroSurfaceBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource SensitivityMatchInsetBorderStyle}">
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="SensitivityMatchStepTagBorderStyle"
               TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Style.Triggers>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                    <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SensitivityMatchStepTagTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchHeadlineTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionSectionTitleTextStyle}">
            <Setter Property="FontSize" Value="34" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="SensitivityMatchIntroOpeningWordTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HeroValueTextStyle}">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="124" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchIntroHeroPrimaryWordTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HeroValueTextStyle}">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="156" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchIntroHeroStackWordTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HeroValueTextStyle}">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="138" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchIntroHeroLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="38" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.Hero}" />
        </Style>

        <Style x:Key="SensitivityMatchIntroHeroConnectorTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HeroValueTextStyle}">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="52" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchSectionTitleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionSectionTitleTextStyle}">
            <Setter Property="FontSize" Value="22" />
        </Style>

        <Style x:Key="SensitivityMatchCompactTitleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSectionTitleTextStyle}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SensitivityMatchCompactValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource KeyDetectionMetricValueTextStyle}">
            <Setter Property="FontSize" Value="28" />
        </Style>

        <Style x:Key="SensitivityMatchLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SensitivityMatchInputTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource KeyDetectionThresholdTextBoxStyle}">
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Left" />
        </Style>

        <Style x:Key="SensitivityMatchPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource VoltButtonStyle}">
            <Setter Property="MinWidth" Value="168" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="20,0" />
        </Style>

        <Style x:Key="SensitivityMatchSecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MinimalGhostButtonStyle}">
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="18,0" />
        </Style>

        <Style x:Key="SensitivityMatchSetupDeviceNameTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSectionTitleTextStyle}">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchSetupBindingStateTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchSetupMetaTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HintTextStyle}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchSetupOptionalBindingStateTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupBindingStateTextStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SensitivityMatchSetupOptionalMetaTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupMetaTextStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SensitivityMatchSetupDpiInputTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource SensitivityMatchInputTextBoxStyle}">
            <Setter Property="Width" Value="136" />
        </Style>

        <Style x:Key="SensitivityMatchSetupEditorialDpiInputTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource SensitivityMatchSetupDpiInputTextBoxStyle}">
            <Setter Property="Width" Value="168" />
            <Setter Property="Height" Value="54" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="EditorialInputSurface"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0,10,0,8"
                                              VerticalAlignment="Center" />
                            </Border>
                            <Rectangle x:Name="EditorialInputTopRule"
                                       Height="1"
                                       VerticalAlignment="Top"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.18" />
                            <Rectangle x:Name="EditorialInputBottomRule"
                                       Height="1"
                                       VerticalAlignment="Bottom"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.82" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorialInputSurface" Property="Background" Value="#08FFFFFF" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorialInputSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="EditorialInputBottomRule" Property="Opacity" Value="1" />
                                <Setter TargetName="EditorialInputTopRule" Property="Opacity" Value="0.32" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorialInputSurface" Property="Opacity" Value="0.36" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SensitivityMatchSetupSourceEditorialDpiInputTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource SensitivityMatchSetupEditorialDpiInputTextBoxStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>

        <Style x:Key="SensitivityMatchSetupTargetEditorialDpiInputTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource SensitivityMatchSetupEditorialDpiInputTextBoxStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Left" />
        </Style>

        <Style x:Key="SensitivityMatchSetupBindButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SensitivityMatchSecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="216" />
        </Style>

        <Style x:Key="SensitivityMatchSetupEditorialBindButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SensitivityMatchSetupBindButtonStyle}">
            <Setter Property="MinWidth" Value="196" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource VoltGreenBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="EditorialButtonSurface"
                                    Background="{TemplateBinding Background}" />
                            <Rectangle x:Name="EditorialButtonTopRule"
                                       Height="1"
                                       VerticalAlignment="Top"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.18" />
                            <Rectangle x:Name="EditorialButtonBottomRule"
                                       Height="1"
                                       VerticalAlignment="Bottom"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.82" />
                            <ContentPresenter x:Name="EditorialButtonContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="#08FFFFFF" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialButtonContent" Property="Margin" Value="0,1,0,-1" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="EditorialButtonSurface" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="EditorialButtonBottomRule" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="EditorialButtonSurface" Property="Opacity" Value="0.34" />
                                <Setter TargetName="EditorialButtonContent" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SensitivityMatchSetupOverlayLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchLabelTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchSetupInfoBandLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupOverlayLabelTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="SensitivityMatchSetupInfoBandDeviceNameTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupDeviceNameTextStyle}">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SensitivityMatchSetupInfoBandBindingStateTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupOptionalBindingStateTextStyle}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style x:Key="SensitivityMatchSetupInfoBandMetaTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupOptionalMetaTextStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SensitivityMatchSetupEditorialInfoBandLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchLabelTextStyle}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchSetupEditorialInfoBandDeviceNameTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SensitivityMatchSetupEditorialInfoBandBindingStateTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupOptionalBindingStateTextStyle}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SensitivityMatchSetupEditorialInfoBandStableBindingStateTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupEditorialInfoBandBindingStateTextStyle}">
            <Setter Property="Height" Value="22" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Hidden" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SensitivityMatchSetupEditorialInfoBandMetaTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchSetupOptionalMetaTextStyle}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <DataTemplate x:Key="SensitivityMatchSetupSourceEditorialInfoBandTemplate">
            <Grid Width="388"
                  Height="84"
                  HorizontalAlignment="Right">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           HorizontalAlignment="Right"
                           Text="{Binding LabelText}"
                           TextAlignment="Right"
                           Style="{StaticResource SensitivityMatchSetupEditorialInfoBandLabelTextStyle}" />
                <TextBlock Grid.Row="2"
                           HorizontalAlignment="Right"
                           MaxWidth="388"
                           Text="{Binding DeviceTitle}"
                           TextAlignment="Right"
                           Style="{StaticResource SensitivityMatchSetupEditorialInfoBandDeviceNameTextStyle}" />
                <TextBlock Grid.Row="4"
                           HorizontalAlignment="Right"
                           Text="{Binding BindingStateText}"
                           TextAlignment="Right"
                           Style="{StaticResource SensitivityMatchSetupEditorialInfoBandStableBindingStateTextStyle}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SensitivityMatchSetupTargetEditorialInfoBandTemplate">
            <Grid Width="388"
                  Height="84"
                  HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           HorizontalAlignment="Left"
                           Text="{Binding LabelText}"
                           TextAlignment="Left"
                           Style="{StaticResource SensitivityMatchSetupEditorialInfoBandLabelTextStyle}" />
                <TextBlock Grid.Row="2"
                           HorizontalAlignment="Left"
                           MaxWidth="388"
                           Text="{Binding DeviceTitle}"
                           TextAlignment="Left"
                           Style="{StaticResource SensitivityMatchSetupEditorialInfoBandDeviceNameTextStyle}" />
                <TextBlock Grid.Row="4"
                           HorizontalAlignment="Left"
                           Text="{Binding BindingStateText}"
                           TextAlignment="Left"
                           Style="{StaticResource SensitivityMatchSetupEditorialInfoBandStableBindingStateTextStyle}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SensitivityMatchSetupInfoBandTemplate">
            <Grid HorizontalAlignment="{Binding BandHorizontalAlignment}">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding BandScaleX}" />
                </Grid.LayoutTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{Binding GapAfterTitle}" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="{Binding GapAfterBindingState}" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Margin="0,4,0,0"
                           Text="{Binding LabelText}"
                           Style="{StaticResource SensitivityMatchSetupInfoBandLabelTextStyle}">
                    <TextBlock.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding BandScaleX}" />
                    </TextBlock.LayoutTransform>
                </TextBlock>

                <TextBlock Grid.Column="2"
                           MaxWidth="246"
                           Text="{Binding DeviceTitle}"
                           Style="{StaticResource SensitivityMatchSetupInfoBandDeviceNameTextStyle}">
                    <TextBlock.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding BandScaleX}" />
                    </TextBlock.LayoutTransform>
                </TextBlock>

                <TextBlock Grid.Column="4"
                           Text="{Binding BindingStateText}"
                           Style="{StaticResource SensitivityMatchSetupInfoBandBindingStateTextStyle}">
                    <TextBlock.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding BandScaleX}" />
                    </TextBlock.LayoutTransform>
                </TextBlock>

                <TextBlock Grid.Column="6"
                           MaxWidth="136"
                           Text="{Binding MetaText}"
                           Style="{StaticResource SensitivityMatchSetupInfoBandMetaTextStyle}">
                    <TextBlock.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding BandScaleX}" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <Style x:Key="SensitivityMatchProgressBarStyle"
               TargetType="ProgressBar">
            <Setter Property="Height" Value="10" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource VoltGreenBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SensitivityMatchRoundBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource SensitivityMatchInsetBorderStyle}">
            <Setter Property="MinHeight" Value="136" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                    <Setter Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource ComboItemSelectedForegroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SensitivityMatchMeasureDeviceBandBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="SensitivityMatchMeasureDeviceLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchLabelTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
        </Style>

        <Style x:Key="SensitivityMatchMeasureDeviceNameTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SensitivityMatchMeasureDeviceSecondaryTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HintTextStyle}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SensitivityMatchMeasureOptionalDeviceSecondaryTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SensitivityMatchMeasureDeviceSecondaryTextStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SensitivityMatchMeasureHeroPrimaryTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HeroValueTextStyle}">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="188" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMeasureActiveState}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource VoltGreenBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMeasureFailureState}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource ComboItemSelectedForegroundBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMeasureExpiredState}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SensitivityMatchMeasureHeroLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

