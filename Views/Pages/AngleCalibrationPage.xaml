<UserControl x:Class="Views.Pages.AngleCalibrationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WpfApp1.Controls"
             Loaded="AngleCalibrationPage_Loaded"
             Unloaded="AngleCalibrationPage_Unloaded"
             IsVisibleChanged="AngleCalibrationPage_IsVisibleChanged"
             DataContextChanged="AngleCalibrationPage_DataContextChanged"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <Style x:Key="AngleCalibrationPanelBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionPanelBorderStyle}">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="{StaticResource Layout.AngleCalibration.CardPadding}" />
        </Style>

        <Style x:Key="AngleCalibrationMeasurementCardBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource AngleCalibrationPanelBorderStyle}">
            <Setter Property="Padding" Value="{StaticResource Layout.AngleCalibration.MeasurementCardPadding}" />
        </Style>

        <Style x:Key="AngleCalibrationInsetBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource KeyDetectionInsetSurfaceBorderStyle}">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="{StaticResource Layout.AngleCalibration.MeasurementSurfacePadding}" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        </Style>

        <Style x:Key="AngleCalibrationActionButtonBaseStyle"
               TargetType="Button"
               BasedOn="{StaticResource MinimalGhostButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource VoltGreenBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Meta}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="0"
                                    Opacity="0.94" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource VoltGreenHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.22" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource TextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AngleCalibrationActionPanelButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource AngleCalibrationActionButtonBaseStyle}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="0"
                                    Opacity="0.95" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource VoltGreenHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.22" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource TextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AngleCalibrationCaptureButtonStyle"
               TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Cross" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AngleCalibrationStatLabelTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource MicroLabelStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="AngleCalibrationStatValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
            <Setter Property="Typography.NumeralStyle" Value="Lining" />
        </Style>

        <Style x:Key="AngleCalibrationResultValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HeroValueTextStyle}">
            <Setter Property="FontSize" Value="{StaticResource Layout.AngleCalibration.ResultValueFontSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasRecommendedAngle}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AngleCalibrationResultUnitTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource HeroUnitTextStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasRecommendedAngle}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AngleCalibrationHintTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Body}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="AngleCalibrationQualityHintTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Body}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasQualityHint}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}"
          RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
        <Grid Margin="{StaticResource Layout.AngleCalibration.PageMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="{StaticResource Layout.AngleCalibration.SectionGap}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.76*" />
                    <ColumnDefinition Width="0.24*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        MinHeight="{StaticResource Layout.AngleCalibration.ResultCardMinHeight}"
                        Height="{StaticResource Layout.AngleCalibration.TopCardHeight}"
                        BorderThickness="1,1,1,0"
                        Style="{StaticResource AngleCalibrationPanelBorderStyle}">
                    <Grid>
                        <TextBlock VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Text="{DynamicResource AngleCalibration.Result.Title}"
                                   Style="{StaticResource KeyDetectionCardTitleTextStyle}"
                                   FontSize="36" />

                        <Grid HorizontalAlignment="Center"
                              Margin="135,0,0,0"
                              VerticalAlignment="Center">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Opacity" Value="0.72" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRecommendedAngle}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding RecommendedAngleText}"
                                       Style="{StaticResource AngleCalibrationResultValueTextStyle}" />
                            <TextBlock Grid.Column="1"
                                       Margin="4,5,0,0"
                                       VerticalAlignment="Center"
                                       Text="&#176;"
                                       Style="{StaticResource AngleCalibrationResultUnitTextStyle}"
                                       FontSize="20" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Height="{StaticResource Layout.AngleCalibration.TopCardHeight}"
                        BorderThickness="1,1,1,0"
                        Padding="0"
                        Style="{StaticResource AngleCalibrationPanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Command="{Binding CopyAngleCommand}"
                                Content="{DynamicResource AngleCalibration.Button.CopyAngle}"
                                Style="{StaticResource AngleCalibrationActionPanelButtonStyle}" />

                        <Border Grid.Row="1"
                                Background="{DynamicResource HairlineBrush}"
                                IsHitTestVisible="False" />

                        <Button Grid.Row="2"
                                Command="{Binding ResetCommand}"
                                Content="{DynamicResource AngleCalibration.Button.Reset}"
                                Style="{StaticResource AngleCalibrationActionPanelButtonStyle}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Background="{DynamicResource HairlineBrush}"
                    IsHitTestVisible="False" />

            <Border Grid.Row="2"
                    MinHeight="420"
                    BorderThickness="1,0,1,1"
                    Style="{StaticResource AngleCalibrationMeasurementCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="18,0,18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.ColumnSpan="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource AngleCalibration.Stats.Swipes}"
                                           Style="{StaticResource AngleCalibrationStatLabelTextStyle}" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="{Binding SwipeCountText}"
                                           Style="{StaticResource AngleCalibrationStatValueTextStyle}" />
                            </StackPanel>

                            <StackPanel Margin="180,0,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource AngleCalibration.Stats.Samples}"
                                           Style="{StaticResource AngleCalibrationStatLabelTextStyle}" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="{Binding SampleCountText}"
                                           Style="{StaticResource AngleCalibrationStatValueTextStyle}" />
                            </StackPanel>

                            <StackPanel Margin="180,0,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource AngleCalibration.Stats.Stability}"
                                           Style="{StaticResource AngleCalibrationStatLabelTextStyle}" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="{Binding StabilityText}"
                                           Style="{StaticResource AngleCalibrationStatValueTextStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            MinHeight="320"
                            Style="{StaticResource AngleCalibrationInsetBorderStyle}"
                            Padding="0">
                        <Button x:Name="CaptureSurfaceButton"
                                Command="{Binding CaptureSurfaceCommand}"
                                Style="{StaticResource AngleCalibrationCaptureButtonStyle}">
                            <Grid Margin="{StaticResource Layout.AngleCalibration.MeasurementSurfacePadding}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding TopHintText}"
                                               Style="{StaticResource AngleCalibrationHintTextStyle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding QualityHintText}"
                                               Style="{StaticResource AngleCalibrationQualityHintTextStyle}" />
                                </StackPanel>

                                <controls:AngleCalibrationTraceControl Grid.Row="2"
                                                                       RenderFrame="{Binding RenderFrame}" />
                            </Grid>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
