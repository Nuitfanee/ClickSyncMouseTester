<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:WpfApp1.Controls"
        xmlns:converters="clr-namespace:WpfApp1.Converters"
        xmlns:navigation="clr-namespace:WpfApp1.Navigation"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="{DynamicResource Window.Title}"
        Height="{StaticResource Layout.Window.DefaultHeight}"
        Width="{StaticResource Layout.Window.DefaultWidth}"
        MinHeight="{StaticResource Layout.Window.MinHeight}"
        MinWidth="{StaticResource Layout.Window.MinWidth}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="{DynamicResource Font.Body}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextRenderingMode="{StaticResource TextRenderingMode.ClearType}"
        TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.Body}"
        TextOptions.TextHintingMode="{StaticResource TextHintingMode.UI}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{StaticResource Layout.Chrome.CaptionHeight}"
                            ResizeBorderThickness="{StaticResource Layout.Chrome.ResizeBorderThickness}"
                            CornerRadius="{StaticResource Layout.Window.CornerRadius}"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:NavigationMenuForegroundConverter x:Key="NavigationMenuForegroundConverter" />
        <converters:NavigationMenuIndexConverter x:Key="NavigationMenuIndexConverter" />
        <Style x:Key="OuterPageFrameGuideBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentPageKey}" Value="{x:Static navigation:AppPageKey.PollingDashboard}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentPageKey}" Value="{x:Static navigation:AppPageKey.AngleCalibration}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PollingPageFrameGuideBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentPageKey}" Value="{x:Static navigation:AppPageKey.PollingDashboard}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    

    <Grid x:Name="WindowPresentationSurface"
          Background="{DynamicResource WindowBackgroundBrush}"
          Opacity="0"
          RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource Layout.Chrome.RowHeight}" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Margin="{StaticResource Layout.OuterFrame.Margin}"
                BorderBrush="{DynamicResource WindowOuterBorderBrush}"
                BorderThickness="{StaticResource Thickness.WindowOuterBorder.All}"
                CornerRadius="{StaticResource Layout.Window.CornerRadius}"
                Panel.ZIndex="1000"
                SnapsToDevicePixels="True"
                IsHitTestVisible="False" />
        <Border Grid.Row="0"
                Background="{DynamicResource GlassTitleBarBackgroundBrush}"
                BorderBrush="{DynamicResource GlassTitleBarBorderBrush}"
                BorderThickness="0,0,0,1"
                CornerRadius="{StaticResource Layout.Window.TopCornerRadius}"
                RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
            <Grid Margin="{StaticResource Layout.Chrome.ContentMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource Layout.Chrome.NavigationButtonColumnWidth}" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Margin="{StaticResource Layout.Chrome.NavigationButtonMargin}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Click="NavigationMenuToggleButton_Click"
                        ToolTip="{DynamicResource Navigation.Menu.Open}"
                        Style="{StaticResource HamburgerNavigationButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True" />

                <Grid Grid.Column="1"
                      Margin="18,0,18,0"
                      VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,18,0">
                        <Rectangle Width="{StaticResource Layout.Chrome.SignalSize}"
                                   Height="{StaticResource Layout.Chrome.SignalSize}"
                                   Fill="{DynamicResource VoltGreenBrush}"
                                   Margin="0,1,12,0" />
                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   Style="{StaticResource MicroLabelStyle}"
                                   Foreground="{DynamicResource TextStrongBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="BY NUITFANEE"
                                   Style="{StaticResource InvariantMicroLabelStyle}"
                                   Foreground="{DynamicResource TextFaintBrush}"
                                   VerticalAlignment="Center" />
                        <Button Width="22"
                                Height="22"
                                Margin="10,0,0,0"
                                Foreground="{DynamicResource TextStrongBrush}"
                                ToolTip="GitHub / Nuitfanee"
                                Click="GithubLinkButton_Click"
                                Style="{StaticResource HeaderToggleLinkButtonStyle}"
                                VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="16"
                                     Height="16"
                                     Stretch="Uniform">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="F1 M 8,0.25 C 3.72,0.25 0.25,3.72 0.25,8 C 0.25,11.43 2.47,14.34 5.55,15.37 C 5.95,15.44 6.09,15.2 6.09,14.99 C 6.09,14.81 6.08,14.22 6.07,13.43 C 3.87,13.91 3.4,12.37 3.4,12.37 C 3.04,11.45 2.52,11.2 2.52,11.2 C 1.8,10.71 2.58,10.72 2.58,10.72 C 3.38,10.78 3.8,11.54 3.8,11.54 C 4.5,12.76 5.66,12.4 6.11,12.19 C 6.18,11.67 6.39,11.31 6.63,11.1 C 4.87,10.9 3.02,10.22 3.02,7.19 C 3.02,6.33 3.32,5.62 3.82,5.07 C 3.74,4.87 3.48,4.06 3.89,2.96 C 3.89,2.96 4.56,2.75 6.08,3.78 C 6.72,3.6 7.4,3.51 8.08,3.51 C 8.76,3.51 9.44,3.6 10.08,3.78 C 11.6,2.75 12.27,2.96 12.27,2.96 C 12.68,4.06 12.42,4.87 12.34,5.07 C 12.84,5.62 13.14,6.33 13.14,7.19 C 13.14,10.23 11.28,10.9 9.52,11.1 C 9.82,11.36 10.09,11.87 10.09,12.66 C 10.09,13.8 10.08,14.72 10.08,14.99 C 10.08,15.2 10.22,15.45 10.63,15.37 C 13.7,14.33 15.91,11.43 15.91,8 C 15.91,3.72 12.44,0.25 8.16,0.25 L 8,0.25 Z" />
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Grid Margin="0,0,40,0"
                          VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="HeaderLanguageZhButton"
                                Grid.Row="0"
                                Grid.Column="0"
                                Command="{Binding ToggleLanguageCommand}"
                                ToolTip="{Binding LanguageToggleText}"
                                Tag="{Binding IsChineseLanguageCurrent}"
                                Style="{StaticResource HeaderToggleLinkButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="简中"
                                       Style="{StaticResource HeaderToggleLinkTextStyle}" />
                        </Button>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="8,0"
                                   Text="/"
                                   Style="{StaticResource HeaderToggleDividerTextStyle}" />

                        <Button x:Name="HeaderLanguageEnButton"
                                Grid.Row="0"
                                Grid.Column="2"
                                Command="{Binding ToggleLanguageCommand}"
                                ToolTip="{Binding LanguageToggleText}"
                                Tag="{Binding IsEnglishLanguageCurrent}"
                                Style="{StaticResource HeaderToggleLinkButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="EN"
                                       Style="{StaticResource HeaderToggleLinkTextStyle}" />
                        </Button>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Height="1"
                                Margin="0,2,0,0"
                                Background="{DynamicResource TextStrongBrush}"
                                RenderTransformOrigin="0,0.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0" ScaleY="1" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, ElementName=HeaderLanguageZhButton}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Tag, ElementName=HeaderLanguageZhButton}" Value="False" />
                                                <Condition Binding="{Binding IsMouseOver, ElementName=HeaderLanguageZhButton}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Opacity" Value="1" />
                                            <MultiDataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="1"
                                                                         Duration="0:0:0.3"
                                                                         EasingFunction="{StaticResource MotionOutEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.EnterActions>
                                            <MultiDataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="0"
                                                                         Duration="0:0:0.3"
                                                                         EasingFunction="{StaticResource MotionInOutEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.ExitActions>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="2"
                                Height="1"
                                Margin="0,2,0,0"
                                Background="{DynamicResource TextStrongBrush}"
                                RenderTransformOrigin="0,0.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0" ScaleY="1" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, ElementName=HeaderLanguageEnButton}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Tag, ElementName=HeaderLanguageEnButton}" Value="False" />
                                                <Condition Binding="{Binding IsMouseOver, ElementName=HeaderLanguageEnButton}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Opacity" Value="1" />
                                            <MultiDataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="1"
                                                                         Duration="0:0:0.3"
                                                                         EasingFunction="{StaticResource MotionOutEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.EnterActions>
                                            <MultiDataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="0"
                                                                         Duration="0:0:0.3"
                                                                         EasingFunction="{StaticResource MotionInOutEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.ExitActions>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,28,0"
                          VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="HeaderThemeLightButton"
                                Grid.Row="0"
                                Grid.Column="0"
                                Command="{Binding ToggleThemeCommand}"
                                ToolTip="{Binding ThemeToggleText}"
                                Tag="{Binding IsLightThemeCurrent}"
                                Style="{StaticResource HeaderToggleLinkButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="{DynamicResource Theme.Toggle.KeyLight}"
                                       Style="{StaticResource HeaderToggleLinkTextStyle}" />
                        </Button>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Margin="8,0"
                                   Text="/"
                                   Style="{StaticResource HeaderToggleDividerTextStyle}" />

                        <Button x:Name="HeaderThemeDarkButton"
                                Grid.Row="0"
                                Grid.Column="2"
                                Command="{Binding ToggleThemeCommand}"
                                ToolTip="{Binding ThemeToggleText}"
                                Tag="{Binding IsDarkThemeCurrent}"
                                Style="{StaticResource HeaderToggleLinkButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock Text="{DynamicResource Theme.Toggle.KeyDark}"
                                       Style="{StaticResource HeaderToggleLinkTextStyle}" />
                        </Button>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Height="1"
                                Margin="0,2,0,0"
                                Background="{DynamicResource TextStrongBrush}"
                                RenderTransformOrigin="0,0.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0" ScaleY="1" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, ElementName=HeaderThemeLightButton}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Tag, ElementName=HeaderThemeLightButton}" Value="False" />
                                                <Condition Binding="{Binding IsMouseOver, ElementName=HeaderThemeLightButton}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Opacity" Value="1" />
                                            <MultiDataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="1"
                                                                         Duration="0:0:0.3"
                                                                         EasingFunction="{StaticResource MotionOutEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.EnterActions>
                                            <MultiDataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="0"
                                                                         Duration="0:0:0.3"
                                                                         EasingFunction="{StaticResource MotionInOutEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.ExitActions>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="2"
                                Height="1"
                                Margin="0,2,0,0"
                                Background="{DynamicResource TextStrongBrush}"
                                RenderTransformOrigin="0,0.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0" ScaleY="1" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, ElementName=HeaderThemeDarkButton}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Tag, ElementName=HeaderThemeDarkButton}" Value="False" />
                                                <Condition Binding="{Binding IsMouseOver, ElementName=HeaderThemeDarkButton}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Opacity" Value="1" />
                                            <MultiDataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="1"
                                                                         Duration="0:0:0.3"
                                                                         EasingFunction="{StaticResource MotionOutEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.EnterActions>
                                            <MultiDataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="0"
                                                                         Duration="0:0:0.3"
                                                                         EasingFunction="{StaticResource MotionInOutEase}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </MultiDataTrigger.ExitActions>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>
                </StackPanel>

                <Border Grid.Column="3" Width="1" Height="{StaticResource Layout.Chrome.SectionDividerHeight}" Background="{DynamicResource HairlineBrush}" VerticalAlignment="Center" />

                <Button Grid.Column="4"
                        Click="MinimizeButton_Click"
                        Style="{StaticResource TitleBarButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="{StaticResource Layout.Chrome.GlyphFontSize}"
                               TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.UI}"
                               Text="&#xE921;" />
                </Button>

                <Button x:Name="MaximizeRestoreButton"
                        Grid.Column="5"
                        Click="MaximizeRestoreButton_Click"
                        Style="{StaticResource TitleBarButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock x:Name="MaximizeRestoreGlyph"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="{StaticResource Layout.Chrome.GlyphFontSize}"
                               TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.UI}"
                               Text="&#xE922;" />
                </Button>

                <Button Grid.Column="6"
                        Click="CloseButton_Click"
                        Style="{StaticResource TitleBarCloseButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="{StaticResource Layout.Chrome.GlyphFontSize}"
                               TextOptions.TextFormattingMode="{StaticResource TextFormattingMode.UI}"
                               Text="&#xE8BB;" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              x:Name="WindowContentSurface"
              Margin="{StaticResource Layout.Main.Margin}"
              Opacity="0"
              RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="WindowContentStartupTransform" Y="12" />
            </Grid.RenderTransform>
            <ContentControl x:Name="CurrentPageHost"
                            Content="{Binding CurrentPage}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            RenderTransformOrigin="0.5,0">
                <ContentControl.RenderTransform>
                    <TranslateTransform Y="0" />
                </ContentControl.RenderTransform>
            </ContentControl>

        </Grid>

        <Border Grid.Row="1"
                Margin="48,0,0,0"
                HorizontalAlignment="Left"
                Width="1"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1,0,0,0"
                Style="{StaticResource OuterPageFrameGuideBorderStyle}"
                Panel.ZIndex="30"
                IsHitTestVisible="False" />
        <Border Grid.Row="1"
                Margin="0,0,404,0"
                HorizontalAlignment="Right"
                Width="1"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1,0,0,0"
                Style="{StaticResource PollingPageFrameGuideBorderStyle}"
                Panel.ZIndex="30"
                IsHitTestVisible="False" />
        <Border Grid.Row="1"
                Margin="0,0,48,0"
                HorizontalAlignment="Right"
                Width="1"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="1,0,0,0"
                Style="{StaticResource OuterPageFrameGuideBorderStyle}"
                Panel.ZIndex="30"
                IsHitTestVisible="False" />
        <Border x:Name="NavigationCurtainSurface"
                Grid.RowSpan="2"
                Panel.ZIndex="120"
                Background="{DynamicResource NavigationCurtainBackgroundBrush}"
                BorderBrush="{DynamicResource NavigationCurtainBorderBrush}"
                BorderThickness="0"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                SizeChanged="NavigationCurtainSurface_SizeChanged">
            <Border.Clip>
                <RectangleGeometry x:Name="NavigationCurtainClipGeometry" Rect="0,0,0,0" />
            </Border.Clip>
            <Grid x:Name="NavigationCurtainContent"
                  RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
                <Border Background="Transparent"
                        MouseLeftButtonDown="NavigationBackdrop_MouseLeftButtonDown" />
                <Border x:Name="NavigationCurtainVerticalGuide"
                        Width="1"
                        Background="{DynamicResource NavigationMenuTextBrush}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Panel.ZIndex="1"
                        IsHitTestVisible="False" />
                <Grid x:Name="NavigationCurtainLayoutRoot"
                      Margin="{StaticResource Layout.Navigation.OverlayPadding}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="NavigationCurtainTopGuideRow" Height="0" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="NavigationCurtainLeftGuideColumn" Width="0" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Height="1"
                            Background="{DynamicResource NavigationMenuTextBrush}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="1"
                            IsHitTestVisible="False" />
                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Margin="0"
                                Panel.ZIndex="2"
                                RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
                        <StackPanel.RenderTransform>
                            <TranslateTransform X="-20"
                                                Y="-30" />
                        </StackPanel.RenderTransform>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,28,0">
                            <Button x:Name="NavigationGithubLinkButton"
                                    Width="36"
                                    Height="36"
                                    Foreground="{DynamicResource NavigationMenuTextBrush}"
                                    ToolTip="GitHub / Nuitfanee"
                                    Click="GithubLinkButton_Click"
                                    Style="{StaticResource HeaderToggleLinkButtonStyle}"
                                    VerticalAlignment="Center">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
