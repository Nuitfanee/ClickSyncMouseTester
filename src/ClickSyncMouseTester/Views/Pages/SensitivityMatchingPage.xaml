                      <FrameworkElement.Style>
                        <Style TargetType="{x:Type StackPanel}">
                          <Setter Property="Visibility" Value="Visible" />
                          <Style.Triggers>
                            <Trigger Property="FrameworkElement.Tag" Value="--">
                              <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                          </Style.Triggers>
                        </Style>
                      </FrameworkElement.Style>
                      <TextBlock HorizontalAlignment="Left" MaxWidth="318" TextAlignment="Left" Style="{StaticResource SensitivityMatchMeasureLaneDeviceTextStyle}" Text="{Binding TargetInfoBand.DeviceTitle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.RowSpan="3" Width="318" Margin="0,18,0,14" HorizontalAlignment="Left" VerticalAlignment="Center" Tag="{Binding MeasureTargetValueText}">
                      <FrameworkElement.Style>
                        <Style TargetType="{x:Type StackPanel}">
                          <Setter Property="Visibility" Value="Collapsed" />
                          <Style.Triggers>
                            <Trigger Property="FrameworkElement.Tag" Value="--">
                              <Setter Property="Visibility" Value="Visible" />
                            </Trigger>
                          </Style.Triggers>
                        </Style>
                      </FrameworkElement.Style>
                      <TextBlock HorizontalAlignment="Left" Text="{DynamicResource SensitivityMatch.Measure.TargetLane}" TextAlignment="Left" Style="{StaticResource MeasureEditorialAxisLabelTextStyle}" />
                      <TextBlock Margin="0,12,0,0" HorizontalAlignment="Left" TextAlignment="Left" Style="{StaticResource MeasureEditorialLaneSupportTextStyle}" Text="{Binding TargetProgressText}" />
                      <Rectangle Height="1" Margin="0,18,72,18" Fill="{DynamicResource HairlineBrush}" Opacity="0.14" />
                      <TextBlock HorizontalAlignment="Left" MaxWidth="318" TextAlignment="Left" Style="{StaticResource SensitivityMatchMeasureLaneDeviceTextStyle}" Text="{Binding TargetInfoBand.DeviceTitle}" />
                    </StackPanel>
                  </Grid>
                </Grid>
              </Grid>
            </Grid>
            <Grid Name="MeasureRoundsList" Row="1" Margin="0,4,0,10">
              <UIElement.RenderTransform>
                <TranslateTransform x:Name="MeasureRoundsTranslate">
                </TranslateTransform>
              </UIElement.RenderTransform>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource SensitivityMatch.Measure.RoundsTitle}" Style="{StaticResource MeasureEditorialAxisLabelTextStyle}" />
                <Rectangle Grid.Column="1" Height="1" Margin="16,8,0,0" VerticalAlignment="Top" Fill="{DynamicResource HairlineBrush}" Opacity="0.16" />
              </Grid>
              <ItemsControl Grid.Row="1" ItemsSource="{Binding Rounds}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Style="{StaticResource MeasureEditorialRoundRowBorderStyle}">
                      <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="84" />
                          <ColumnDefinition Width="112" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource MeasureEditorialRoundTitleTextStyle}" Text="{Binding Title}" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource MeasureEditorialRoundStatusTextStyle}" Text="{Binding StatusText}" />
                        <TextBlock Grid.Column="2" Margin="18,0,28,0" VerticalAlignment="Center" Text="{Binding DetailText}">
                          <FrameworkElement.Style>
                            <Style BasedOn="{StaticResource MeasureEditorialRoundDetailTextStyle}" TargetType="{x:Type TextBlock}">
                              <Setter Property="Visibility" Value="Visible" />
                              <Style.Triggers>
                                <DataTrigger Value="True" Binding="{Binding ShowProgressTrack}">
                                  <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </FrameworkElement.Style>
                        </TextBlock>
                        <Border Grid.Column="2" Margin="18,0,28,0" HorizontalAlignment="Stretch">
                          <FrameworkElement.Style>
                            <Style BasedOn="{StaticResource MeasureEditorialRoundTrackSurfaceStyle}" TargetType="{x:Type Border}">
                              <Setter Property="Visibility" Value="Collapsed" />
                              <Style.Triggers>
                                <DataTrigger Value="True" Binding="{Binding ShowProgressTrack}">
                                  <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </FrameworkElement.Style>
                          <Grid Height="48">
                            <Grid ClipToBounds="True">
                              <Border Margin="0,19,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top" Style="{StaticResource MeasureEditorialRoundTrackLineStyle}" />
                              <Rectangle Margin="0,14,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource MeasureEditorialRoundTrackStartMarkerStyle}" />
                              <Canvas Name="RoundTrackTravelCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="48" ClipToBounds="True" UseLayoutRounding="True">
                                <Grid Canvas.Left="10" Canvas.Top="7" Style="{StaticResource MeasureEditorialRoundTrackMouseHostStyle}" UseLayoutRounding="True">
                                  <UIElement.RenderTransform>
                                    <TranslateTransform>
                                      <TranslateTransform.X>
                                        <MultiBinding Converter="{StaticResource TrackProgressOffsetConverter}" ConverterParameter="60">
                                          <Binding Path="TrackProgressValue" />
                                          <Binding ElementName="RoundTrackTravelCanvas" Path="ActualWidth" />
                                        </MultiBinding>
                                      </TranslateTransform.X>
                                    </TranslateTransform>
                                  </UIElement.RenderTransform>
                                  <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="24" />
                                  </Grid.ColumnDefinitions>
                                  <Grid Column="0">
                                    <Border Style="{StaticResource MeasureEditorialRoundTrackMouseBodyStyle}" />
                                    <Border Width="6" Height="13" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,6,0,0" CornerRadius="3" Background="#101215" />
                                    <Rectangle Height="1" Margin="0,18,0,0" VerticalAlignment="Top" Fill="#16000000" />
                                  </Grid>
                                  <Grid Column="2">
                                    <Border Style="{StaticResource MeasureEditorialRoundTrackMouseBodyStyle}" />
                                    <Border Width="6" Height="13" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,6,0,0" CornerRadius="3" Background="#101215" />
                                    <Rectangle Height="1" Margin="0,18,0,0" VerticalAlignment="Top" Fill="#16000000" />
                                  </Grid>
                                </Grid>
                              </Canvas>
                            </Grid>
                          </Grid>
                        </Border>
                        <TextBlock Grid.Column="3" MinWidth="84" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource MeasureEditorialRoundValueTextStyle}" Text="{Binding ValueText}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
            <Canvas Name="MeasureTransitionOverlay" ZIndex="8" Visibility="Collapsed" IsHitTestVisible="False">
              <TextBlock Name="MeasureTransitionLeftWord" Text="SOURCE" RenderTransformOrigin="0,0" Style="{StaticResource MeasureTransitionOverlayWordTextStyle}">
                <UIElement.RenderTransform>
                  <TransformGroup>
                    <ScaleTransform x:Name="MeasureTransitionLeftScale">
                    </ScaleTransform>
                    <TranslateTransform x:Name="MeasureTransitionLeftTranslate">
                    </TranslateTransform>
                  </TransformGroup>
                </UIElement.RenderTransform>
              </TextBlock>
              <TextBlock Name="MeasureTransitionRightWord" Text="TARGET" RenderTransformOrigin="0,0" Style="{StaticResource MeasureTransitionOverlayWordTextStyle}">
                <UIElement.RenderTransform>
                  <TransformGroup>
                    <ScaleTransform x:Name="MeasureTransitionRightScale">
                    </ScaleTransform>
                    <TranslateTransform x:Name="MeasureTransitionRightTranslate">
                    </TranslateTransform>
                  </TransformGroup>
                </UIElement.RenderTransform>
              </TextBlock>
            </Canvas>
          </Grid>
        </Grid>
      </Border>
      <Border Grid.Row="3" Background="{DynamicResource HairlineBrush}" />
      <Border Grid.Row="4" MinHeight="{StaticResource Layout.SensitivityMatch.ActionMinHeight}" BorderThickness="1,0,1,1" Style="{StaticResource SensitivityMatchPanelBorderStyle}">
        <Grid>
          <Grid Name="IntroActionSectionHost" Style="{StaticResource SectionIntroStyle}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid Name="IntroActionHost" Column="1" Opacity="0">
              <UIElement.RenderTransform>
                <TranslateTransform x:Name="IntroActionTranslate" Y="12">
                </TranslateTransform>
              </UIElement.RenderTransform>
              <Button Name="IntroStartButton" Content="{DynamicResource SensitivityMatch.Button.StartSetup}" IsHitTestVisible="False" IsTabStop="False" Style="{StaticResource SensitivityMatchPrimaryButtonStyle}" Click="IntroStartButton_Click" />
            </Grid>
          </Grid>
          <Grid Name="SetupFooterHost" Style="{StaticResource SectionSetupFooterStyle}">
            <UIElement.RenderTransform>
              <TranslateTransform x:Name="SetupFooterTranslate">
              </TranslateTransform>
            </UIElement.RenderTransform>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="{DynamicResource SensitivityMatch.Button.Back}" Style="{StaticResource SensitivityMatchSecondaryButtonStyle}" Click="SetupBackButton_Click" />
            <Button Grid.Column="2" Content="{DynamicResource SensitivityMatch.Button.ContinueToMeasure}" Style="{StaticResource SensitivityMatchPrimaryButtonStyle}" IsEnabled="{Binding IsContinueFromSetupEnabled}" Click="ContinueToMeasureButton_Click" />
          </Grid>
          <Grid Name="MeasureFooterHost" Style="{StaticResource SectionMeasureStyle}">
            <UIElement.RenderTransform>
              <TranslateTransform x:Name="MeasureFooterTranslate">
              </TranslateTransform>
            </UIElement.RenderTransform>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="{DynamicResource SensitivityMatch.Button.Back}" Style="{StaticResource SensitivityMatchSecondaryButtonStyle}" Click="MeasureBackButton_Click" />
            <StackPanel Grid.Column="1" HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Foreground="{DynamicResource TextStrongBrush}" Style="{StaticResource SensitivityMatchLabelTextStyle}" Text="{Binding StatusPillText}" />
            </StackPanel>
            <Button Grid.Column="2" Style="{StaticResource MeasureFooterStartButtonStyle}" Command="{Binding StartRoundCommand}" Content="{Binding StartRoundButtonText}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Style="{StaticResource MeasureFooterResultActionsHostStyle}">
              <Button Content="{DynamicResource SensitivityMatch.Button.Remeasure}" Style="{StaticResource SensitivityMatchSecondaryButtonStyle}" Command="{Binding RemeasureCommand}" />
              <Button Margin="10,0,0,0" Content="{DynamicResource SensitivityMatch.Button.CopyRecommendedDpi}" Style="{StaticResource SensitivityMatchPrimaryButtonStyle}" Command="{Binding CopyRecommendedDpiCommand}" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
