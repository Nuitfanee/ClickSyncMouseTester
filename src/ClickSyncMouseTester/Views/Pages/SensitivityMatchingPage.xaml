        <RowDefinition Height="1" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0" BorderThickness="1">
        <FrameworkElement.Style>
          <Style BasedOn="{StaticResource SensitivityMatchPanelBorderStyle}" TargetType="{x:Type Border}">
            <Setter Property="MinHeight" Value="{StaticResource Layout.SensitivityMatch.HeaderMinHeight}" />
            <Style.Triggers>
              <DataTrigger Value="True" Binding="{Binding IsIntroStep}">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
