                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
              <DataTrigger Value="True" Binding="{Binding IsMeasureStep}">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </FrameworkElement.Style>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.35*" />
            <ColumnDefinition Width="0.95*" />
          </Grid.ColumnDefinitions>
          <StackPanel Margin="0,0,28,0">
            <TextBlock Text="{DynamicResource SensitivityMatch.Header.Eyebrow}" Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
            <TextBlock Margin="0,8,0,0" Text="{DynamicResource SensitivityMatch.PageTitle}" Style="{StaticResource SensitivityMatchHeadlineTextStyle}" />
            <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
              <Border Padding="12,6" HorizontalAlignment="Left" Tag="{Binding StatusPillText}">
                <FrameworkElement.Style>
                  <Style BasedOn="{StaticResource SensitivityMatchInsetBorderStyle}" TargetType="{x:Type Border}">
                    <Style.Triggers>
                      <Trigger Property="FrameworkElement.Tag" Value="">
