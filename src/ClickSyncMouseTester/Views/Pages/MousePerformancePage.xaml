<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="ClickSyncMouseTester.Views.Pages.MousePerformancePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="clr-namespace:ClickSyncMouseTester.Controls" SnapsToDevicePixels="True" UseLayoutRounding="True" xmlns:pages="clr-namespace:ClickSyncMouseTester.Views.Pages;assembly=ClickSyncMouseTester" Loaded="MousePerformancePage_Loaded" Unloaded="MousePerformancePage_Unloaded">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Style x:Key="MousePerformanceSectionTitleStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MicroLabelStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextBlock.TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
      </Style>
      <Style x:Key="MousePerformanceFieldLabelStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MicroLabelStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
      </Style>
      <Style x:Key="MousePerformanceStatusMessageBlockStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource StatusMessageTextStyle}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextBlock.LineHeight" Value="24" />
        <Setter Property="TextBlock.LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextBlock.TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
      </Style>
      <Style x:Key="MousePerformanceQualityTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HintTextStyle}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextBlock.LineHeight" Value="18" />
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="TextBlock.TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="NoWrap" />
      </Style>
      <Style x:Key="MousePerformanceQualityVisibleTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MousePerformanceQualityTextStyle}">
        <Setter Property="Visibility" Value="Hidden" />
        <Style.Triggers>
          <DataTrigger Value="True" Binding="{Binding IsQualityVisible}">
            <Setter Property="Visibility" Value="Visible" />
          </DataTrigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="MousePerformanceValueTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="34" />
        <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        <Setter Property="Typography.NumeralStyle" Value="Lining" />
        <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
        <Setter Property="TextBlock.TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
      </Style>
      <Style x:Key="MousePerformanceSummaryLabelStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MicroLabelStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextBlock.TextAlignment" Value="Center" />
      </Style>
      <Style x:Key="MousePerformanceSummaryUnitStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HintTextStyle}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextBlock.LineHeight" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextBlock.TextAlignment" Value="Center" />
      </Style>
      <Style x:Key="MousePerformanceEditorialInputTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource KeyDetectionThresholdTextBoxStyle}">
        <Setter Property="Width" Value="168" />
        <Setter Property="Height" Value="54" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="TextBoxBase.CaretBrush" Value="{DynamicResource TextStrongBrush}" />
        <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="TextBox.TextAlignment" Value="Center" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type TextBox}">
              <Grid SnapsToDevicePixels="True">
                <Border Name="EditorialInputSurface" Background="{TemplateBinding Control.Background}">
                  <ScrollViewer Name="PART_ContentHost" Margin="0,10,0,8" VerticalAlignment="Center" />
                </Border>
                <Rectangle Name="EditorialInputTopRule" Height="1" VerticalAlignment="Top" Fill="{TemplateBinding Control.BorderBrush}" Opacity="0.18" />
                <Rectangle Name="EditorialInputBottomRule" Height="1" VerticalAlignment="Bottom" Fill="{TemplateBinding Control.BorderBrush}" Opacity="0.82" />
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="EditorialInputSurface" Property="Border.Background" Value="#08FFFFFF" />
                  <Setter TargetName="EditorialInputBottomRule" Value="{DynamicResource TextStrongBrush}" Property="Shape.Fill" />
                  <Setter TargetName="EditorialInputBottomRule" Property="UIElement.Opacity" Value="1" />
                </Trigger>
                <Trigger Property="UIElement.IsKeyboardFocused" Value="True">
                  <Setter TargetName="EditorialInputSurface" Value="{DynamicResource GhostHoverBrush}" Property="Border.Background" />
                  <Setter TargetName="EditorialInputBottomRule" Value="{DynamicResource TextStrongBrush}" Property="Shape.Fill" />
                  <Setter TargetName="EditorialInputBottomRule" Property="UIElement.Opacity" Value="1" />
                  <Setter TargetName="EditorialInputTopRule" Property="UIElement.Opacity" Value="0.32" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="EditorialInputSurface" Property="UIElement.Opacity" Value="0.36" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="MousePerformanceEditorialActionButtonBaseStyle" TargetType="{x:Type Button}">
        <Setter Property="MinWidth" Value="164" />
        <Setter Property="Height" Value="54" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.DisplaySans}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Grid SnapsToDevicePixels="True">
                <Border Name="EditorialButtonSurface" Background="{TemplateBinding Control.Background}" />
                <Rectangle Name="EditorialButtonTopRule" Height="1" VerticalAlignment="Top" Fill="{TemplateBinding Control.BorderBrush}" Opacity="0.18" />
                <Rectangle Name="EditorialButtonBottomRule" Height="1" VerticalAlignment="Bottom" Fill="{TemplateBinding Control.BorderBrush}" Opacity="0.82" />
                <ContentPresenter Name="EditorialButtonContent" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Control.Padding}" />
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="EditorialButtonSurface" Property="Border.Background" Value="#08FFFFFF" />
                  <Setter TargetName="EditorialButtonBottomRule" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
                  <Setter TargetName="EditorialButtonBottomRule" Property="UIElement.Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="EditorialButtonSurface" Value="{DynamicResource GhostHoverBrush}" Property="Border.Background" />
                  <Setter TargetName="EditorialButtonContent" Property="Margin" Value="0,1,0,-1" />
                  <Setter TargetName="EditorialButtonBottomRule" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
                  <Setter TargetName="EditorialButtonBottomRule" Property="UIElement.Opacity" Value="1" />
                </Trigger>
                <Trigger Property="UIElement.IsKeyboardFocused" Value="True">
                  <Setter TargetName="EditorialButtonSurface" Value="{DynamicResource GhostHoverBrush}" Property="Border.Background" />
                  <Setter TargetName="EditorialButtonBottomRule" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
                  <Setter TargetName="EditorialButtonBottomRule" Property="UIElement.Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="EditorialButtonSurface" Property="UIElement.Opacity" Value="0.34" />
                  <Setter TargetName="EditorialButtonContent" Property="UIElement.Opacity" Value="0.46" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="MousePerformancePrimaryActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MousePerformanceEditorialActionButtonBaseStyle}">
        <Setter Property="MinWidth" Value="208" />
        <Setter Property="Foreground" Value="{DynamicResource VoltGreenBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
      </Style>
      <Style x:Key="MousePerformanceActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MousePerformanceEditorialActionButtonBaseStyle}">
        <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
      </Style>
      <Style x:Key="MousePerformancePlotActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MousePerformanceActionButtonStyle}">
        <Style.Triggers>
          <DataTrigger Value="True" Binding="{Binding IsPlotHighlighted}">
            <Setter Property="Foreground" Value="{DynamicResource VoltGreenBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
          </DataTrigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="MousePerformanceCenteredComboBoxStyle" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource AvantGardeComboBoxStyle}">
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type ComboBox}">
              <Grid>
                <Border Name="ComboBorder" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" Opacity="0.92" />
                <Border Name="ActiveLine" Height="1" Margin="18,0,18,0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Background="{DynamicResource VoltGreenBrush}" Opacity="0.92" RenderTransformOrigin="0,0.5">
                  <UIElement.RenderTransform>
                    <ScaleTransform ScaleX="0" />
                  </UIElement.RenderTransform>
                </Border>
                <ContentPresenter Name="ContentSite" Margin="40,12,40,12" HorizontalAlignment="Center" VerticalAlignment="Center" Content="{TemplateBinding ComboBox.SelectionBoxItem}" ContentTemplate="{TemplateBinding ComboBox.SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding ComboBox.SelectionBoxItemStringFormat}" SnapsToDevicePixels="True" IsHitTestVisible="False" />
                <Border Width="24" HorizontalAlignment="Right" Background="#00FFFFFF">
                  <Path Name="Arrow" Width="8" Height="4" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L8,0 L4,4" Fill="{DynamicResource TextMutedBrush}" Opacity="0.72" RenderTransformOrigin="0.5,0.5">
                    <UIElement.RenderTransform>
                      <RotateTransform Angle="0" />
                    </UIElement.RenderTransform>
                  </Path>
                </Border>
                <ToggleButton Background="#00FFFFFF" BorderThickness="0" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                  <Control.Template>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                      <Border Background="#00FFFFFF" />
                    </ControlTemplate>
                  </Control.Template>
                </ToggleButton>
                <Popup Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{TemplateBinding ComboBox.IsDropDownOpen}" Placement="Bottom" PopupAnimation="Fade">
                  <Border Margin="0,4,0,0" MaxHeight="300" Background="{DynamicResource GlassPopupBackgroundBrush}" BorderBrush="{DynamicResource GlassPopupBorderBrush}" BorderThickness="1" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                    <ScrollViewer CanContentScroll="True">
                      <StackPanel IsItemsHost="True" />
                    </ScrollViewer>
                  </Border>
                </Popup>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="ComboBorder" Value="{DynamicResource TextStrongBrush}" Property="Border.BorderBrush" />
                  <Setter TargetName="Arrow" Value="{DynamicResource TextStrongBrush}" Property="Shape.Fill" />
                  <Setter TargetName="ComboBorder" Property="UIElement.Opacity" Value="1" />
                  <Setter TargetName="Arrow" Property="UIElement.Opacity" Value="1" />
                  <Setter TargetName="ActiveLine" Property="UIElement.Opacity" Value="0.42" />
                </Trigger>
                <Trigger Property="ComboBox.IsDropDownOpen" Value="True">
                  <Setter TargetName="ComboBorder" Value="{DynamicResource VoltGreenBrush}" Property="Border.BorderBrush" />
                  <Setter TargetName="Arrow" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
                  <Setter TargetName="ComboBorder" Property="UIElement.Opacity" Value="1" />
                  <Setter TargetName="Arrow" Property="UIElement.Opacity" Value="1" />
                  <TriggerBase.EnterActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="180" Duration="{StaticResource MotionMediumDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                        <DoubleAnimation Storyboard.TargetName="ActiveLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="{StaticResource MotionMediumDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.EnterActions>
                  <TriggerBase.ExitActions>
                    <BeginStoryboard>
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                        <DoubleAnimation Storyboard.TargetName="ActiveLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.ExitActions>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="ComboBorder" Property="UIElement.Opacity" Value="0.45" />
                  <Setter TargetName="Arrow" Property="UIElement.Opacity" Value="0.45" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Border Name="CaptureSurface" Background="{DynamicResource WindowBackgroundBrush}" Focusable="True" FocusVisualStyle="{x:Null}" Padding="{StaticResource Layout.CaptureSurface.Padding}">
    <Grid Margin="0,18,18,24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border Name="CaptureLockZone" Grid.Column="2" Margin="16,32,16,32" Background="#00FFFFFF" Focusable="True" FocusVisualStyle="{x:Null}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      </Border>
      <StackPanel Grid.Column="1" MaxWidth="980" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12,0,0">
        <StackPanel Width="980" HorizontalAlignment="Center">
          <TextBlock Style="{StaticResource StatusPillTextStyle}" HorizontalAlignment="Center" Text="{Binding StatusPillText}" />
          <Grid Height="48" Margin="0,12,0,0">
            <TextBlock Style="{StaticResource MousePerformanceStatusMessageBlockStyle}" Text="{Binding StatusMessage}" />
          </Grid>
          <TextBlock Margin="0,8,0,0" Style="{StaticResource MousePerformanceQualityVisibleTextStyle}" Text="{Binding QualityText}" />
        </StackPanel>
        <Border Width="72" Height="1" Margin="0,24,0,28" Background="{DynamicResource HairlineBrush}" HorizontalAlignment="Center" IsHitTestVisible="False" />
        <Grid Width="840" HorizontalAlignment="Center">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="48" />
            <ColumnDefinition Width="168" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Bottom" Text="{DynamicResource MousePerformance.Device.Title}" Style="{StaticResource MousePerformanceFieldLabelStyle}" />
          <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,1" Text="{DynamicResource MousePerformance.Cpi.Title}" Style="{StaticResource MousePerformanceFieldLabelStyle}" HorizontalAlignment="Center" TextAlignment="Center" />
          <ComboBox Grid.Row="2" Grid.Column="0" Style="{StaticResource MousePerformanceCenteredComboBoxStyle}" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" IsEnabled="{Binding IsDeviceSelectionEnabled}" controls:ManualComboBoxSelection.CommitCommand="{Binding CommitManualDeviceSelectionCommand}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Style="{StaticResource DeviceComboItemTextStyle}" HorizontalAlignment="Center" TextAlignment="Center" Text="{Binding DisplayLabel}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ComboBox>
          <TextBox Name="CpiTextBox" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center" Style="{StaticResource MousePerformanceEditorialInputTextBoxStyle}" IsEnabled="{Binding IsCpiInputEnabled}" Text="{Binding CpiText, UpdateSourceTrigger=PropertyChanged}" LostFocus="CpiTextBox_LostFocus" PreviewKeyDown="CpiTextBox_PreviewKeyDown" />
        </Grid>
        <Grid Width="980" Margin="0,28,0,0" HorizontalAlignment="Center" IsEnabled="{Binding AreActionButtonsEnabled}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" Content="{DynamicResource MousePerformance.Action.Import}" Style="{StaticResource MousePerformanceActionButtonStyle}" Click="ImportButton_Click" />
          <Button Grid.Column="2" Content="{DynamicResource MousePerformance.Action.DeleteImportedData}" Style="{StaticResource MousePerformanceActionButtonStyle}" IsEnabled="{Binding CanDeleteImportedSessions}" Click="DeleteImportedDataButton_Click" />
          <Button Grid.Column="4" Content="{Binding CollectActionText}" Style="{StaticResource MousePerformancePrimaryActionButtonStyle}" Command="{Binding CollectCommand}" />
          <Button Grid.Column="6" Content="{DynamicResource MousePerformance.Action.Reset}" Style="{StaticResource MousePerformanceActionButtonStyle}" Command="{Binding ResetCommand}" />
          <Button Grid.Column="8" Content="{DynamicResource MousePerformance.Action.Plot}" Style="{StaticResource MousePerformancePlotActionButtonStyle}" Command="{Binding PlotCommand}" />
        </Grid>
        <StackPanel Margin="0,36,0,0" Width="840" HorizontalAlignment="Center">
          <TextBlock Text="{DynamicResource MousePerformance.Summary.Title}" Style="{StaticResource MousePerformanceSectionTitleStyle}" />
          <Border Width="72" Height="1" Margin="0,12,0,18" Background="{DynamicResource HairlineBrush}" HorizontalAlignment="Center" IsHitTestVisible="False" />
          <Grid MinHeight="116">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="1" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="1" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="1" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="1" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource MousePerformance.Summary.EventCount}" Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
              <TextBlock Margin="0,16,0,0" Style="{StaticResource MousePerformanceValueTextStyle}" Text="{Binding EventCountText}" />
            </StackPanel>
            <Border Grid.Column="1" Margin="0,10" Background="{DynamicResource HairlineBrush}" IsHitTestVisible="False" />
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource MousePerformance.Summary.SumX}" Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
              <TextBlock Margin="0,16,0,0" Style="{StaticResource MousePerformanceValueTextStyle}" Text="{Binding SumXCountText}" />
              <TextBlock Margin="0,8,0,0" Style="{StaticResource MousePerformanceSummaryUnitStyle}" Text="{Binding SumXCmText}" />
            </StackPanel>
            <Border Grid.Column="3" Margin="0,10" Background="{DynamicResource HairlineBrush}" IsHitTestVisible="False" />
            <StackPanel Grid.Column="4" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource MousePerformance.Summary.SumY}" Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
              <TextBlock Margin="0,16,0,0" Style="{StaticResource MousePerformanceValueTextStyle}" Text="{Binding SumYCountText}" />
              <TextBlock Margin="0,8,0,0" Style="{StaticResource MousePerformanceSummaryUnitStyle}" Text="{Binding SumYCmText}" />
            </StackPanel>
            <Border Grid.Column="5" Margin="0,10" Background="{DynamicResource HairlineBrush}" IsHitTestVisible="False" />
            <StackPanel Grid.Column="6" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource MousePerformance.Summary.Path}" Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
              <TextBlock Margin="0,16,0,0" Style="{StaticResource MousePerformanceValueTextStyle}" Text="{Binding PathCountText}" />
              <TextBlock Margin="0,8,0,0" Style="{StaticResource MousePerformanceSummaryUnitStyle}" Text="{Binding PathCmText}" />
            </StackPanel>
            <Border Grid.Column="7" Margin="0,10" Background="{DynamicResource HairlineBrush}" IsHitTestVisible="False" />
            <StackPanel Grid.Column="8" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource MousePerformance.Summary.Speed}" Style="{StaticResource MousePerformanceSummaryLabelStyle}" />
              <TextBlock Margin="0,16,0,0" Style="{StaticResource MousePerformanceValueTextStyle}" Text="{Binding SpeedText}" />
              <TextBlock Margin="0,8,0,0" Text="{DynamicResource MousePerformance.Summary.SpeedUnit}" Style="{StaticResource MousePerformanceSummaryUnitStyle}" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
