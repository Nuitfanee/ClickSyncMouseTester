<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="ClickSyncMouseTester.Views.Pages.PollingWorkspacePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="clr-namespace:ClickSyncMouseTester.Controls" SnapsToDevicePixels="True" UseLayoutRounding="True" xmlns:pages="clr-namespace:ClickSyncMouseTester.Views.Pages" Loaded="PollingWorkspacePage_Loaded" Unloaded="PollingWorkspacePage_Unloaded">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="{StaticResource Layout.Main.GapColumnWidth}" />
      <ColumnDefinition Width="{StaticResource Layout.Main.RailColumnWidth}" />
    </Grid.ColumnDefinitions>
    <Border Name="CaptureSurface" Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}" Focusable="True" Padding="{StaticResource Layout.CaptureSurface.Padding}" RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
            <TextBlock Margin="0,0,12,0" Style="{StaticResource StatusPillTextStyle}" VerticalAlignment="Center" Text="{Binding StatusPillText, NotifyOnTargetUpdated=True}">
              <UIElement.RenderTransform>
                <TranslateTransform Y="0" />
              </UIElement.RenderTransform>
              <FrameworkElement.Triggers>
                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.45" To="1" Duration="0:0:0.14" EasingFunction="{StaticResource MotionInOutEase}" />
                      <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="1" To="0" Duration="0:0:0.14" EasingFunction="{StaticResource MotionOutEase}" />
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </FrameworkElement.Triggers>
            </TextBlock>
            <Ellipse Style="{StaticResource StatusLampStyle}" VerticalAlignment="Center" />
          </StackPanel>
        </Grid>
        <Grid Row="1" VerticalAlignment="Top" Margin="{StaticResource Layout.Hero.Margin}" MinHeight="{StaticResource Layout.Hero.MinHeight}">
          <TextBlock Text="{DynamicResource Capture.Head.Measuring}" Style="{StaticResource HeroWatermarkTextStyle}" FontSize="{StaticResource Layout.Hero.WatermarkFontSize}" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,30,0,0" IsHitTestVisible="False" />
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{DynamicResource Capture.Head.Rate}" Style="{StaticResource InvariantMicroLabelStyle}" Foreground="{DynamicResource VoltGreenBrush}" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
              <TextBlock Style="{StaticResource HeroValueTextStyle}" Margin="0,0,0,-24" RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}" Text="{Binding CurrentRateText}">
                <TextBlock.FontSize>
                  <MultiBinding Converter="{StaticResource ResponsiveFontSizeConverter}" ConverterParameter="214|214|380|1240|940">
                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Window}" />
                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Window}" />
                  </MultiBinding>
                </TextBlock.FontSize>
              </TextBlock>
              <TextBlock Text="{DynamicResource Unit.Hertz}" Style="{StaticResource HeroUnitTextStyle}" FontSize="{StaticResource Layout.Hero.UnitFontSize}" VerticalAlignment="Bottom" Margin="14,0,0,26" />
            </StackPanel>
          </StackPanel>
        </Grid>
        <Border Grid.Row="2" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="{StaticResource Thickness.Hairline.Top}" Padding="{StaticResource Layout.Metrics.Padding}" RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
          <ItemsControl ItemsSource="{Binding MetricCards}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="{Binding DataContext.MetricColumnCount, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding TitleText}" Style="{StaticResource MicroLabelStyle}" />
                  <TextBlock Margin="0,12,0,0" Style="{StaticResource MetricValueStyle}" Text="{Binding ValueText}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>
        <Grid Row="3" Height="{StaticResource Layout.History.Height}" Margin="0,0,0,6">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource History.Label}" Style="{StaticResource MicroLabelStyle}" VerticalAlignment="Center" />
            <Border Width="{StaticResource Layout.History.HeaderRuleWidth}" Height="1" Background="{DynamicResource HairlineBrush}" Margin="12,0,12,0" VerticalAlignment="Center" />
            <TextBlock Text="{DynamicResource History.Trace}" Style="{StaticResource InvariantHistoryTraceTextStyle}" VerticalAlignment="Center" />
          </StackPanel>
          <controls:PollingHistoryChartControl Grid.Row="1" HistoryPoints="{Binding HistoryPoints}" PeakRate="{Binding PeakRate}" CurrentRate="{Binding RawCurrentRate}" IsLocked="{Binding IsLocked}">
            <FrameworkElement.Style>
              <Style TargetType="{x:Type controls:PollingHistoryChartControl}">
                <Setter Property="UIElement.Opacity" Value="1" />
                <Style.Triggers>
                  <DataTrigger Value="0" Binding="{Binding HistoryPoints.Count}">
                    <TriggerBase.EnterActions>
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.32" Duration="0:0:0.2" EasingFunction="{StaticResource MotionInOutEase}" />
                        </Storyboard>
                      </BeginStoryboard>
                    </TriggerBase.EnterActions>
                    <TriggerBase.ExitActions>
                      <BeginStoryboard>
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18" EasingFunction="{StaticResource MotionOutEase}" />
                        </Storyboard>
                      </BeginStoryboard>
                    </TriggerBase.ExitActions>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </FrameworkElement.Style>
          </controls:PollingHistoryChartControl>
        </Grid>
      </Grid>
    </Border>
    <Border Grid.Column="2" Margin="{StaticResource Layout.ControlRail.Margin}" Padding="{StaticResource Layout.ControlRail.Padding}" Background="{DynamicResource GlassShellBackgroundBrush}" BorderBrush="{DynamicResource GlassShellBorderBrush}" BorderThickness="1,0,0,0" RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,6">
          <TextBlock Text="{DynamicResource Control.Rail.Label}" Style="{StaticResource MicroLabelStyle}" Foreground="{DynamicResource VoltGreenBrush}" Margin="0,0,0,42" />
          <TextBlock Text="{DynamicResource Control.TargetDevice.Label}" Style="{StaticResource MicroLabelStyle}" Margin="0,0,0,14" />
          <ComboBox Style="{StaticResource AvantGardeComboBoxStyle}" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" IsEnabled="{Binding IsDeviceSelectionEnabled}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Style="{StaticResource DeviceComboItemTextStyle}" Text="{Binding DisplayLabel}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="0,38,0,0">
          <TextBlock Text="{DynamicResource Control.ReportMode.Label}" Style="{StaticResource MicroLabelStyle}" Margin="0,0,0,14" />
          <ToggleButton Style="{StaticResource PollingRateModeToggleStyle}" IsChecked="{Binding IsRawPacketRateMode, Mode=TwoWay}" IsEnabled="{Binding IsRateModeSwitchEnabled}" />
          <TextBlock Margin="0,16,2,0" MinHeight="{StaticResource Layout.ControlRail.ModeDescriptionMinHeight}" VerticalAlignment="Top" TextWrapping="Wrap" Style="{StaticResource HintTextStyle}" Text="{Binding RateModeDescriptionText}" />
        </StackPanel>
        <Grid Row="2" Margin="0,42,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Button Grid.Row="0" Margin="10,0" Style="{StaticResource VoltButtonStyle}" Command="{Binding StartCommand}" Content="{Binding StartButtonText}" />
          <Grid Row="2" Margin="10,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="18" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{DynamicResource Button.RefreshDevices}" Style="{StaticResource MinimalGhostButtonStyle}" Command="{Binding RefreshDevicesCommand}" />
            <Button Grid.Column="2" Content="{DynamicResource Button.Stop}" Style="{StaticResource MinimalGhostButtonStyle}" Command="{Binding StopCommand}" />
          </Grid>
        </Grid>
        <Border Grid.Row="3" Height="1" Background="{DynamicResource HairlineBrush}" Margin="0,44,0,34" />
        <Grid Grid.Row="4" Margin="0,10,2,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="{StaticResource Layout.SessionStatusMessage.Height}" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Text="{DynamicResource Session.NotesLabel}" Style="{StaticResource MicroLabelStyle}" />
          <TextBlock Grid.Row="1" Margin="0,18,0,0" TextWrapping="Wrap" Style="{StaticResource StatusMessageTextStyle}" Text="{Binding StatusMessage, NotifyOnTargetUpdated=True}">
            <FrameworkElement.Triggers>
              <EventTrigger RoutedEvent="Binding.TargetUpdated">
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.5" To="1" Duration="0:0:0.16" EasingFunction="{StaticResource MotionInOutEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </FrameworkElement.Triggers>
          </TextBlock>
          <Border Grid.Row="2" Margin="0,0,0,0" Padding="12,10,12,10" Background="{DynamicResource GhostHoverBrush}" BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="1" Opacity="0.96">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Background="{DynamicResource VoltGreenBrush}" Opacity="0.92" />
              <TextBlock Grid.Column="2" TextWrapping="Wrap" Style="{StaticResource SessionHintCalloutTextStyle}" Text="{Binding HintText}" />
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
