      </Style>
      <Style x:Key="KeyDetectionMetricFooterLabelTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource KeyDetectionEyebrowTextStyle}">
        <Setter Property="TextWrapping" Value="NoWrap" />
      </Style>
      <Style x:Key="KeyDetectionMetricFooterValueTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource KeyDetectionSubMetricValueTextStyle}">
        <Setter Property="TextWrapping" Value="NoWrap" />
      </Style>
      <Style x:Key="KeyDetectionCompactScrollValueTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource KeyDetectionScrollValueTextStyle}">
        <Setter Property="FontSize" Value="28" />
      </Style>
      <DataTemplate x:Key="KeyDetectionButtonCardTemplate">
        <Grid Margin="0,0,8,8">
          <Border Name="ButtonCardShadow" CornerRadius="22" Background="{DynamicResource TextStrongBrush}" Opacity="0.18" IsHitTestVisible="False">
            <UIElement.RenderTransform>
              <TranslateTransform X="7" Y="7" />
            </UIElement.RenderTransform>
          </Border>
          <Border Name="ButtonCardBorder" RenderTransformOrigin="0.5,0.5" Style="{StaticResource KeyDetectionRoundedButtonCardBorderStyle}">
            <UIElement.RenderTransform>
              <TranslateTransform X="0" Y="0" />
            </UIElement.RenderTransform>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock HorizontalAlignment="Center" Style="{StaticResource KeyDetectionCardCenteredTitleTextStyle}" Text="{Binding Title}" />
              <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" Style="{StaticResource KeyDetectionCardHeroValueTextStyle}" Text="{Binding DoubleClickCountText}" />
                <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" Text="{DynamicResource KeyDetection.Metric.DoubleClicks}" Style="{StaticResource KeyDetectionDoubleClickSummaryLabelTextStyle}" />
              </StackPanel>
              <Border Grid.Row="4" Style="{StaticResource KeyDetectionCardSectionDividerStyle}" />
              <Grid Row="6">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="10" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{DynamicResource KeyDetection.Metric.DownCount}" Style="{StaticResource KeyDetectionCardRowLabelTextStyle}" />
                  <TextBlock Grid.Column="1" HorizontalAlignment="Right" Style="{StaticResource KeyDetectionCardRowValueTextStyle}" Text="{Binding DownCountText}" />
                </Grid>
                <Grid Row="2">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{DynamicResource KeyDetection.Metric.UpCount}" Style="{StaticResource KeyDetectionCardRowLabelTextStyle}" />
                  <TextBlock Grid.Column="1" HorizontalAlignment="Right" Style="{StaticResource KeyDetectionCardRowValueTextStyle}" Text="{Binding UpCountText}" />
                </Grid>
              </Grid>
              <Border Grid.Row="8" Style="{StaticResource KeyDetectionCardSectionDividerStyle}" />
              <Grid Row="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="16" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource KeyDetection.Metric.DownToDown}" Style="{StaticResource KeyDetectionCardRowLabelTextStyle}" />
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Style="{StaticResource KeyDetectionCardTimingValueTextStyle}" Text="{Binding CurrentDownDownText}" />
                  </Grid>
                  <StackPanel Margin="0,8,0,0" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.Min}" Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
                      <TextBlock Margin="4,0,0,0" Style="{StaticResource KeyDetectionSubMetricValueTextStyle}" Text="{Binding MinimumDownDownText}" />
                    </StackPanel>
                    <StackPanel Margin="0,3,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.Avg}" Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
                      <TextBlock Margin="4,0,0,0" Style="{StaticResource KeyDetectionSubMetricValueTextStyle}" Text="{Binding AverageDownDownText}" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="2">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource KeyDetection.Metric.DownToUp}" Style="{StaticResource KeyDetectionCardRowLabelTextStyle}" />
                    <TextBlock Grid.Column="1" HorizontalAlignment="Right" Style="{StaticResource KeyDetectionCardTimingValueTextStyle}" Text="{Binding CurrentDownUpText}" />
                  </Grid>
                  <StackPanel Margin="0,8,0,0" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.Min}" Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
                      <TextBlock Margin="4,0,0,0" Style="{StaticResource KeyDetectionSubMetricValueTextStyle}" Text="{Binding MinimumDownUpText}" />
                    </StackPanel>
                    <StackPanel Margin="0,3,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.Avg}" Style="{StaticResource KeyDetectionEyebrowTextStyle}" />
                      <TextBlock Margin="4,0,0,0" Style="{StaticResource KeyDetectionSubMetricValueTextStyle}" Text="{Binding AverageDownUpText}" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Grid>
          </Border>
        </Grid>
        <DataTemplate.Triggers>
          <DataTrigger Value="True" Binding="{Binding IsPressed}">
            <TriggerBase.EnterActions>
              <BeginStoryboard>
                <Storyboard FillBehavior="HoldEnd">
                  <DoubleAnimation Storyboard.TargetName="ButtonCardBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="7" Duration="0:0:0.08" EasingFunction="{StaticResource MotionOutEase}" />
                  <DoubleAnimation Storyboard.TargetName="ButtonCardBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="7" Duration="0:0:0.08" EasingFunction="{StaticResource MotionOutEase}" />
                </Storyboard>
              </BeginStoryboard>
            </TriggerBase.EnterActions>
            <TriggerBase.ExitActions>
              <BeginStoryboard>
                <Storyboard FillBehavior="HoldEnd">
                  <DoubleAnimation Storyboard.TargetName="ButtonCardBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.12" EasingFunction="{StaticResource MotionOutEase}" />
                  <DoubleAnimation Storyboard.TargetName="ButtonCardBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.12" EasingFunction="{StaticResource MotionOutEase}" />
                </Storyboard>
              </BeginStoryboard>
            </TriggerBase.ExitActions>
          </DataTrigger>
        </DataTemplate.Triggers>
      </DataTemplate>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Name="RootScrollViewer" Background="{DynamicResource WindowBackgroundBrush}" Focusable="True" PreviewMouseDown="RootScrollViewer_PreviewMouseDown" PreviewMouseWheel="RootScrollViewer_PreviewMouseWheel">
    <Grid Margin="{StaticResource Layout.KeyDetection.PageMargin}" RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="12" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="12" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="14" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="14" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="14" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="14" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ContentControl HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" Content="{Binding ButtonCards[0]}" />
        <ContentControl Grid.Column="2" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" Content="{Binding ButtonCards[1]}" />
        <ContentControl Grid.Column="4" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" Content="{Binding ButtonCards[2]}" />
        <ContentControl Grid.Column="6" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" Content="{Binding ButtonCards[3]}" />
        <ContentControl Grid.Column="8" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" ContentTemplate="{StaticResource KeyDetectionButtonCardTemplate}" Content="{Binding ButtonCards[4]}" />
      </Grid>
      <Border Grid.Row="2" Style="{StaticResource KeyDetectionThresholdBarBorderStyle}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="18" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="{DynamicResource KeyDetection.MouseThreshold.Title}" Style="{StaticResource KeyDetectionCompactPanelTitleTextStyle}" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="13" Text="{DynamicResource KeyDetection.MouseThreshold.Description}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Style="{StaticResource HintTextStyle}" />
          </Grid>
          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="{DynamicResource KeyDetection.MouseThreshold.InputLabel}" Style="{StaticResource MicroLabelStyle}" />
            <TextBox Name="MouseThresholdTextBox" Width="78" Style="{StaticResource KeyDetectionRaisedThresholdTextBoxStyle}" Text="{Binding MouseDoubleClickThresholdText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" PreviewKeyDown="ThresholdTextBox_PreviewKeyDown" LostFocus="ThresholdTextBox_LostFocus" GotKeyboardFocus="ThresholdTextBox_GotKeyboardFocus" LostKeyboardFocus="ThresholdTextBox_LostKeyboardFocus" />
            <Button Margin="12,0,0,0" MinWidth="108" Content="{DynamicResource KeyDetection.Action.ResetStatistics}" Style="{StaticResource KeyDetectionPillGhostButtonStyle}" Command="{Binding ResetStatisticsCommand}" />
          </StackPanel>
        </Grid>
      </Border>
      <Grid Row="4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="160" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Padding="10" Style="{StaticResource KeyDetectionRoundedPanelBorderStyle}">
          <Border Style="{StaticResource KeyDetectionWheelRailBorderStyle}">
            <Grid Margin="0,2">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Border Style="{StaticResource KeyDetectionWheelPulseZoneStyle}" Tag="{Binding IsScrollUpPulseActive}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Viewbox Width="18" Height="10" Margin="0,0,0,12" HorizontalAlignment="Center" Stretch="Fill">
                    <Path Data="M13,0 L26,16 L0,16" Fill="{DynamicResource TextStrongBrush}" Stretch="Fill" />
                  </Viewbox>
                  <TextBlock HorizontalAlignment="Center" Style="{StaticResource KeyDetectionCompactScrollValueTextStyle}" Text="{Binding ScrollUpCountText}" />
                  <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" Text="{DynamicResource KeyDetection.Scroll.Up}" TextAlignment="Center" Style="{StaticResource MicroLabelStyle}" />
                </StackPanel>
              </Border>
              <Border Grid.Row="1" Width="40" Height="1" HorizontalAlignment="Center" Background="{DynamicResource HairlineBrush}" Opacity="0.52" />
              <Border Grid.Row="2" Style="{StaticResource KeyDetectionWheelPulseZoneStyle}" Tag="{Binding IsScrollDownPulseActive}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Viewbox Width="18" Height="10" Margin="0,0,0,12" HorizontalAlignment="Center" Stretch="Fill">
                    <Path Data="M0,0 L26,0 L13,16" Fill="{DynamicResource TextStrongBrush}" Stretch="Fill" />
                  </Viewbox>
                  <TextBlock HorizontalAlignment="Center" Style="{StaticResource KeyDetectionCompactScrollValueTextStyle}" Text="{Binding ScrollDownCountText}" />
                  <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" Text="{DynamicResource KeyDetection.Scroll.Down}" TextAlignment="Center" Style="{StaticResource MicroLabelStyle}" />
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </Border>
        <Border Grid.Column="2" Padding="18,16" Style="{StaticResource KeyDetectionRoundedPanelBorderStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="12" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="12" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="{DynamicResource KeyDetection.CustomKey.Title}" Style="{StaticResource KeyDetectionCompactPanelTitleTextStyle}" />
                <TextBlock Margin="0,4,0,0" MaxWidth="720" Text="{DynamicResource KeyDetection.CustomKey.Description}" TextWrapping="Wrap" Style="{StaticResource HintTextStyle}" />
              </StackPanel>
              <Button Grid.Column="2" MinWidth="78" Style="{StaticResource KeyDetectionPillGhostButtonStyle}" Command="{Binding ToggleKeyPickModeCommand}" Content="{Binding CustomKeyPickButtonText}" />
              <Button Grid.Column="4" MinWidth="78" Content="{DynamicResource KeyDetection.CustomKey.Button.Reset}" Style="{StaticResource KeyDetectionPillGhostButtonStyle}" Command="{Binding ResetCustomKeyCommand}" />
            </Grid>
            <Grid Row="2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.28*" />
              </Grid.ColumnDefinitions>
              <Border Grid.Column="0" Style="{StaticResource KeyDetectionPillBorderStyle}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border Style="{StaticResource KeyDetectionInfoTagBorderStyle}">
                    <TextBlock Text="{DynamicResource KeyDetection.CustomKey.Selection.Label}" Style="{StaticResource KeyDetectionInfoTagTextStyle}" />
                  </Border>
                  <TextBlock Grid.Column="2" Style="{StaticResource KeyDetectionInfoValueTextStyle}" Text="{Binding CustomKeySelectionValueText}" />
                </Grid>
              </Border>
              <Border Grid.Column="2" Style="{StaticResource KeyDetectionStatusPillBorderStyle}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border Style="{StaticResource KeyDetectionInfoTagBorderStyle}">
                    <TextBlock Text="{DynamicResource KeyDetection.CustomKey.Status.Label}" Style="{StaticResource KeyDetectionInfoTagTextStyle}" />
                  </Border>
                  <TextBlock Grid.Column="2" Style="{StaticResource KeyDetectionInfoValueTextStyle}" Text="{Binding CustomKeyStatusValueText}" />
                </Grid>
              </Border>
            </Grid>
            <Grid Row="4">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="14" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="14" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource KeyDetectionMetricTileBorderStyle}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.DownCount}" Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />
                      <TextBlock Grid.Column="2" Style="{StaticResource KeyDetectionMetricInlineValueTextStyle}" Text="{Binding CustomKeyDownCountText}" />
                    </Grid>
                  </Grid>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource KeyDetectionMetricTileBorderStyle}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.UpCount}" Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />
                      <TextBlock Grid.Column="2" Style="{StaticResource KeyDetectionMetricInlineValueTextStyle}" Text="{Binding CustomKeyUpCountText}" />
                    </Grid>
                  </Grid>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource KeyDetectionMetricTileBorderStyle}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.DoubleClicks}" Style="{StaticResource KeyDetectionDoubleClickMetricHeaderTextStyle}" />
                      <TextBlock Grid.Column="2" Style="{StaticResource KeyDetectionMetricInlineValueTextStyle}" Text="{Binding CustomKeyDoubleClickCountText}" />
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
              <Grid Row="2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="14" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="14" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource KeyDetectionTimingSurfaceBorderStyle}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{DynamicResource KeyDetection.CustomKey.ThresholdTitle}" Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />
                      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBox Name="CustomKeyThresholdTextBox" Width="94" Style="{StaticResource KeyDetectionRaisedThresholdTextBoxStyle}" Text="{Binding KeyDoubleClickThresholdText, Mode=TwoWay, UpdateSourceTrigger=Explicit}" PreviewKeyDown="ThresholdTextBox_PreviewKeyDown" LostFocus="ThresholdTextBox_LostFocus" GotKeyboardFocus="ThresholdTextBox_GotKeyboardFocus" LostKeyboardFocus="ThresholdTextBox_LostKeyboardFocus" />
                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="{DynamicResource KeyDetection.CustomKey.ThresholdInputLabel}" Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                      </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="2" Margin="0,6,0,0" Text="{DynamicResource KeyDetection.CustomKey.ThresholdHint}" Style="{StaticResource KeyDetectionMetricNoteTextStyle}" />
                  </Grid>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource KeyDetectionTimingSurfaceBorderStyle}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.DownToDown}" Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />
                      <TextBlock Grid.Column="2" Style="{StaticResource KeyDetectionMetricInlineTimingValueTextStyle}" Text="{Binding CustomKeyCurrentDownDownText}" />
                    </Grid>
                    <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.Min}" Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                      <TextBlock Margin="4,0,0,0" Style="{StaticResource KeyDetectionMetricFooterValueTextStyle}" Text="{Binding CustomKeyMinimumDownDownText}" />
                      <TextBlock Margin="14,0,0,0" Text="{DynamicResource KeyDetection.Metric.Avg}" Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                      <TextBlock Margin="4,0,0,0" Style="{StaticResource KeyDetectionMetricFooterValueTextStyle}" Text="{Binding CustomKeyAverageDownDownText}" />
                    </StackPanel>
                  </Grid>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource KeyDetectionTimingSurfaceBorderStyle}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.DownToUp}" Style="{StaticResource KeyDetectionMetricHeaderTextStyle}" />
                      <TextBlock Grid.Column="2" Style="{StaticResource KeyDetectionMetricInlineTimingValueTextStyle}" Text="{Binding CustomKeyCurrentDownUpText}" />
                    </Grid>
                    <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                      <TextBlock Text="{DynamicResource KeyDetection.Metric.Min}" Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                      <TextBlock Margin="4,0,0,0" Style="{StaticResource KeyDetectionMetricFooterValueTextStyle}" Text="{Binding CustomKeyMinimumDownUpText}" />
                      <TextBlock Margin="14,0,0,0" Text="{DynamicResource KeyDetection.Metric.Avg}" Style="{StaticResource KeyDetectionMetricFooterLabelTextStyle}" />
                      <TextBlock Margin="4,0,0,0" Style="{StaticResource KeyDetectionMetricFooterValueTextStyle}" Text="{Binding CustomKeyAverageDownUpText}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
