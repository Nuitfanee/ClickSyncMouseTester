                <Border Name="ShadowPlate" Margin="5,5,0,0" Background="#ECECEC" CornerRadius="8" IsHitTestVisible="False" Opacity="1" />
                <Border Name="InputSurface" Margin="0,0,5,5" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="8" SnapsToDevicePixels="True" UseLayoutRounding="True">
                  <ScrollViewer Name="PART_ContentHost" Margin="{TemplateBinding Control.Padding}" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}" />
                </Border>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsKeyboardFocusWithin" Value="True">
                  <Setter TargetName="InputSurface" Property="Border.BorderBrush" Value="#D4D4D4" />
                  <TriggerBase.EnterActions>
                    <BeginStoryboard>
                      <Storyboard FillBehavior="HoldEnd">
                        <DoubleAnimation Storyboard.TargetName="ShadowPlate" From="1" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12" EasingFunction="{StaticResource MotionOutEase}" />
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.EnterActions>
                  <TriggerBase.ExitActions>
                    <BeginStoryboard>
                      <Storyboard FillBehavior="HoldEnd">
                        <DoubleAnimation Storyboard.TargetName="ShadowPlate" From="0" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16" EasingFunction="{StaticResource MotionOutEase}" />
                      </Storyboard>
                    </BeginStoryboard>
                  </TriggerBase.ExitActions>
                </Trigger>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="InputSurface" Property="Border.BorderBrush" Value="#DEDEDE" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="InputSurface" Property="UIElement.Opacity" Value="0.52" />
                  <Setter TargetName="ShadowPlate" Property="UIElement.Opacity" Value="0.36" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
