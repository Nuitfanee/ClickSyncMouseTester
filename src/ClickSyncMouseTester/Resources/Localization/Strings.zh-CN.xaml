  <String x:Key="AngleCalibration.PageTitle" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">鼠标传感器角度校准</String>
  <String x:Key="AngleCalibration.Instructions.Title" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">使用方法</String>
  <String x:Key="AngleCalibration.Instructions.Step1" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">1. 点击下方测量区域开始，并锁定光标。</String>
  <String x:Key="AngleCalibration.Instructions.Step2" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">2. 自然摆姿左右来回滑动不少于 30 次，尽量维持你认定的“水平”。</String>
  <String x:Key="AngleCalibration.Instructions.Step3" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">3. 右键暂停后可查看推荐角度；继续点击测量区域可在同一会话内继续测量。</String>
  <String x:Key="AngleCalibration.Instructions.Step4" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">4. 也可以在手动调整握姿或垫面后反复测量，直到推荐角度稳定在理想范围内。</String>
  <String x:Key="AngleCalibration.Button.Reset" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">重置</String>
  <String x:Key="AngleCalibration.Button.CopyAngle" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">复制角度</String>
  <String x:Key="AngleCalibration.Result.Title" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">推荐角度</String>
  <String x:Key="AngleCalibration.Measurement.Title" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">测量区域</String>
  <String x:Key="AngleCalibration.Measurement.Help" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">点击区域开始采样；右键或 Esc 暂停，继续测量会提升结果精度。</String>
  <String x:Key="AngleCalibration.Stats.Swipes" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">往返:</String>
  <String x:Key="AngleCalibration.Stats.Samples" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">样本:</String>
  <String x:Key="AngleCalibration.Stats.Stability" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">稳定:</String>
  <String x:Key="AngleCalibration.Hint.Ready" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">点击测量区域开始并锁定光标；锁定后移动任意鼠标开始测量。</String>
  <String x:Key="AngleCalibration.Hint.AwaitingInput" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">已锁定：等待任意鼠标产生第一条位移来开始测量。右键暂停。</String>
  <String x:Key="AngleCalibration.Hint.Measuring" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">测量中：移动当前测量鼠标左右来回滑动至少 30 次。右键暂停。</String>
  <String x:Key="AngleCalibration.Hint.Paused" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">已暂停：点击测量区域继续，随后移动任意鼠标恢复测量。</String>
  <String x:Key="AngleCalibration.Hint.ResultReady.Active" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">推荐角已可用：继续滑动当前测量鼠标可提高准确度；右键暂停。</String>
  <String x:Key="AngleCalibration.Hint.ResultReady.Paused" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">推荐角已可用：点击测量区域继续，随后移动任意鼠标恢复测量。</String>
  <String x:Key="AngleCalibration.Hint.NoDevice" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">未检测到可用鼠标，连接任意鼠标后再开始传感器角度校准。</String>
  <String x:Key="AngleCalibration.Hint.DeviceDisconnected" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">当前测量鼠标已断开；点击测量区域后移动任意鼠标可开始新一轮测量。</String>
  <String x:Key="AngleCalibration.Quality.InsufficientProgress" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">轨迹样本仍偏少：继续完成更多往返，结果会更稳。</String>
  <String x:Key="AngleCalibration.Quality.Imbalance" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">左右幅度还不够均衡：尽量让两侧摆动更对称。</String>
  <String x:Key="AngleCalibration.Quality.HighDispersion" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">轨迹离散较大：尽量保持轨迹更直、更稳定。</String>
  <String x:Key="AngleCalibration.Quality.Outliers" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">异常轨迹较多：减少抖动和急转折后再继续测量。</String>
  <String x:Key="AngleCalibration.Quality.QueueOverflow" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">采集队列曾溢出并丢弃 {0} 个包；当前结果可能被工具侧压力影响，建议重置后重测。</String>
  <String x:Key="AngleCalibration.Quality.Fair" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">轨迹质量一般：继续补充更多稳定往返，结果会更可靠。</String>
  <String x:Key="AngleCalibration.Quality.Good" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">轨迹质量良好：继续保持当前节奏即可。</String>
  <String x:Key="AngleCalibration.Quality.Excellent" xmlns="clr-namespace:System;assembly=System.Private.CoreLib">轨迹质量优秀：再测几次可以进一步确认结果。</String>
