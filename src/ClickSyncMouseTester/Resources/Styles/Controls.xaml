  <Style x:Key="AvantGardeComboPopupScrollBarStyle" TargetType="{x:Type ScrollBar}">
    <Setter Property="Width" Value="12" />
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ScrollBar}">
          <Grid Name="VerticalRoot" Width="{TemplateBinding FrameworkElement.Width}" Background="{TemplateBinding Control.Background}" SnapsToDevicePixels="True">
            <Border Name="TrackRail" Margin="4,8,4,8" CornerRadius="3" Background="{DynamicResource HairlineBrush}" Opacity="0.9" />
            <Track Name="PART_Track" Margin="4,8,4,8" IsDirectionReversed="True">
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource AvantGardeComboPopupScrollBarPageButtonStyle}" />
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb MinHeight="36" Style="{StaticResource AvantGardeComboPopupScrollBarThumbStyle}" />
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource AvantGardeComboPopupScrollBarPageButtonStyle}" />
              </Track.IncreaseRepeatButton>
            </Track>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="ScrollBar.Orientation" Value="Horizontal">
              <Setter TargetName="VerticalRoot" Property="Visibility" Value="Collapsed" />
            </Trigger>
            <Trigger SourceName="PART_Track" Property="IsEnabled" Value="False">
              <Setter TargetName="PART_Track" Property="Visibility" Value="Hidden" />
            </Trigger>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="TrackRail" Property="UIElement.Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="TrackRail" Property="UIElement.Opacity" Value="0.3" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="AvantGardeComboBoxStyle" TargetType="{x:Type ComboBox}">
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="Background" Value="{DynamicResource ControlPanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="FontFamily" Value="{DynamicResource Font.ListDisplay}" />
    <Setter Property="FontWeight" Value="{DynamicResource TextWeight.ComboBox}" />
    <Setter Property="FontSize" Value="{DynamicResource TypeScale.ComboBox}" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.Grayscale}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
    <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ComboBox}">
          <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border Name="ComboBorder" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" Opacity="0.92" SnapsToDevicePixels="True" />
            <Border Name="ActiveLine" Height="1" Margin="0,0,18,0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Background="{DynamicResource VoltGreenBrush}" Opacity="0.92" RenderTransformOrigin="0,0.5" SnapsToDevicePixels="True">
              <UIElement.RenderTransform>
                <ScaleTransform ScaleX="0" />
              </UIElement.RenderTransform>
            </Border>
            <ContentPresenter Name="ContentSite" Margin="8,12,32,12" VerticalAlignment="Center" Content="{TemplateBinding ComboBox.SelectionBoxItem}" ContentTemplate="{TemplateBinding ComboBox.SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding ComboBox.SelectionBoxItemStringFormat}" SnapsToDevicePixels="True" IsHitTestVisible="False" />
            <Border Width="24" HorizontalAlignment="Right" Background="#00FFFFFF">
              <Path Name="Arrow" Width="8" Height="4" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L8,0 L4,4" Fill="{DynamicResource TextMutedBrush}" Opacity="0.72" RenderTransformOrigin="0.5,0.5">
                <UIElement.RenderTransform>
                  <RotateTransform Angle="0" />
                </UIElement.RenderTransform>
              </Path>
            </Border>
            <ToggleButton Background="#00FFFFFF" BorderThickness="0" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
              <Control.Template>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                  <Border Background="#00FFFFFF" />
                </ControlTemplate>
              </Control.Template>
            </ToggleButton>
            <Popup Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{TemplateBinding ComboBox.IsDropDownOpen}" Placement="Bottom" PopupAnimation="Fade">
              <Grid Margin="0,4,0,0" SnapsToDevicePixels="True" UseLayoutRounding="True">
                <Border Margin="0,2,0,-2" Background="{DynamicResource GlassPopupShadowBrush}" IsHitTestVisible="False" />
                <Border MaxHeight="300" Background="{DynamicResource GlassPopupBackgroundBrush}" BorderBrush="{DynamicResource GlassPopupBorderBrush}" BorderThickness="1" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" SnapsToDevicePixels="True">
                  <ScrollViewer CanContentScroll="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <FrameworkElement.Resources>
                      <ResourceDictionary>
                        <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource AvantGardeComboPopupScrollBarStyle}" />
                      </ResourceDictionary>
                    </FrameworkElement.Resources>
                    <StackPanel IsItemsHost="True" />
                  </ScrollViewer>
                </Border>
              </Grid>
            </Popup>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="ComboBorder" Value="{DynamicResource TextStrongBrush}" Property="Border.BorderBrush" />
              <Setter TargetName="Arrow" Value="{DynamicResource TextStrongBrush}" Property="Shape.Fill" />
              <Setter TargetName="ComboBorder" Property="UIElement.Opacity" Value="1" />
              <Setter TargetName="Arrow" Property="UIElement.Opacity" Value="1" />
              <Setter TargetName="ActiveLine" Property="UIElement.Opacity" Value="0.42" />
            </Trigger>
            <Trigger Property="ComboBox.IsDropDownOpen" Value="True">
              <Setter TargetName="ComboBorder" Value="{DynamicResource VoltGreenBrush}" Property="Border.BorderBrush" />
              <Setter TargetName="Arrow" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
              <Setter TargetName="ComboBorder" Property="UIElement.Opacity" Value="1" />
              <Setter TargetName="Arrow" Property="UIElement.Opacity" Value="1" />
              <TriggerBase.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="180" Duration="{StaticResource MotionMediumDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="ActiveLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="{StaticResource MotionMediumDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.EnterActions>
              <TriggerBase.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="ActiveLine" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="ComboBorder" Property="UIElement.Opacity" Value="0.45" />
              <Setter TargetName="Arrow" Property="UIElement.Opacity" Value="0.45" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="{x:Type ComboBoxItem}" TargetType="{x:Type ComboBoxItem}">
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.Grayscale}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
    <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ComboBoxItem}">
          <Border Name="ItemBorder" Background="#00FFFFFF" SnapsToDevicePixels="True">
            <Grid ClipToBounds="True">
              <Border Name="ItemSurface" Background="#00FFFFFF" Opacity="0" />
              <Rectangle Name="ItemAccentBar" Width="2" HorizontalAlignment="Left" Fill="{DynamicResource ComboItemHoverAccentBrush}" Opacity="0" />
              <ContentPresenter Name="ItemContent" Margin="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True" VerticalAlignment="Center" RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="ListBoxItem.IsSelected" Value="True">
              <Setter TargetName="ItemSurface" Value="{DynamicResource ComboItemSelectedBrush}" Property="Border.Background" />
              <Setter TargetName="ItemSurface" Property="UIElement.Opacity" Value="1" />
              <Setter TargetName="ItemAccentBar" Value="{DynamicResource ComboItemSelectedForegroundBrush}" Property="Shape.Fill" />
              <Setter TargetName="ItemAccentBar" Property="UIElement.Opacity" Value="0.72" />
              <Setter Value="{DynamicResource ComboItemSelectedForegroundBrush}" Property="Foreground" />
            </Trigger>
            <Trigger Property="ComboBoxItem.IsHighlighted" Value="True">
              <Setter TargetName="ItemSurface" Value="{DynamicResource ComboItemHoverBrush}" Property="Border.Background" />
              <Setter TargetName="ItemSurface" Property="UIElement.Opacity" Value="1" />
              <Setter TargetName="ItemAccentBar" Property="UIElement.Opacity" Value="1" />
              <Setter Value="{DynamicResource ComboItemHoverAccentBrush}" Property="Foreground" />
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="ListBoxItem.IsSelected" Value="True" />
                <Condition Property="ComboBoxItem.IsHighlighted" Value="True" />
              </MultiTrigger.Conditions>
              <Setter TargetName="ItemSurface" Value="{DynamicResource ComboItemSelectedActiveBrush}" Property="Border.Background" />
              <Setter TargetName="ItemSurface" Property="UIElement.Opacity" Value="1" />
              <Setter TargetName="ItemAccentBar" Value="{DynamicResource ComboItemSelectedForegroundBrush}" Property="Shape.Fill" />
              <Setter TargetName="ItemAccentBar" Property="UIElement.Opacity" Value="1" />
              <Setter Value="{DynamicResource ComboItemSelectedForegroundBrush}" Property="Foreground" />
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="UIElement.Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="PollingRateModeToggleStyle" TargetType="{x:Type ToggleButton}">
    <Setter Property="Width" Value="{StaticResource Layout.PollingModeSwitch.Width}" />
    <Setter Property="Height" Value="{StaticResource Layout.PollingModeSwitch.Height}" />
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="Background" Value="{DynamicResource TitleBarModeButtonBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
    <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ToggleButton}">
          <Grid Name="TemplateRoot" SnapsToDevicePixels="True">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CheckStates">
                <VisualState x:Name="Unchecked">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="0" Duration="{StaticResource MotionMediumDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="MotionText" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="RawText" Storyboard.TargetProperty="Opacity" To="0.72" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Checked">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ThumbTransform" Storyboard.TargetProperty="X" To="{StaticResource Layout.PollingModeSwitch.ThumbTravel}" Duration="{StaticResource MotionMediumDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="MotionText" Storyboard.TargetProperty="Opacity" To="0.72" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="RawText" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                  </Storyboard>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Border Name="TrackBorder" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="23" SnapsToDevicePixels="True" Opacity="0.96">
              <Grid Margin="4" ClipToBounds="True">
                <Border Name="Thumb" Background="{DynamicResource VoltGreenBrush}" CornerRadius="19" HorizontalAlignment="Left" Opacity="0.94" Width="{StaticResource Layout.PollingModeSwitch.ThumbWidth}">
                  <UIElement.RenderTransform>
                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                  </UIElement.RenderTransform>
                </Border>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Name="MotionText" Grid.Column="0" Text="{DynamicResource Control.ReportMode.MotionReport}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.Meta}" FontWeight="{DynamicResource TextWeight.SecondaryButton}" FontSize="{DynamicResource TypeScale.SecondaryButton}" Foreground="{DynamicResource AccentForegroundBrush}" Opacity="1" />
                  <TextBlock Name="RawText" Grid.Column="1" Text="{DynamicResource Control.ReportMode.RawPacket}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="{DynamicResource Font.Meta}" FontWeight="{DynamicResource TextWeight.SecondaryButton}" FontSize="{DynamicResource TypeScale.SecondaryButton}" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.72" />
                </Grid>
              </Grid>
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="ToggleButton.IsChecked" Value="True">
              <Setter TargetName="MotionText" Value="{DynamicResource TextMutedBrush}" Property="TextBlock.Foreground" />
              <Setter TargetName="RawText" Value="{DynamicResource AccentForegroundBrush}" Property="TextBlock.Foreground" />
            </Trigger>
            <Trigger Property="ToggleButton.IsChecked" Value="False">
              <Setter TargetName="MotionText" Value="{DynamicResource AccentForegroundBrush}" Property="TextBlock.Foreground" />
              <Setter TargetName="RawText" Value="{DynamicResource TextMutedBrush}" Property="TextBlock.Foreground" />
            </Trigger>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="TrackBorder" Property="UIElement.Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="TrackBorder" Property="UIElement.Opacity" Value="0.9" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="TrackBorder" Property="UIElement.Opacity" Value="0.34" />
              <Setter TargetName="Thumb" Property="UIElement.Opacity" Value="0.45" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
