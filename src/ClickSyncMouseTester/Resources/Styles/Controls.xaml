            <Trigger Property="Thumb.IsDragging" Value="True">
              <Setter TargetName="ThumbBody" Value="{DynamicResource VoltGreenBrush}" Property="Border.Background" />
              <Setter TargetName="ThumbBody" Property="UIElement.Opacity" Value="1" />
