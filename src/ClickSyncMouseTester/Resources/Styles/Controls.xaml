<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="{x:Type ToolTip}" TargetType="{x:Type ToolTip}">
    <Setter Property="FontFamily" Value="{DynamicResource Font.Body}" />
    <Setter Property="FontWeight" Value="{DynamicResource TextWeight.Hint}" />
    <Setter Property="FontSize" Value="{DynamicResource TypeScale.Hint}" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
    <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="FrameworkElement.UseLayoutRounding" Value="True" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="Background" Value="{DynamicResource GlassPopupBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource GlassPopupBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ToolTip}">
          <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border Margin="0,2,0,-2" Background="{DynamicResource GlassTooltipShadowBrush}" IsHitTestVisible="False" />
            <Border Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.ClearTypeHint="{StaticResource ClearTypeHint.Enabled}" />
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="VoltButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    <Setter Property="Background" Value="{DynamicResource VoltGreenBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontFamily" Value="{DynamicResource Font.Meta}" />
    <Setter Property="FontWeight" Value="{DynamicResource TextWeight.PrimaryButton}" />
    <Setter Property="FontSize" Value="{DynamicResource TypeScale.PrimaryButton}" />
    <Setter Property="Padding" Value="0,20" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
    <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Name="ButtonBorder" Background="{TemplateBinding Control.Background}" Padding="{TemplateBinding Control.Padding}" Opacity="0.94" RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <UIElement.RenderTransform>
              <ScaleTransform ScaleX="1" ScaleY="1" />
            </UIElement.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="ButtonBorder" Value="{DynamicResource VoltGreenHoverBrush}" Property="Border.Background" />
              <TriggerBase.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource MotionQuickDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.EnterActions>
              <TriggerBase.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="Opacity" To="0.94" Duration="{StaticResource MotionQuickDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ButtonBorder" Property="UIElement.Opacity" Value="0.82" />
              <Setter TargetName="ButtonBorder" Property="UIElement.RenderTransform">
                <Setter.Value>
                  <ScaleTransform ScaleX="{StaticResource MotionPressScale.Primary}" ScaleY="{StaticResource MotionPressScale.Primary}" />
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="ButtonBorder" Property="UIElement.Opacity" Value="0.2" />
              <Setter TargetName="ButtonBorder" Value="{DynamicResource TextMutedBrush}" Property="Border.Background" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="MinimalGhostButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontFamily" Value="{DynamicResource Font.Meta}" />
    <Setter Property="FontWeight" Value="{DynamicResource TextWeight.SecondaryButton}" />
    <Setter Property="FontSize" Value="{DynamicResource TypeScale.SecondaryButton}" />
    <Setter Property="Padding" Value="16,8" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
    <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Name="ButtonBorder" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" Padding="{TemplateBinding Control.Padding}" Opacity="0.9" RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <UIElement.RenderTransform>
              <ScaleTransform ScaleX="1" ScaleY="1" />
            </UIElement.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="ButtonBorder" Value="{DynamicResource GhostHoverBrush}" Property="Border.Background" />
              <Setter TargetName="ButtonBorder" Value="{DynamicResource TextStrongBrush}" Property="Border.BorderBrush" />
              <TriggerBase.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource MotionQuickDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.EnterActions>
              <TriggerBase.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="Opacity" To="0.9" Duration="{StaticResource MotionQuickDuration}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ButtonBorder" Property="UIElement.Opacity" Value="0.72" />
              <Setter TargetName="ButtonBorder" Property="UIElement.RenderTransform">
                <Setter.Value>
                  <ScaleTransform ScaleX="{StaticResource MotionPressScale.Secondary}" ScaleY="{StaticResource MotionPressScale.Secondary}" />
                </Setter.Value>
              </Setter>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="ButtonBorder" Property="UIElement.Opacity" Value="0.3" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="HeaderToggleLinkButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
    <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
    <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Name="ButtonSurface" Background="{TemplateBinding Control.Background}" Padding="{TemplateBinding Control.Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="HeaderToggleActiveTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource BaseTextBlockStyle}">
    <Setter Property="FontFamily" Value="{DynamicResource Font.ListDisplay}" />
    <Setter Property="FontWeight" Value="{StaticResource TextWeight.InvariantEnglish.MicroLabel}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style x:Key="HeaderToggleLinkTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderToggleActiveTextStyle}">
    <Setter Property="UIElement.Opacity" Value="0.3" />
    <Style.Triggers>
      <DataTrigger Value="True" Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}">
        <Setter Property="UIElement.Opacity" Value="1" />
      </DataTrigger>
      <DataTrigger Value="True" Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}">
        <Setter Property="UIElement.Opacity" Value="1" />
      </DataTrigger>
      <DataTrigger Value="False" Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}">
        <Setter Property="UIElement.Opacity" Value="0.3" />
      </DataTrigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="HeaderToggleDividerTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource BaseTextBlockStyle}">
    <Setter Property="FontFamily" Value="{DynamicResource Font.ListDisplay}" />
    <Setter Property="FontWeight" Value="{StaticResource TextWeight.InvariantEnglish.MicroLabel}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="UIElement.Opacity" Value="0.3" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style x:Key="NavigationToggleActiveTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource BaseTextBlockStyle}">
    <Setter Property="FontFamily" Value="{DynamicResource Font.ListDisplay}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="Foreground" Value="{DynamicResource NavigationMenuTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.Grayscale}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
  </Style>
  <Style x:Key="NavigationToggleLinkTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource NavigationToggleActiveTextStyle}">
    <Setter Property="UIElement.Opacity" Value="0.3" />
    <Style.Triggers>
      <DataTrigger Value="True" Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}">
        <Setter Property="UIElement.Opacity" Value="1" />
      </DataTrigger>
      <DataTrigger Value="True" Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}">
        <Setter Property="UIElement.Opacity" Value="1" />
      </DataTrigger>
      <DataTrigger Value="False" Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}">
        <Setter Property="UIElement.Opacity" Value="0.3" />
      </DataTrigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="NavigationToggleDividerTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource NavigationToggleActiveTextStyle}">
    <Setter Property="UIElement.Opacity" Value="0.3" />
  </Style>
  <Style x:Key="HamburgerNavigationButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Width" Value="{StaticResource Layout.Chrome.NavigationButtonWidth}" />
    <Setter Property="Height" Value="{StaticResource Layout.Chrome.NavigationButtonHeight}" />
    <Setter Property="Foreground" Value="{DynamicResource NavigationButtonGlyphBrush}" />
    <Setter Property="Background" Value="{DynamicResource NavigationButtonSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource NavigationButtonSurfaceBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Name="ButtonBorder" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" SnapsToDevicePixels="True" Opacity="1">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True" Width="{StaticResource Layout.Chrome.NavigationGlyphWidth}" Height="{StaticResource Layout.Chrome.NavigationGlyphHeight}" Margin="{StaticResource Layout.Chrome.NavigationGlyphMargin}">
              <Rectangle Name="TopLine" Height="1" HorizontalAlignment="Center" VerticalAlignment="Top" SnapsToDevicePixels="True" Fill="{TemplateBinding Control.Foreground}" Width="{StaticResource Layout.Chrome.NavigationGlyphLineWidth}" />
              <Rectangle Name="MiddleLine" Height="1" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True" Fill="{TemplateBinding Control.Foreground}" Width="{StaticResource Layout.Chrome.NavigationGlyphLineWidth}" />
              <Rectangle Name="BottomLine" Height="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" SnapsToDevicePixels="True" Fill="{TemplateBinding Control.Foreground}" Width="{StaticResource Layout.Chrome.NavigationGlyphLineWidth}" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="ButtonBorder" Value="{DynamicResource NavigationButtonSurfaceBrush}" Property="Border.Background" />
              <Setter TargetName="ButtonBorder" Value="{DynamicResource NavigationButtonSurfaceBrush}" Property="Border.BorderBrush" />
              <Setter TargetName="TopLine" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
              <Setter TargetName="MiddleLine" Value="{DynamicResource NavigationButtonGlyphBrush}" Property="Shape.Fill" />
              <Setter TargetName="BottomLine" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ButtonBorder" Value="{DynamicResource VoltGreenBrush}" Property="Border.Background" />
              <Setter TargetName="ButtonBorder" Value="{DynamicResource VoltGreenBrush}" Property="Border.BorderBrush" />
              <Setter Value="{DynamicResource AccentForegroundBrush}" Property="Foreground" />
              <Setter TargetName="TopLine" Value="{DynamicResource AccentForegroundBrush}" Property="Shape.Fill" />
              <Setter TargetName="MiddleLine" Value="{DynamicResource AccentForegroundBrush}" Property="Shape.Fill" />
              <Setter TargetName="BottomLine" Value="{DynamicResource AccentForegroundBrush}" Property="Shape.Fill" />
            </Trigger>
            <DataTrigger Value="True" Binding="{Binding IsNavigationMenuOpen}">
              <Setter TargetName="ButtonBorder" Value="{DynamicResource NavigationButtonSurfaceBrush}" Property="Border.Background" />
              <Setter TargetName="ButtonBorder" Value="{DynamicResource NavigationButtonSurfaceBrush}" Property="Border.BorderBrush" />
              <Setter TargetName="TopLine" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
              <Setter TargetName="MiddleLine" Value="{DynamicResource NavigationButtonGlyphBrush}" Property="Shape.Fill" />
              <Setter TargetName="BottomLine" Value="{DynamicResource VoltGreenBrush}" Property="Shape.Fill" />
            </DataTrigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="ButtonBorder" Property="UIElement.Opacity" Value="0.35" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="NavigationCurtainMenuButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Foreground" Value="{DynamicResource NavigationMenuTextBrush}" />
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="BorderBrush" Value="#00FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MinHeight" Value="{DynamicResource Layout.Navigation.MenuItemMinHeight.Localized}" />
    <Setter Property="Padding" Value="{DynamicResource Layout.Navigation.ItemPadding.Localized}" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid ClipToBounds="True" Background="{TemplateBinding Control.Background}">
            <Border Name="HoverSurface" Background="{DynamicResource NavigationMenuHoverSurfaceBrush}" Opacity="0" IsHitTestVisible="False" />
            <ContentPresenter Name="MenuContent" Margin="{TemplateBinding Control.Padding}" HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}" VerticalAlignment="Center" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="HoverSurface" Property="UIElement.Opacity" Value="1" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="NavigationCurtainCloseButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Width" Value="76" />
    <Setter Property="Height" Value="76" />
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="BorderBrush" Value="#00FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Name="ButtonSurface" Background="{TemplateBinding Control.Background}" ClipToBounds="False" SnapsToDevicePixels="True">
            <Grid Width="66" Height="66" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="False" SnapsToDevicePixels="True">
              <Grid Width="60" Height="3" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="False" RenderTransformOrigin="0.5,0.5">
                <UIElement.RenderTransform>
                  <RotateTransform Angle="45" />
                </UIElement.RenderTransform>
                <Border Name="PrimaryCloseLine" CornerRadius="1.5" Background="{DynamicResource NavigationMenuTextBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RenderTransformOrigin="0,0.5" SnapsToDevicePixels="True">
                  <UIElement.RenderTransform>
                    <ScaleTransform x:Name="PrimaryCloseLineScale" ScaleX="0" ScaleY="1" />
                  </UIElement.RenderTransform>
                </Border>
              </Grid>
              <Grid Width="60" Height="3" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="False" RenderTransformOrigin="0.5,0.5">
                <UIElement.RenderTransform>
                  <RotateTransform Angle="-45" />
                </UIElement.RenderTransform>
                <Border Name="SecondaryCloseLine" CornerRadius="1.5" Background="{DynamicResource NavigationMenuTextBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RenderTransformOrigin="1,0.5" SnapsToDevicePixels="True">
                  <UIElement.RenderTransform>
                    <ScaleTransform x:Name="SecondaryCloseLineScale" ScaleX="0" ScaleY="1" />
                  </UIElement.RenderTransform>
                </Border>
              </Grid>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="ButtonSurface" Value="{DynamicResource NavigationMenuTextBrush}" Property="Border.Background" />
              <Setter TargetName="PrimaryCloseLine" Value="{DynamicResource NavigationCurtainBackgroundBrush}" Property="Border.Background" />
              <Setter TargetName="SecondaryCloseLine" Value="{DynamicResource NavigationCurtainBackgroundBrush}" Property="Border.Background" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ButtonSurface" Value="{DynamicResource NavigationMenuTextBrush}" Property="Border.Background" />
              <Setter TargetName="PrimaryCloseLine" Value="{DynamicResource NavigationCurtainBackgroundBrush}" Property="Border.Background" />
              <Setter TargetName="SecondaryCloseLine" Value="{DynamicResource NavigationCurtainBackgroundBrush}" Property="Border.Background" />
            </Trigger>
            <DataTrigger Value="True" Binding="{Binding IsNavigationMenuOpen}">
              <TriggerBase.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PrimaryCloseLineScale" Storyboard.TargetProperty="ScaleX" To="1" BeginTime="0:0:0.4" Duration="{StaticResource MotionNavigationItemEnterDuration}" EasingFunction="{StaticResource MotionNavigationContentEnterEase}" />
                    <DoubleAnimation Storyboard.TargetName="SecondaryCloseLineScale" Storyboard.TargetProperty="ScaleX" To="1" BeginTime="0:0:0.4" Duration="{StaticResource MotionNavigationItemEnterDuration}" EasingFunction="{StaticResource MotionNavigationContentEnterEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.EnterActions>
              <TriggerBase.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PrimaryCloseLineScale" Storyboard.TargetProperty="ScaleX" To="0" BeginTime="0:0:0.72" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionNavigationCurtainExitEase}" />
                    <DoubleAnimation Storyboard.TargetName="SecondaryCloseLineScale" Storyboard.TargetProperty="ScaleX" To="0" BeginTime="0:0:0.72" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionNavigationCurtainExitEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.ExitActions>
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="TitleBarButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Width" Value="{StaticResource Layout.Chrome.IconButtonWidth}" />
    <Setter Property="Height" Value="{StaticResource Layout.Chrome.ModeButtonHeight}" />
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
    <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
    <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Name="ButtonBorder" Background="{TemplateBinding Control.Background}" Opacity="0.9" RenderTransformOrigin="0.5,0.5">
            <UIElement.RenderTransform>
              <ScaleTransform ScaleX="1" ScaleY="1" />
            </UIElement.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="ButtonBorder" Value="{DynamicResource GhostHoverBrush}" Property="Border.Background" />
              <Setter Value="{DynamicResource TextStrongBrush}" Property="Foreground" />
              <TriggerBase.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource MotionQuickDuration}" />
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.EnterActions>
              <TriggerBase.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="Opacity" To="0.9" Duration="{StaticResource MotionQuickDuration}" />
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ButtonBorder" Property="UIElement.Opacity" Value="0.7" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="TitleBarCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TitleBarButtonStyle}">
    <Setter Property="Width" Value="{StaticResource Layout.Chrome.CloseButtonWidth}" />
    <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Name="ButtonBorder" Background="{TemplateBinding Control.Background}" Opacity="0.92" RenderTransformOrigin="0.5,0.5">
            <UIElement.RenderTransform>
              <ScaleTransform ScaleX="1" ScaleY="1" />
            </UIElement.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="ButtonBorder" Value="{DynamicResource VoltGreenBrush}" Property="Border.Background" />
              <Setter Value="{DynamicResource AccentForegroundBrush}" Property="Foreground" />
              <TriggerBase.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource MotionQuickDuration}" />
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.015" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.015" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionOutEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.EnterActions>
              <TriggerBase.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="Opacity" To="0.92" Duration="{StaticResource MotionQuickDuration}" />
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                    <DoubleAnimation Storyboard.TargetName="ButtonBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
                  </Storyboard>
                </BeginStoryboard>
              </TriggerBase.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="ButtonBorder" Property="UIElement.Opacity" Value="0.76" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="StatusLampStyle" TargetType="{x:Type Ellipse}">
    <Setter Property="Width" Value="{StaticResource Layout.Chrome.LampSize}" />
    <Setter Property="Height" Value="{StaticResource Layout.Chrome.LampSize}" />
    <Setter Property="Fill" Value="{DynamicResource TextFaintBrush}" />
    <Setter Property="UIElement.Opacity" Value="0.45" />
    <Setter Property="UIElement.RenderTransformOrigin" Value="0.5,0.5" />
    <Setter Property="RenderTransform">
      <Setter.Value>
        <ScaleTransform ScaleX="1" ScaleY="1" />
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Value="True" Binding="{Binding IsLocked}">
        <Setter Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
        <Setter Property="UIElement.Opacity" Value="1" />
        <TriggerBase.EnterActions>
          <BeginStoryboard Name="LockedLampPulse">
            <Storyboard AutoReverse="True" RepeatBehavior="Forever">
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.62" Duration="{StaticResource MotionPulseDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.18" Duration="{StaticResource MotionPulseDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.18" Duration="{StaticResource MotionPulseDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
            </Storyboard>
          </BeginStoryboard>
        </TriggerBase.EnterActions>
        <TriggerBase.ExitActions>
          <StopStoryboard BeginStoryboardName="LockedLampPulse" />
          <BeginStoryboard>
            <Storyboard>
              <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.45" Duration="{StaticResource MotionQuickDuration}" />
              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
              <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="{StaticResource MotionQuickDuration}" EasingFunction="{StaticResource MotionInOutEase}" />
            </Storyboard>
          </BeginStoryboard>
        </TriggerBase.ExitActions>
      </DataTrigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="AvantGardeComboPopupScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
