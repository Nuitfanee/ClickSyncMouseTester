<?xml version="1.0" encoding="utf-8"?>
<Application x:Class="ClickSyncMouseTester.Application" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:pageViews="clr-namespace:ClickSyncMouseTester.Views.Pages" xmlns:pageViewModels="clr-namespace:ClickSyncMouseTester.ViewModels.Pages" xmlns:viewModels="clr-namespace:ClickSyncMouseTester.ViewModels" xmlns:ClickSyncMouseTester="clr-namespace:ClickSyncMouseTester">
