                        <BeginStoryboard x:Name="LockedLampPulse">
                            <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0.62"
                                                 Duration="{StaticResource MotionPulseDuration}"
                                                 EasingFunction="{StaticResource MotionInOutEase}" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1.18"
                                                 Duration="{StaticResource MotionPulseDuration}"
                                                 EasingFunction="{StaticResource MotionInOutEase}" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="1.18"
                                                 Duration="{StaticResource MotionPulseDuration}"
                                                 EasingFunction="{StaticResource MotionInOutEase}" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="LockedLampPulse" />
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0.45"
                                                 Duration="{StaticResource MotionQuickDuration}" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="1"
                                                 Duration="{StaticResource MotionQuickDuration}"
                                                 EasingFunction="{StaticResource MotionInOutEase}" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
