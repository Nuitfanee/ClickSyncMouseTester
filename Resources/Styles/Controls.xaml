                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
