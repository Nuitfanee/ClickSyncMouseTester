        <Style x:Key="AvantGardeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.ListDisplay}" />
            <Setter Property="FontWeight" Value="{DynamicResource TextWeight.ComboBox}" />
            <Setter Property="FontSize" Value="{DynamicResource TypeScale.ComboBox}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.Grayscale}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Opacity="0.92" />
                            <Border x:Name="ActiveLine"
                                    Height="1"
                                    Margin="0,0,18,0"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Stretch"
                                    Background="{DynamicResource VoltGreenBrush}"
                                    Opacity="0.92"
                                    RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="0" />
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="8,12,32,12"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              SnapsToDevicePixels="True"
                                              IsHitTestVisible="False" />
                            <Border Width="24" HorizontalAlignment="Right" Background="Transparent">
                                <Path x:Name="Arrow"
                                      Width="8"
                                      Height="4"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M 0 0 L 8 0 L 4 4 z"
                                      Fill="{DynamicResource TextMutedBrush}"
                                      Opacity="0.72"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Path.RenderTransform>
                                </Path>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="300"
                                        Background="{DynamicResource GlassPopupBackgroundBrush}"
                                        BorderBrush="{DynamicResource GlassPopupBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="ScrollBar"
                                                   BasedOn="{StaticResource AvantGardeComboPopupScrollBarStyle}" />
                                        </ScrollViewer.Resources>
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource TextStrongBrush}" />
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="1" />
                                <Setter TargetName="Arrow" Property="Opacity" Value="1" />
                                <Setter TargetName="ActiveLine" Property="Opacity" Value="0.42" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="1" />
                                <Setter TargetName="Arrow" Property="Opacity" Value="1" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             To="180"
                                                             Duration="{StaticResource MotionMediumDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ActiveLine"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1"
                                                             Duration="{StaticResource MotionMediumDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             To="0"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ActiveLine"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="0"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.45" />
                                <Setter TargetName="Arrow" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.Grayscale}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" SnapsToDevicePixels="True">
                            <Grid ClipToBounds="True">
                                <Border x:Name="ItemSurface"
                                        Background="Transparent"
                                        Opacity="0" />
                                <Rectangle x:Name="ItemAccentBar"
                                           Width="2"
                                           HorizontalAlignment="Left"
                                           Fill="{DynamicResource ComboItemHoverAccentBrush}"
                                           Opacity="0" />
                                <ContentPresenter x:Name="ItemContent"
                                                  Margin="{TemplateBinding Padding}"
                                                  SnapsToDevicePixels="True"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemSurface" Property="Background" Value="{DynamicResource ComboItemSelectedBrush}" />
                                <Setter TargetName="ItemSurface" Property="Opacity" Value="1" />
                                <Setter TargetName="ItemAccentBar" Property="Fill" Value="{DynamicResource ComboItemSelectedForegroundBrush}" />
                                <Setter TargetName="ItemAccentBar" Property="Opacity" Value="0.72" />
                                <Setter Property="Foreground" Value="{DynamicResource ComboItemSelectedForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemSurface" Property="Background" Value="{DynamicResource ComboItemHoverBrush}" />
                                <Setter TargetName="ItemSurface" Property="Opacity" Value="1" />
                                <Setter TargetName="ItemAccentBar" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource ComboItemHoverAccentBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsHighlighted" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemSurface" Property="Background" Value="{DynamicResource ComboItemSelectedActiveBrush}" />
                                <Setter TargetName="ItemSurface" Property="Opacity" Value="1" />
                                <Setter TargetName="ItemAccentBar" Property="Fill" Value="{DynamicResource ComboItemSelectedForegroundBrush}" />
                                <Setter TargetName="ItemAccentBar" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource ComboItemSelectedForegroundBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PollingRateModeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="{StaticResource Layout.PollingModeSwitch.Width}" />
            <Setter Property="Height" Value="{StaticResource Layout.PollingModeSwitch.Height}" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="{DynamicResource TitleBarModeButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid x:Name="TemplateRoot" SnapsToDevicePixels="True">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="0"
                                                             Duration="{StaticResource MotionMediumDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MotionText"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="RawText"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.72"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                                             Storyboard.TargetProperty="X"
                                                             To="{StaticResource Layout.PollingModeSwitch.ThumbTravel}"
                                                             Duration="{StaticResource MotionMediumDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="MotionText"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.72"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="RawText"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Border x:Name="TrackBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="23"
                                    SnapsToDevicePixels="True"
                                    Opacity="0.96">
                                <Grid Margin="4" ClipToBounds="True">
                                    <Border x:Name="Thumb"
                                            Width="{StaticResource Layout.PollingModeSwitch.ThumbWidth}"
                                            Background="{DynamicResource VoltGreenBrush}"
                                            CornerRadius="19"
                                            HorizontalAlignment="Left"
                                            Opacity="0.94">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="ThumbTransform" X="0" />
                                        </Border.RenderTransform>
                                    </Border>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="MotionText"
                                                   Grid.Column="0"
                                                   Text="{DynamicResource Control.ReportMode.MotionReport}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{DynamicResource Font.Meta}"
                                                   FontWeight="{DynamicResource TextWeight.SecondaryButton}"
                                                   FontSize="{DynamicResource TypeScale.SecondaryButton}"
                                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                                   Opacity="1" />
                                        <TextBlock x:Name="RawText"
                                                   Grid.Column="1"
                                                   Text="{DynamicResource Control.ReportMode.RawPacket}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{DynamicResource Font.Meta}"
                                                   FontWeight="{DynamicResource TextWeight.SecondaryButton}"
                                                   FontSize="{DynamicResource TypeScale.SecondaryButton}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Opacity="0.72" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="MotionText" Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                <Setter TargetName="RawText" Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="MotionText" Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                <Setter TargetName="RawText" Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackBorder" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TrackBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TrackBorder" Property="Opacity" Value="0.34" />
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

