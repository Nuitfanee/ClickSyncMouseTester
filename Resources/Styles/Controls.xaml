<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

        <Style TargetType="ToolTip">
            <Setter Property="FontFamily" Value="{DynamicResource Font.Body}" />
            <Setter Property="FontWeight" Value="{DynamicResource TextWeight.Hint}" />
            <Setter Property="FontSize" Value="{DynamicResource TypeScale.Hint}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style x:Key="VoltButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource VoltGreenBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Meta}" />
            <Setter Property="FontWeight" Value="{DynamicResource TextWeight.PrimaryButton}" />
            <Setter Property="FontSize" Value="{DynamicResource TypeScale.PrimaryButton}" />
            <Setter Property="Padding" Value="0,20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Opacity="0.94">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource VoltGreenHoverBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.94"
                                                             Duration="{StaticResource MotionQuickDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                                <Setter TargetName="ButtonBorder" Property="Margin" Value="0,1,0,-1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.2" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource TextMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalGhostButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource HairlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Meta}" />
            <Setter Property="FontWeight" Value="{DynamicResource TextWeight.SecondaryButton}" />
            <Setter Property="FontSize" Value="{DynamicResource TypeScale.SecondaryButton}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                Opacity="0.9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource TextStrongBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.9"
                                                             Duration="{StaticResource MotionQuickDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderToggleLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="RenderOptions.ClearTypeHint" Value="{StaticResource ClearTypeHint.Enabled}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderToggleActiveTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.ListDisplay}" />
            <Setter Property="FontWeight" Value="{StaticResource TextWeight.InvariantEnglish.MicroLabel}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderToggleLinkTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderToggleActiveTextStyle}">
            <Setter Property="Opacity" Value="0.3" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                    <Setter Property="Opacity" Value="0.3" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderToggleDividerTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.ListDisplay}" />
            <Setter Property="FontWeight" Value="{StaticResource TextWeight.InvariantEnglish.MicroLabel}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Opacity" Value="0.3" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="NavigationToggleActiveTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BaseTextBlockStyle}">
            <Setter Property="FontFamily" Value="{DynamicResource Font.ListDisplay}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Foreground" Value="{DynamicResource NavigationMenuTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.Grayscale}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
        </Style>

        <Style x:Key="NavigationToggleLinkTextStyle" TargetType="TextBlock" BasedOn="{StaticResource NavigationToggleActiveTextStyle}">
            <Setter Property="Opacity" Value="0.3" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                    <Setter Property="Opacity" Value="0.3" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavigationToggleDividerTextStyle" TargetType="TextBlock" BasedOn="{StaticResource NavigationToggleActiveTextStyle}">
            <Setter Property="Opacity" Value="0.3" />
        </Style>

        <Style x:Key="HamburgerNavigationButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="{StaticResource Layout.Chrome.NavigationButtonWidth}" />
            <Setter Property="Height" Value="{StaticResource Layout.Chrome.NavigationButtonHeight}" />
            <Setter Property="Foreground" Value="{DynamicResource NavigationButtonGlyphBrush}" />
            <Setter Property="Background" Value="{DynamicResource NavigationButtonSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource NavigationButtonSurfaceBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True"
                                Opacity="1">
                            <Grid Width="{StaticResource Layout.Chrome.NavigationGlyphWidth}"
                                  Height="{StaticResource Layout.Chrome.NavigationGlyphHeight}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True"
                                  Margin="{StaticResource Layout.Chrome.NavigationGlyphMargin}">
                                <Rectangle x:Name="TopLine"
                                           Width="{StaticResource Layout.Chrome.NavigationGlyphLineWidth}"
                                           Height="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           SnapsToDevicePixels="True"
                                           Fill="{TemplateBinding Foreground}" />
                                <Rectangle x:Name="MiddleLine"
                                           Width="{StaticResource Layout.Chrome.NavigationGlyphLineWidth}"
                                           Height="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           SnapsToDevicePixels="True"
                                           Fill="{TemplateBinding Foreground}" />
                                <Rectangle x:Name="BottomLine"
                                           Width="{StaticResource Layout.Chrome.NavigationGlyphLineWidth}"
                                           Height="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           SnapsToDevicePixels="True"
                                           Fill="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource NavigationButtonSurfaceBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource NavigationButtonSurfaceBrush}" />
                                <Setter TargetName="TopLine" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="MiddleLine" Property="Fill" Value="{DynamicResource NavigationButtonGlyphBrush}" />
                                <Setter TargetName="BottomLine" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                <Setter TargetName="TopLine" Property="Fill" Value="{DynamicResource AccentForegroundBrush}" />
                                <Setter TargetName="MiddleLine" Property="Fill" Value="{DynamicResource AccentForegroundBrush}" />
                                <Setter TargetName="BottomLine" Property="Fill" Value="{DynamicResource AccentForegroundBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsNavigationMenuOpen}" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource NavigationButtonSurfaceBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource NavigationButtonSurfaceBrush}" />
                                <Setter TargetName="TopLine" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter TargetName="MiddleLine" Property="Fill" Value="{DynamicResource NavigationButtonGlyphBrush}" />
                                <Setter TargetName="BottomLine" Property="Fill" Value="{DynamicResource VoltGreenBrush}" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavigationCurtainMenuButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource NavigationMenuTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="{DynamicResource Layout.Navigation.MenuItemMinHeight.Localized}" />
            <Setter Property="Padding" Value="{DynamicResource Layout.Navigation.ItemPadding.Localized}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True"
                              Background="{TemplateBinding Background}">
                            <Border x:Name="HoverSurface"
                                    Background="{DynamicResource NavigationMenuHoverSurfaceBrush}"
                                    Opacity="0"
                                    IsHitTestVisible="False" />
                            <ContentPresenter x:Name="MenuContent"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverSurface" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavigationCurtainCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="76" />
            <Setter Property="Height" Value="76" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}"
                                ClipToBounds="False"
                                SnapsToDevicePixels="True">
                            <Grid Width="66"
                                  Height="66"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ClipToBounds="False"
                                  SnapsToDevicePixels="True">
                                <Grid Width="60"
                                      Height="3"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      ClipToBounds="False"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <RotateTransform Angle="45" />
                                    </Grid.RenderTransform>
                                    <Border x:Name="PrimaryCloseLine"
                                            CornerRadius="1.5"
                                            Background="{DynamicResource NavigationMenuTextBrush}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            RenderTransformOrigin="0,0.5"
                                            SnapsToDevicePixels="True">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="PrimaryCloseLineScale" ScaleX="0" ScaleY="1" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                                <Grid Width="60"
                                      Height="3"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      ClipToBounds="False"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <RotateTransform Angle="-45" />
                                    </Grid.RenderTransform>
                                    <Border x:Name="SecondaryCloseLine"
                                            CornerRadius="1.5"
                                            Background="{DynamicResource NavigationMenuTextBrush}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            RenderTransformOrigin="1,0.5"
                                            SnapsToDevicePixels="True">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="SecondaryCloseLineScale" ScaleX="0" ScaleY="1" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource NavigationMenuTextBrush}" />
                                <Setter TargetName="PrimaryCloseLine" Property="Background" Value="{DynamicResource NavigationCurtainBackgroundBrush}" />
                                <Setter TargetName="SecondaryCloseLine" Property="Background" Value="{DynamicResource NavigationCurtainBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource NavigationMenuTextBrush}" />
                                <Setter TargetName="PrimaryCloseLine" Property="Background" Value="{DynamicResource NavigationCurtainBackgroundBrush}" />
                                <Setter TargetName="SecondaryCloseLine" Property="Background" Value="{DynamicResource NavigationCurtainBackgroundBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsNavigationMenuOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PrimaryCloseLineScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             BeginTime="0:0:0.4"
                                                             Duration="{StaticResource MotionNavigationItemEnterDuration}"
                                                             EasingFunction="{StaticResource MotionNavigationContentEnterEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SecondaryCloseLineScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             BeginTime="0:0:0.4"
                                                             Duration="{StaticResource MotionNavigationItemEnterDuration}"
                                                             EasingFunction="{StaticResource MotionNavigationContentEnterEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PrimaryCloseLineScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0"
                                                             BeginTime="0:0:0.72"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionNavigationCurtainExitEase}" />
                                            <DoubleAnimation Storyboard.TargetName="SecondaryCloseLineScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0"
                                                             BeginTime="0:0:0.72"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionNavigationCurtainExitEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="{StaticResource Layout.Chrome.IconButtonWidth}" />
            <Setter Property="Height" Value="{StaticResource Layout.Chrome.ModeButtonHeight}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="TextOptions.TextRenderingMode" Value="{StaticResource TextRenderingMode.ClearType}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="{StaticResource TextFormattingMode.UI}" />
            <Setter Property="TextOptions.TextHintingMode" Value="{StaticResource TextHintingMode.UI}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                Opacity="0.9"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource GhostHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.02"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.02"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.9"
                                                             Duration="{StaticResource MotionQuickDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionInOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Width" Value="{StaticResource Layout.Chrome.CloseButtonWidth}" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrongBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                Opacity="0.92"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource VoltGreenBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="{StaticResource MotionQuickDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.015"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.015"
                                                             Duration="{StaticResource MotionQuickDuration}"
                                                             EasingFunction="{StaticResource MotionOutEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                             Storyboard.TargetProperty="Opacity"
