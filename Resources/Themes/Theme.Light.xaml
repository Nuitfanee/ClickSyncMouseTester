<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#F7F8FA</Color>
    <Color x:Key="ControlPanelColor">#F4F6F8</Color>
    <Color x:Key="TextStrongColor">#13151A</Color>
    <Color x:Key="TextMutedColor">#6E7580</Color>
    <Color x:Key="TextFaintColor">#A7ADB6</Color>
    <Color x:Key="WindowOuterBorderColor">#33000000</Color>
    <Color x:Key="HairlineColor">#E3E6EA</Color>
    <Color x:Key="AccentColor">#5C35FF</Color>
    <Color x:Key="AccentHoverColor">#704DFF</Color>
    <Color x:Key="GhostHoverColor">#EEF2F6</Color>
    <Color x:Key="AccentForegroundColor">#FFFFFF</Color>
    <Color x:Key="TitleBarModeButtonBackgroundColor">#94FFFFFF</Color>
    <Color x:Key="TitleBarModeButtonHoverColor">#D6FFFFFF</Color>
    <Color x:Key="ComboItemHoverColor">#EDF1F5</Color>
    <Color x:Key="ComboItemHoverAccentColor">#3F7A1D</Color>
    <Color x:Key="ComboItemSelectedColor">#E9EDF8</Color>
    <Color x:Key="ComboItemSelectedActiveColor">#DFE6F8</Color>
    <Color x:Key="ComboItemSelectedForegroundColor">#704DFF</Color>
    <Color x:Key="HeroWatermarkColor">#F2F4F7</Color>
    <Color x:Key="ControlPanelTextureDotColor">#E9EDF1</Color>
    <Color x:Key="GlassTitleBarBackgroundColor">#ECFAFBFD</Color>
    <Color x:Key="GlassTitleBarBorderColor">#74DBE0E7</Color>
    <Color x:Key="GlassShellBackgroundColor">#EFF9FAFC</Color>
    <Color x:Key="GlassShellBorderColor">#70DCE1E8</Color>
    <Color x:Key="GlassPopupBackgroundColor">#F7ECEFF4</Color>
    <Color x:Key="GlassPopupBorderColor">#B2C8D0DA</Color>
    <Color x:Key="NavigationCurtainBackgroundColor">#1E3A89</Color>
    <Color x:Key="NavigationCurtainBorderColor">#1E3A89</Color>
    <Color x:Key="NavigationButtonSurfaceColor">#1E3A89</Color>
    <Color x:Key="NavigationButtonGlyphColor">#FFFFFF</Color>
    <Color x:Key="NavigationMenuTextColor">#000000</Color>
    <Color x:Key="NavigationMenuTextActiveColor">#FFFFFF</Color>
    <Color x:Key="NavigationMenuHoverSurfaceColor">#000000</Color>
    <Color x:Key="ChartBackgroundColor">#F7F8FA</Color>
    <Color x:Key="ChartGridColor">#E4E8ED</Color>
    <Color x:Key="ChartGridStrongColor">#D8DDE4</Color>
    <Color x:Key="ChartAxisColor">#BEC5CE</Color>
    <Color x:Key="ChartAreaFillColor">#15000000</Color>
    <Color x:Key="ChartLiveBandColor">#185C35FF</Color>
    <Color x:Key="ChartCurveUnderlayColor">#40FFFFFF</Color>
    <Color x:Key="ChartCurveColor">#1B1D22</Color>
    <Color x:Key="ChartAccentColor">#5C35FF</Color>
    <Color x:Key="ChartLabelColor">#747C86</Color>
    <Color x:Key="ChartStrongLabelColor">#16181D</Color>
    <Color x:Key="ChartBackdropColor">#ECEFF3</Color>
    <Color x:Key="ChartLatestPointFillColor">#5C35FF</Color>
    <Color x:Key="ChartLatestPointOuterColor">#F7F8FA</Color>
    <Color x:Key="ChartLatestPointOuterStrokeColor">#551B1D22</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="ControlPanelBrush" Color="{StaticResource ControlPanelColor}" />
    <SolidColorBrush x:Key="TextStrongBrush" Color="{StaticResource TextStrongColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaintColor}" />
    <SolidColorBrush x:Key="WindowOuterBorderBrush" Color="{StaticResource WindowOuterBorderColor}" />
    <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource HairlineColor}" />
    <SolidColorBrush x:Key="VoltGreenBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="VoltGreenHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="GhostHoverBrush" Color="{StaticResource GhostHoverColor}" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="{StaticResource AccentForegroundColor}" />
    <SolidColorBrush x:Key="TitleBarModeButtonBackgroundBrush" Color="{StaticResource TitleBarModeButtonBackgroundColor}" />
    <SolidColorBrush x:Key="TitleBarModeButtonHoverBrush" Color="{StaticResource TitleBarModeButtonHoverColor}" />
    <SolidColorBrush x:Key="ComboItemHoverBrush" Color="{StaticResource ComboItemHoverColor}" />
    <SolidColorBrush x:Key="ComboItemHoverAccentBrush" Color="{StaticResource ComboItemHoverAccentColor}" />
    <SolidColorBrush x:Key="ComboItemSelectedBrush" Color="{StaticResource ComboItemSelectedColor}" />
    <SolidColorBrush x:Key="ComboItemSelectedActiveBrush" Color="{StaticResource ComboItemSelectedActiveColor}" />
    <SolidColorBrush x:Key="ComboItemSelectedForegroundBrush" Color="{StaticResource ComboItemSelectedForegroundColor}" />
    <SolidColorBrush x:Key="HeroWatermarkBrush" Color="{StaticResource HeroWatermarkColor}" />
    <SolidColorBrush x:Key="ControlPanelTextureDotBrush" Color="{StaticResource ControlPanelTextureDotColor}" />
    <SolidColorBrush x:Key="GlassTitleBarBackgroundBrush" Color="{StaticResource GlassTitleBarBackgroundColor}" />
    <SolidColorBrush x:Key="GlassTitleBarBorderBrush" Color="{StaticResource GlassTitleBarBorderColor}" />
    <SolidColorBrush x:Key="GlassShellBackgroundBrush" Color="{StaticResource GlassShellBackgroundColor}" />
    <SolidColorBrush x:Key="GlassShellBorderBrush" Color="{StaticResource GlassShellBorderColor}" />
    <SolidColorBrush x:Key="GlassPopupBackgroundBrush" Color="{StaticResource GlassPopupBackgroundColor}" />
    <SolidColorBrush x:Key="GlassPopupBorderBrush" Color="{StaticResource GlassPopupBorderColor}" />
    <SolidColorBrush x:Key="NavigationCurtainBackgroundBrush" Color="{StaticResource NavigationCurtainBackgroundColor}" />
    <SolidColorBrush x:Key="NavigationCurtainBorderBrush" Color="{StaticResource NavigationCurtainBorderColor}" />
    <SolidColorBrush x:Key="NavigationButtonSurfaceBrush" Color="{StaticResource NavigationButtonSurfaceColor}" />
    <SolidColorBrush x:Key="NavigationButtonGlyphBrush" Color="{StaticResource NavigationButtonGlyphColor}" />
    <SolidColorBrush x:Key="NavigationMenuTextBrush" Color="{StaticResource NavigationMenuTextColor}" />
    <SolidColorBrush x:Key="NavigationMenuTextActiveBrush" Color="{StaticResource NavigationMenuTextActiveColor}" />
    <SolidColorBrush x:Key="NavigationMenuHoverSurfaceBrush" Color="{StaticResource NavigationMenuHoverSurfaceColor}" />
    <SolidColorBrush x:Key="ChartBackgroundBrush" Color="{StaticResource ChartBackgroundColor}" />
    <SolidColorBrush x:Key="ChartGridBrush" Color="{StaticResource ChartGridColor}" />
    <SolidColorBrush x:Key="ChartGridStrongBrush" Color="{StaticResource ChartGridStrongColor}" />
    <SolidColorBrush x:Key="ChartAxisBrush" Color="{StaticResource ChartAxisColor}" />
    <SolidColorBrush x:Key="ChartAreaFillBrush" Color="{StaticResource ChartAreaFillColor}" />
    <SolidColorBrush x:Key="ChartLiveBandBrush" Color="{StaticResource ChartLiveBandColor}" />
    <SolidColorBrush x:Key="ChartCurveUnderlayBrush" Color="{StaticResource ChartCurveUnderlayColor}" />
    <SolidColorBrush x:Key="ChartCurveBrush" Color="{StaticResource ChartCurveColor}" />
    <SolidColorBrush x:Key="ChartAccentBrush" Color="{StaticResource ChartAccentColor}" />
    <SolidColorBrush x:Key="ChartLabelBrush" Color="{StaticResource ChartLabelColor}" />
    <SolidColorBrush x:Key="ChartStrongLabelBrush" Color="{StaticResource ChartStrongLabelColor}" />
    <SolidColorBrush x:Key="ChartBackdropBrush" Color="{StaticResource ChartBackdropColor}" />
    <SolidColorBrush x:Key="ChartLatestPointFillBrush" Color="{StaticResource ChartLatestPointFillColor}" />
    <SolidColorBrush x:Key="ChartLatestPointOuterBrush" Color="{StaticResource ChartLatestPointOuterColor}" />
    <SolidColorBrush x:Key="ChartLatestPointOuterStrokeBrush" Color="{StaticResource ChartLatestPointOuterStrokeColor}" />

    <DrawingBrush x:Key="ControlPanelTextureBrush" TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource ControlPanelBrush}">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,4,4" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="{StaticResource ControlPanelTextureDotBrush}">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,1,1" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
</ResourceDictionary>
