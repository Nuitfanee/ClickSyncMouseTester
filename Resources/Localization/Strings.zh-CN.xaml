    <sys:String x:Key="MousePerformance.Status.NoDevice.Hint">重新连接鼠标后，设备列表会自动刷新。</sys:String>
    <sys:String x:Key="MousePerformance.Status.DeviceDisconnected.Pill">设备已断开</sys:String>
